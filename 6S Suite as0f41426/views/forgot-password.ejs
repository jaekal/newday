<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Forgot Password | 6S Tool Suite</title>
  <script src="/theme-init.js"></script>
  <link rel="stylesheet" href="/styles.css" />
</head>
<body class="full-bleed">
  <main class="auth-bg" role="main">
    <div class="auth-floating" aria-hidden="true">
      <div class="auth-bubble"></div>
      <div class="auth-bubble"></div>
      <div class="auth-bubble"></div>
      <div class="auth-bubble"></div>
    </div>

    <section class="auth-card" aria-label="Forgot password">
      <img src="/images/zt-logo.png" alt="ZT Systems Logo" class="auth-logo" />

      <h1>🔐 Forgot Password</h1>

      <% if (message) { %>
        <div class="mb-4 p-3 rounded" style="background: var(--accent); color:var(--accent-contrast); text-align:center;">
          <%= message %>
        </div>
      <% } %>

      <form method="POST" action="/auth/forgot" class="space-y-4">
        <div>
          <label for="uoe">Username or Email</label>
          <input type="text" id="uoe" name="usernameOrEmail" required autofocus class="form-input" />
        </div>

        <div>
          <button type="submit" class="btn-primary w-full">📩 Continue</button>
        </div>
      </form>

      <a href="/auth/login" class="auth-back-link">← Back to Login</a>
    </section>
  </main>
</body>
</html>

