<!--public/history/index.html-->
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="csp-nonce" content="<%= cspNonce %>">
  <meta name="viewport" content="width=device-width,initial-scale=1"/>
  <title>My History – 6S Tool Suite</title>
  <link rel="icon" href="/images/favicon.png" type="image/png"/>
  <script src="/theme-init.js"></script>
  <link rel="stylesheet" href="/styles.css"/>
  <style>
    .wrap { max-width:900px; margin:0 auto; padding:1rem; }
    .section-card { background:var(--surface); border:1px solid var(--border); border-radius:.75rem; padding:1rem; margin-bottom:1.25rem; box-shadow:var(--shadow); }
    .section-title { font-size:1rem; font-weight:800; margin-bottom:.75rem; display:flex; align-items:center; gap:.5rem; }
    table { width:100%; border-collapse:collapse; font-size:.88rem; }
    th, td { padding:.5rem .6rem; border-bottom:1px solid var(--border); text-align:left; }
    th { font-size:.78rem; font-weight:700; color:var(--fg-muted); text-transform:uppercase; letter-spacing:.04em; }
    tbody tr:hover { background:var(--row-hover); }
    .pill { display:inline-flex; padding:.15rem .5rem; border-radius:999px; font-size:.75rem; font-weight:700; }
    .pill-out      { background:var(--warn-bg); color:var(--warn); }
    .pill-returned { background:var(--ok-bg); color:var(--ok); }
    .pill-checkout { background:var(--status-checked); color:var(--accent-contrast); }
    .duration-warn { color:var(--warn); font-weight:700; }
    .duration-danger { color:var(--danger); font-weight:700; }
    .user-card { display:flex; align-items:center; gap:.85rem; padding:.75rem 1rem; background:var(--surface-strong); border-radius:.6rem; border:1px solid var(--border); margin-bottom:1.25rem; }
    .user-avatar { width:44px; height:44px; border-radius:50%; background:var(--accent); color:var(--accent-contrast); display:flex; align-items:center; justify-content:center; font-size:1.2rem; font-weight:800; flex-shrink:0; }
    .user-name { font-size:1.05rem; font-weight:700; }
    .user-meta { font-size:.83rem; color:var(--fg-muted); }
  </style>
</head>
<body>
  <div class="wrap">
    <!-- Suite Topbar -->
    <header class="suite-topbar" style="margin-bottom:1rem">
      <div class="brand">
        <div class="brand-title">🧑‍🔧 My History</div>
        <div class="brand-subtitle">Your checkouts and recent activity</div>
      </div>
      <div class="suite-actions">
        <a href="/home" class="home-button">🏠 Home</a>
        <a href="/kiosk/" class="btn-secondary" style="padding:.45rem .85rem;border-radius:.4rem;text-decoration:none;font-size:.88rem;border:1px solid var(--border)">↩ Kiosk</a>
        <label for="themeSelector" class="visually-hidden">Theme</label>
        <select id="themeSelector" class="theme-select" aria-label="Theme">
          <option value="theme-command">Command</option>
<option value="theme-atlas">Atlas</option>
<option value="theme-carbon">Carbon</option>
<option value="theme-grove">Grove</option>
<option value="theme-ember">Ember</option>
<option value="theme-harbor">Harbor</option>
<option value="theme-slate">Slate</option>
<option value="theme-orchid">Orchid</option>
<option value="theme-dusk">Dusk</option>
<option value="theme-pulse">Pulse</option>
<option value="theme-highcontrast">High Contrast</option>
        </select>
      </div>
    </header>

    <!-- User identity card (populated by JS) -->
    <div class="user-card" id="userCard" style="display:none">
      <div class="user-avatar" id="userAvatar">?</div>
      <div>
        <div class="user-name" id="userName">Loading…</div>
        <div class="user-meta" id="userMeta"></div>
      </div>
    </div>

    <!-- Currently checked out -->
    <div class="section-card">
      <div class="section-title">📤 Currently Checked Out</div>
      <div id="currentOut-skeleton" aria-hidden="true">
        <div class="skeleton skeleton-row"></div>
        <div class="skeleton skeleton-row skeleton-row--med"></div>
      </div>
      <div id="currentOut" style="display:none">
        <table>
          <thead><tr><th>Serial</th><th>Model / Description</th><th>Checked Out</th><th>Duration</th><th>Action</th></tr></thead>
          <tbody id="currentOutBody"></tbody>
        </table>
        <div id="currentOutEmpty" class="empty-state" style="display:none">
          <div class="empty-state__icon">✅</div>
          <div class="empty-state__title">Nothing currently checked out</div>
          <div class="empty-state__body">All your tools have been returned.</div>
        </div>
      </div>
    </div>

    <!-- Checkout history -->
    <div class="section-card">
      <div class="section-title">📋 Recent Tool History <span style="font-size:.78rem;color:var(--fg-muted);font-weight:400">(last 30 days)</span></div>
      <div id="history-skeleton" aria-hidden="true">
        <div class="skeleton skeleton-row"></div>
        <div class="skeleton skeleton-row skeleton-row--med"></div>
        <div class="skeleton skeleton-row skeleton-row--short"></div>
      </div>
      <div id="historyTable" style="display:none">
        <table>
          <thead><tr><th>Serial</th><th>Model</th><th>Action</th><th>When</th><th>Duration</th></tr></thead>
          <tbody id="historyBody"></tbody>
        </table>
        <div id="historyEmpty" class="empty-state" style="display:none">
          <div class="empty-state__icon">📭</div>
          <div class="empty-state__title">No tool activity in the last 30 days</div>
        </div>
      </div>
    </div>

    <!-- Submitted tickets & suggestions -->
    <div class="section-card">
      <div class="section-title">🧾 My Tickets &amp; Suggestions</div>
      <div id="tickets-skeleton" aria-hidden="true">
        <div class="skeleton skeleton-row"></div>
        <div class="skeleton skeleton-row skeleton-row--med"></div>
      </div>
      <div id="ticketsTable" style="display:none">
        <table>
          <thead><tr><th>Title</th><th>Type</th><th>Status</th><th>Submitted</th></tr></thead>
          <tbody id="ticketsBody"></tbody>
        </table>
        <div id="ticketsEmpty" class="empty-state" style="display:none">
          <div class="empty-state__icon">💬</div>
          <div class="empty-state__title">No tickets or suggestions yet</div>
          <div class="empty-state__body">Submit a ticket or suggestion from the Kiosk.</div>
        </div>
      </div>
    </div>
  </div>

  <script src="/nav.js"></script>
  <script src="/socket.io/socket.io.js" defer></script>
  <script type="module" src="/history/history.js"></script>
</body>
</html>


