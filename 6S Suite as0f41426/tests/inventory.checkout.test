import { describe, it, expect } from 'vitest';
import request from 'supertest';
import app from '../server.js'; // export app from server.js

describe('Inventory checkout', () => {
  it('blocks when qty exceeds stock', async () => {
    // seed one item first or mock service
    const res = await request(app).post('/inventory/TEST-1/checkout').send({
      qty: 9999, operatorId: 'op1', sixSOperator: 'lead'
    });
    expect([400,404]).toContain(res.status);
  });
});
