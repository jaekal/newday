{
  "name": "6s-suite",
  "version": "1.1.0",
  "description": "Screwdriver Tool Checkout & Audit Tracker",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "cross-env NODE_ENV=development nodemon server.js",
    "dev:light": "cross-env NODE_ENV=development BOOT_TASKS_ENABLED=false LOW_STOCK_ALERTS=false node server.js",
    "lint": "eslint .",
    "format": "prettier --write .",
    "docs": "node ./scripts/build-openapi.js",
    "ts:check": "node scripts/taskservice-check.mjs --list",
    "ts:all": "node scripts/taskservice-check.mjs --all",
    "ts:step": "node scripts/taskservice-check.mjs --steps",
    "migrate:tools-audit": "node scripts/migrate-tools-audit.mjs",
    "migrate:tools-audit:dry": "node scripts/migrate-tools-audit.mjs --dry-run",
    "migrate:calibration": "node scripts/migrate-calibration.mjs",
    "migrate:calibration:dry": "node scripts/migrate-calibration.mjs --dry-run"
  },
  "dependencies": {
    "@sentry/node": "^8.28.0",
    "bcrypt": "^5.1.1",
    "compression": "^1.7.4",
    "connect-redis": "^7.1.1",
    "cors": "^2.8.5",
    "csv-parser": "^3.2.0",
    "dotenv": "^16.4.5",
    "ejs": "^3.1.10",
    "express": "^4.19.2",
    "express-rate-limit": "^8.2.1",
    "express-session": "^1.17.3",
    "helmet": "^7.1.0",
    "joi": "^17.13.3",
    "json2csv": "^6.0.0-alpha.2",
    "method-override": "^3.0.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^4.2.1",
    "openid-client": "^6.8.1",
    "pdfkit": "^0.17.2",
    "pino": "^9.4.0",
    "pino-http": "^10.3.0",
    "prom-client": "^15.1.3",
    "redis": "^4.7.0",
    "sequelize": "^6.37.7",
    "sharp": "^0.33.4",
    "socket.io": "^4.7.5",
    "sqlite3": "^5.1.7",
    "swagger-ui-express": "^5.0.1",
    "xlsx": "^0.18.5",
    "yamljs": "^0.3.0"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "eslint": "^9.9.0",
    "nodemon": "^3.1.4",
    "prettier": "^3.3.3"
  }
}
