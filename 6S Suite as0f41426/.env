# ─────────────────────────────────────────────
# Core app
# ─────────────────────────────────────────────
NODE_ENV=development
PORT=1133
HTTP_PORT=1155
LOG_LEVEL=info

# ─────────────────────────────────────────────
# HTTPS / LAN access
# Set FORCE_HTTP=false when using real certs
# HTTPS_KEY / HTTPS_CERT must point to existing files
# The cert should include localhost and your LAN IP
# Example mkcert:
# mkcert localhost 127.0.0.1 ::1 10.1.4.66
# ─────────────────────────────────────────────
FORCE_HTTP=false
HTTPS_KEY=./certs/dev-key.pem
HTTPS_CERT=./certs/dev-cert.pem

# Trust proxy only if you're behind nginx/IIS/reverse proxy
# blank = false in dev, 1 = trust first proxy
TRUST_PROXY=

# ─────────────────────────────────────────────
# Sessions / auth
# SESSION_SECURE blank = auto follow HTTPS_ENABLED
# Set true only when actually serving HTTPS
# ─────────────────────────────────────────────
SESSION_SECRET=change-this-to-a-long-random-secret
SESSION_SAMESITE=lax
SESSION_SECURE=

# Optional: disable RBAC for temporary troubleshooting
DISABLE_RBAC=false

# ─────────────────────────────────────────────
# Redis session store
# Leave USE_REDIS=false for local dev unless Redis is running
# ─────────────────────────────────────────────
USE_REDIS=false
REDIS_URL=redis://127.0.0.1:6379

# ─────────────────────────────────────────────
# Telemetry
# ─────────────────────────────────────────────
OTEL_ENABLED=false

# ─────────────────────────────────────────────
# Boot tasks
# ─────────────────────────────────────────────
BOOT_TASKS_ENABLED=true
BOOT_DELAY_MS=1000
TASK_TIMEOUT_MS=10000
SEED_ON_BOOT=1

# ─────────────────────────────────────────────
# Expiration / task sync
# ─────────────────────────────────────────────
EXP_SYNC_ENABLED=true
EXP_SYNC_DAYS=30
EXP_SYNC_MAX_CREATE=50

# ─────────────────────────────────────────────
# Project/task store limits
# ─────────────────────────────────────────────
PROJECTS_MAX=3000
AUDIT_INSTANCE_MAX_CREATE=24
PRUNE_DONE_DAYS=60
AUDIT_INSTANCE_RETENTION_DAYS=30

# ─────────────────────────────────────────────
# Metrics
# Leave token blank to disable bearer auth for metrics
# Set allow IPs as needed
# ─────────────────────────────────────────────
METRICS_PREFIX=
METRICS_TOKEN=
METRICS_ALLOW_IPS=127.0.0.1,::1,::ffff:127.0.0.1

# ─────────────────────────────────────────────
# Low stock alerts / cron
# ─────────────────────────────────────────────
LOW_STOCK_ALERTS=true
LOW_STOCK_CRON=*/15 * * * *
LOW_STOCK_RUN_ON_START=false

# ─────────────────────────────────────────────
# Optional integrations / inbound hooks
# Fill these only if your app uses them
# ─────────────────────────────────────────────
# INTEGRATION_SHARED_SECRET=
# API_KEY_SALT=
# WEBHOOK_SECRET=

# ─────────────────────────────────────────────
# Database / app-specific values
# Add your own model/service settings below
# ─────────────────────────────────────────────
# DB_PATH=./data/app.db
# SQLITE_BUSY_TIMEOUT=5000
