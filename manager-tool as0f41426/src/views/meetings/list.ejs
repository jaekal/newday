<!-- src/views/meetings/list.ejs -->
<%- include('../layout') %>

<div class="page-header">
  <h2>Meetings</h2>
  <a href="/meetings/new" class="btn primary btn-sm">+ Schedule Meeting</a>
</div>

<% if (!meetings || meetings.length === 0) { %>
  <div class="card empty-state">
    <p>No meetings recorded yet.</p>
    <a href="/meetings/new" class="btn primary btn-sm">Schedule your first meeting</a>
  </div>
<% } else { %>
  <div class="table-wrapper">
    <table class="data-table">
      <thead>
        <tr>
          <th>Date</th>
          <th>Time</th>
          <th>Type</th>
          <th>Staff Member</th>
          <th>Organizer</th>
          <th>Duration</th>
          <th>Notes</th>
        </tr>
      </thead>
      <tbody>
        <% meetings.forEach(function(m) {
          const start = m.startAt ? new Date(m.startAt) : null;
          const end = m.endAt ? new Date(m.endAt) : null;
          const dateStr = start ? start.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }) : '—';
          const timeStr = start ? start.toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit' }) : '—';
          let duration = '—';
          if (start && end) {
            const mins = Math.round((end - start) / 60000);
            duration = mins >= 60 ? Math.round(mins / 60) + 'h' : mins + 'm';
          }
          const staffName = m.Staff ? (m.Staff.name || m.Staff.username || '—') : '—';
          const staffId = m.Staff ? m.Staff.id : null;
          const organizerName = m.Organizer ? (m.Organizer.name || m.Organizer.username || '—') : '—';
        %>
        <tr>
          <td><%= dateStr %></td>
          <td><%= timeStr %></td>
          <td>
            <span class="badge"><%= m.type === 'ONE_ON_ONE' ? '1:1' : m.type %></span>
            <% if (m.focus) { %><span class="badge" style="margin-left:0.25rem;opacity:0.8;"><%= m.focus %></span><% } %>
          </td>
          <td>
            <% if (staffId) { %>
              <a href="/staff/<%= staffId %>"><%= staffName %></a>
            <% } else { %>
              <%= staffName %>
            <% } %>
          </td>
          <td><%= organizerName %></td>
          <td><%= duration %></td>
          <td class="notes-cell"><%= m.notes ? m.notes.slice(0, 80) + (m.notes.length > 80 ? '…' : '') : '' %></td>
        </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
<% } %>

</main>
</body>
</html>
