<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= typeof title !== 'undefined' ? title : 'Error' %></title>
  <style>
    body {
      font-family: Arial, sans-serif;
      background: #f7f8fa;
      color: #1f2937;
      margin: 0;
      padding: 40px;
    }
    .container {
      max-width: 700px;
      margin: 60px auto;
      background: #fff;
      border-radius: 12px;
      padding: 32px;
      box-shadow: 0 8px 24px rgba(0,0,0,0.08);
    }
    h1 {
      margin-top: 0;
      color: #b91c1c;
    }
    .details {
      margin-top: 20px;
      padding: 16px;
      background: #f3f4f6;
      border-radius: 8px;
      white-space: pre-wrap;
      word-break: break-word;
      font-family: Consolas, monospace;
      font-size: 14px;
    }
    a {
      display: inline-block;
      margin-top: 20px;
      color: #2563eb;
      text-decoration: none;
    }
  </style>
</head>
<body>
  <div class="container">
    <h1><%= typeof message !== 'undefined' ? message : 'Something went wrong' %></h1>
    <p>Status: <%= typeof status !== 'undefined' ? status : 500 %></p>

    <% if (typeof error !== 'undefined' && error && error.stack) { %>
      <div class="details"><%= error.stack %></div>
    <% } %>

    <a href="/">Return to Home</a>
  </div>
</body>
</html>