<!-- views/layout.ejs -->

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="color-scheme" content="dark light" />
  <title>Performance Development Management System</title>
  <link rel="stylesheet" href="/styles.css" />
  <script>
    // Apply saved theme before first paint to prevent flash
    (function() {
      var t = localStorage.getItem('app-theme');
      if (t && t !== 'meridian') document.documentElement.setAttribute('data-theme', t);
    })();
  </script>
</head>

<%
  const user = (typeof currentUser !== 'undefined' && currentUser) ? currentUser : null;
  const userRole = user && user.role ? String(user.role).toUpperCase() : '';
  const userName = user && (user.name || user.username) ? String(user.name || user.username) : '';

  const isLoggedIn = !!user;
  const canSeeNewReview    = ['ADMIN', 'SENIOR_MANAGER', 'MANAGER', 'SUPERVISOR', 'LEAD'].includes(userRole);
  const canSeeSubmittedReviews = ['ADMIN', 'SENIOR_MANAGER', 'MANAGER', 'SUPERVISOR'].includes(userRole);
  const canSeeStaff        = isLoggedIn;
  const canSeeCalendar     = ['ADMIN', 'SENIOR_MANAGER', 'MANAGER', 'SUPERVISOR', 'LEAD'].includes(userRole);
  const canSeeGoals        = ['ADMIN', 'SENIOR_MANAGER', 'MANAGER', 'SUPERVISOR', 'LEAD'].includes(userRole);
  const canSeeIncidents    = ['ADMIN', 'SENIOR_MANAGER', 'MANAGER', 'SUPERVISOR', 'LEAD'].includes(userRole);
  const canSeeUserMgmt     = ['ADMIN', 'SENIOR_MANAGER', 'MANAGER'].includes(userRole);
  const canSeeAdminAudit   = ['ADMIN'].includes(userRole);
  const canSeeAssignments  = ['ADMIN', 'SENIOR_MANAGER', 'MANAGER', 'SUPERVISOR'].includes(userRole);
  const canSeeImportsExports = ['ADMIN', 'SENIOR_MANAGER', 'MANAGER', 'SUPERVISOR'].includes(userRole);

  const canSeeOperations = canSeeImportsExports || canSeeAssignments || canSeeNewReview || canSeeSubmittedReviews;
  const canSeeAdminGroup = canSeeGoals || canSeeIncidents || canSeeUserMgmt || canSeeAdminAudit;

  const reqPath = (typeof path !== 'undefined' && path) ? String(path) : '';
  function isActive(href) {
    if (!reqPath) return false;
    return reqPath === href || reqPath.startsWith(href + '/');
  }

  const operationsActive = ['/imports','/exports','/assignments','/reviews','/meetings'].some(h => isActive(h));
  const adminGroupActive  = ['/goals','/incidents','/admin/users','/admin/audit'].some(h => isActive(h));

%>

<body class="<%= userRole ? ('role-' + userRole.toLowerCase()) : '' %>">
  <a href="#main-content" class="skip-link">Skip to content</a>

  <header class="app-header">
    <div class="inner">

      <div class="header-left">
        <h1>Performance Development Management System</h1>
        <% if (user) { %>
          <div class="header-meta">
            <form method="GET" action="/search" class="nav-search-form" role="search">
              <input type="text" name="q" placeholder="Search&hellip;" class="nav-search-input" aria-label="Global search" maxlength="100" />
            </form>
          </div>
        <% } %>
      </div>

      <button class="nav-hamburger" aria-label="Toggle navigation" aria-expanded="false" aria-controls="primary-nav" type="button">
        <span></span><span></span><span></span>
      </button>

      <nav id="primary-nav" aria-label="Primary" class="nav-closed">
        <% if (user) { %>

          <% if (userRole) { %>
            <a href="/account/password" class="role-badge-link<%= isActive('/account/password') ? ' role-badge-link--active' : '' %>" title="Account settings">
              <span class="dot"></span>
              <span><%= userRole %><% if (userName) { %> &middot; <%= userName %><% } %></span>
            </a>
          <% } %>

          <a href="/" class="nav-link<%= isActive('/') && !operationsActive && !adminGroupActive && !isActive('/reviews') && !isActive('/staff') && !isActive('/calendar') && !isActive('/account') ? ' nav-link--active' : '' %>">
            Dashboard
          </a>

          <% if (canSeeStaff) { %>
            <a href="/staff" class="nav-link<%= isActive('/staff') ? ' nav-link--active' : '' %>" <%= isActive('/staff') ? 'aria-current="page"' : '' %>>Staff</a>
          <% } %>

          <% if (canSeeCalendar) { %>
            <a href="/calendar" class="nav-link<%= isActive('/calendar') ? ' nav-link--active' : '' %>" <%= isActive('/calendar') ? 'aria-current="page"' : '' %>>Calendar</a>
          <% } %>

          <% if (canSeeOperations) { %>
            <div class="nav-dropdown<%= operationsActive ? ' nav-dropdown--active' : '' %>">
              <button class="nav-link nav-dropdown__trigger" aria-haspopup="true" aria-expanded="false" type="button">
                Operations
                <svg class="nav-dropdown__caret" width="10" height="6" viewBox="0 0 10 6" fill="none" aria-hidden="true">
                  <path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </button>
              <div class="nav-dropdown__menu" role="menu">
                <% if (canSeeImportsExports) { %>
                  <a href="/imports" class="nav-dropdown__item<%= isActive('/imports') ? ' nav-dropdown__item--active' : '' %>" role="menuitem" <%= isActive('/imports') ? 'aria-current="page"' : '' %>>
                    <svg class="nav-dropdown__icon" width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M8 1v9M4 7l4 4 4-4M2 12v2a1 1 0 001 1h10a1 1 0 001-1v-2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    Imports
                  </a>
                  <a href="/exports" class="nav-dropdown__item<%= isActive('/exports') ? ' nav-dropdown__item--active' : '' %>" role="menuitem" <%= isActive('/exports') ? 'aria-current="page"' : '' %>>
                    <svg class="nav-dropdown__icon" width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M8 11V2M4 5l4-4 4 4M2 12v2a1 1 0 001 1h10a1 1 0 001-1v-2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    Exports
                  </a>
                <% } %>
                <% if (canSeeAssignments) { %>
                  <a href="/assignments" class="nav-dropdown__item<%= isActive('/assignments') ? ' nav-dropdown__item--active' : '' %>" role="menuitem" <%= isActive('/assignments') ? 'aria-current="page"' : '' %>>
                    <svg class="nav-dropdown__icon" width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true"><rect x="2" y="3" width="12" height="10" rx="1.5" stroke="currentColor" stroke-width="1.4"/><path d="M5 7h6M5 10h4" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/><path d="M6 1v2M10 1v2" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg>
                    Assignments
                  </a>
                <% } %>
                <% if (canSeeNewReview) { %>
                  <a href="/meetings" class="nav-dropdown__item<%= isActive('/meetings') ? ' nav-dropdown__item--active' : '' %>" role="menuitem" <%= isActive('/meetings') ? 'aria-current="page"' : '' %>>
                    <svg class="nav-dropdown__icon" width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true"><circle cx="5" cy="5" r="2.5" stroke="currentColor" stroke-width="1.4"/><circle cx="11" cy="5" r="2.5" stroke="currentColor" stroke-width="1.4"/><path d="M1 13c0-2 1.8-3.5 4-3.5s4 1.5 4 3.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/><path d="M11 9.5c1.8 0 3.2 1.2 3.5 3" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>
                    Meetings
                  </a>
                  <a href="/reviews/new" class="nav-dropdown__item<%= isActive('/reviews/new') ? ' nav-dropdown__item--active' : '' %>" role="menuitem" <%= isActive('/reviews/new') ? 'aria-current="page"' : '' %>>
                    <svg class="nav-dropdown__icon" width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M8 3v10M3 8h10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                    New Review
                  </a>
                <% } %>
                <% if (canSeeSubmittedReviews) { %>
                  <a href="/reviews/submitted" class="nav-dropdown__item<%= isActive('/reviews/submitted') ? ' nav-dropdown__item--active' : '' %>" role="menuitem" <%= isActive('/reviews/submitted') ? 'aria-current="page"' : '' %>>
                    <svg class="nav-dropdown__icon" width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true"><rect x="2.25" y="2.25" width="11.5" height="11.5" rx="1.75" stroke="currentColor" stroke-width="1.4"/><path d="M5 6h6M5 8.5h6M5 11h4" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg>
                    Submitted Reviews
                  </a>
                  <a href="/reviews/calibration" class="nav-dropdown__item<%= isActive('/reviews/calibration') ? ' nav-dropdown__item--active' : '' %>" role="menuitem" <%= isActive('/reviews/calibration') ? 'aria-current="page"' : '' %>>
                    <svg class="nav-dropdown__icon" width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M2 12l4-5 3 3 5-7" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    Calibration
                  </a>
                  <a href="/reviews/audit" class="nav-dropdown__item<%= isActive('/reviews/audit') ? ' nav-dropdown__item--active' : '' %>" role="menuitem" <%= isActive('/reviews/audit') ? 'aria-current="page"' : '' %>>
                    <svg class="nav-dropdown__icon" width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M3 4h10M3 8h7M3 12h5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg>
                    Review Audit
                  </a>
                <% } %>
              </div>
            </div>
          <% } %>

          <% if (canSeeAdminGroup) { %>
            <div class="nav-dropdown<%= adminGroupActive ? ' nav-dropdown--active' : '' %>">
              <button class="nav-link nav-dropdown__trigger" aria-haspopup="true" aria-expanded="false" type="button">
                Admin
                <svg class="nav-dropdown__caret" width="10" height="6" viewBox="0 0 10 6" fill="none" aria-hidden="true">
                  <path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </button>
              <div class="nav-dropdown__menu" role="menu">
                <% if (canSeeGoals) { %>
                  <a href="/goals" class="nav-dropdown__item<%= isActive('/goals') ? ' nav-dropdown__item--active' : '' %>" role="menuitem" <%= isActive('/goals') ? 'aria-current="page"' : '' %>>
                    <svg class="nav-dropdown__icon" width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true"><circle cx="8" cy="8" r="6" stroke="currentColor" stroke-width="1.4"/><circle cx="8" cy="8" r="3" stroke="currentColor" stroke-width="1.4"/><circle cx="8" cy="8" r="1" fill="currentColor"/></svg>
                    Goals
                  </a>
                <% } %>
                <% if (canSeeIncidents) { %>
                  <a href="/incidents" class="nav-dropdown__item<%= isActive('/incidents') ? ' nav-dropdown__item--active' : '' %>" role="menuitem" <%= isActive('/incidents') ? 'aria-current="page"' : '' %>>
                    <svg class="nav-dropdown__icon" width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M8 2L1.5 13h13L8 2z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/><path d="M8 6v3.5M8 11v.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                    Incidents
                  </a>
                <% } %>
                <% if (canSeeUserMgmt) { %>
                  <a href="/admin/users" class="nav-dropdown__item<%= isActive('/admin/users') ? ' nav-dropdown__item--active' : '' %>" role="menuitem" <%= isActive('/admin/users') ? 'aria-current="page"' : '' %>>
                    <svg class="nav-dropdown__icon" width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true"><circle cx="8" cy="5" r="3" stroke="currentColor" stroke-width="1.4"/><path d="M2 14c0-3 2.7-5 6-5s6 2 6 5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>
                    User Management
                  </a>
                <% } %>
                <% if (canSeeAdminAudit) { %>
                  <a href="/admin/audit" class="nav-dropdown__item<%= isActive('/admin/audit') ? ' nav-dropdown__item--active' : '' %>" role="menuitem" <%= isActive('/admin/audit') ? 'aria-current="page"' : '' %>>
                    <svg class="nav-dropdown__icon" width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true"><rect x="2" y="2" width="12" height="12" rx="2" stroke="currentColor" stroke-width="1.4"/><path d="M5 6h6M5 9h4" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg>
                    Audit Log
                  </a>
                <% } %>
              </div>
            </div>
          <% } %>

          <!-- Theme Switcher -->
          <div class="theme-switcher" id="theme-switcher">
            <button class="theme-switcher__btn" type="button" aria-haspopup="true" aria-expanded="false" id="theme-switcher-btn" title="Switch theme">
              <span class="theme-switcher__dot"></span>
              <span id="theme-switcher-label">Theme</span>
            </button>
            <div class="theme-switcher__menu" id="theme-switcher-menu" role="menu">
              <span class="theme-switcher__label">Select theme</span>

              <button class="theme-option" data-theme-value="meridian" role="menuitem" type="button">
                <span class="theme-option__swatch">
                  <span style="background:#5b6cf9"></span>
                  <span style="background:#1a1a22"></span>
                  <span style="background:#0c0c0f"></span>
                </span>
                <span>
                  <span class="theme-option__name">Meridian</span>
                  <span class="theme-option__desc">Charcoal + Indigo</span>
                </span>
              </button>

              <button class="theme-option" data-theme-value="forge" role="menuitem" type="button">
                <span class="theme-option__swatch">
                  <span style="background:#DE4827"></span>
                  <span style="background:#11161C"></span>
                  <span style="background:#161616"></span>
                </span>
                <span>
                  <span class="theme-option__name">Forge</span>
                  <span class="theme-option__desc">Dark + Red-orange accent</span>
                </span>
              </button>

              <button class="theme-option" data-theme-value="canvas" role="menuitem" type="button">
                <span class="theme-option__swatch">
                  <span style="background:#3b4fd8"></span>
                  <span style="background:#ffffff"></span>
                  <span style="background:#f0f2f7"></span>
                </span>
                <span>
                  <span class="theme-option__name">Canvas</span>
                  <span class="theme-option__desc">Light + Navy</span>
                </span>
              </button>
            </div>
          </div>

          <form method="POST" action="/logout" class="inline-form nav-logout">
            <button type="submit" class="btn ghost btn-sm">Logout</button>
          </form>

        <% } else { %>
          <a href="/login" class="nav-link<%= isActive('/login') ? ' nav-link--active' : '' %>" <%= isActive('/login') ? 'aria-current="page"' : '' %>>Login</a>
        <% } %>
      </nav>

    </div>
  </header>

  <main id="main-content">

  <script>
    // ── Hamburger toggle ──────────────────────────────────────────────────────
    (function () {
      const btn = document.querySelector('.nav-hamburger');
      const nav = document.getElementById('primary-nav');
      if (!btn || !nav) return;

      btn.addEventListener('click', function () {
        const open = nav.classList.toggle('nav-open');
        nav.classList.toggle('nav-closed', !open);
        btn.setAttribute('aria-expanded', open ? 'true' : 'false');
      });
    })();

    // ── Dropdown triggers ─────────────────────────────────────────────────────
    (function () {
      const dropdowns = document.querySelectorAll('.nav-dropdown');

      function closeAll(except) {
        dropdowns.forEach(function (d) {
          if (d === except) return;
          d.classList.remove('nav-dropdown--open');
          var trigger = d.querySelector('.nav-dropdown__trigger');
          if (trigger) trigger.setAttribute('aria-expanded', 'false');
        });
      }

      dropdowns.forEach(function (dropdown) {
        var trigger = dropdown.querySelector('.nav-dropdown__trigger');
        var menu    = dropdown.querySelector('.nav-dropdown__menu');
        if (!trigger || !menu) return;

        trigger.addEventListener('click', function (e) {
          e.stopPropagation();
          var isOpen = dropdown.classList.toggle('nav-dropdown--open');
          trigger.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
          if (isOpen) closeAll(dropdown);
        });

        // Close on Escape
        dropdown.addEventListener('keydown', function (e) {
          if (e.key === 'Escape') {
            dropdown.classList.remove('nav-dropdown--open');
            trigger.setAttribute('aria-expanded', 'false');
            trigger.focus();
          }
        });
      });

      // Click outside closes all
      document.addEventListener('click', function () { closeAll(null); });
    })();
  </script>

  <script>
    // ── Theme switcher ────────────────────────────────────────────────────────
    (function () {
      var THEMES = {
        meridian: 'Meridian',
        forge:    'Forge',
        canvas:   'Canvas',
      };

      var wrapper = document.getElementById('theme-switcher');
      var btn     = document.getElementById('theme-switcher-btn');
      var menu    = document.getElementById('theme-switcher-menu');
      var lbl     = document.getElementById('theme-switcher-label');
      if (!wrapper || !btn || !menu) return;

      // Determine active theme
      function getTheme() {
        return localStorage.getItem('app-theme') || 'meridian';
      }

      function applyTheme(theme) {
        if (theme === 'meridian') {
          document.documentElement.removeAttribute('data-theme');
        } else {
          document.documentElement.setAttribute('data-theme', theme);
        }
        localStorage.setItem('app-theme', theme);
        lbl.textContent = THEMES[theme] || theme;

        // Update active states
        menu.querySelectorAll('.theme-option').forEach(function(opt) {
          opt.classList.toggle('active', opt.dataset.themeValue === theme);
        });
      }

      // Init
      applyTheme(getTheme());

      // Toggle open/close
      btn.addEventListener('click', function(e) {
        e.stopPropagation();
        var open = wrapper.classList.toggle('theme-switcher--open');
        btn.setAttribute('aria-expanded', open ? 'true' : 'false');
      });

      // Option click
      menu.querySelectorAll('.theme-option').forEach(function(opt) {
        opt.addEventListener('click', function(e) {
          e.stopPropagation();
          applyTheme(opt.dataset.themeValue);
          wrapper.classList.remove('theme-switcher--open');
          btn.setAttribute('aria-expanded', 'false');
        });
      });

      // Close on outside click
      document.addEventListener('click', function() {
        wrapper.classList.remove('theme-switcher--open');
        btn.setAttribute('aria-expanded', 'false');
      });

      // Close on Escape
      wrapper.addEventListener('keydown', function(e) {
        if (e.key === 'Escape') {
          wrapper.classList.remove('theme-switcher--open');
          btn.setAttribute('aria-expanded', 'false');
          btn.focus();
        }
      });
    })();
  </script>

  <script>
    // ── CSRF token auto-inject ────────────────────────────────────────────────
    // Runs after all child-view HTML is parsed so every POST form gets the token.
    document.addEventListener('DOMContentLoaded', function () {
      var token = '<%= typeof csrfToken !== "undefined" ? csrfToken : "" %>';
      if (!token) return;
      document.querySelectorAll('form').forEach(function (form) {
        var method = (form.getAttribute('method') || '').toUpperCase();
        if (method !== 'POST') return;
        if (form.querySelector('input[name="_csrf"]')) return; // already present
        var input = document.createElement('input');
        input.type  = 'hidden';
        input.name  = '_csrf';
        input.value = token;
        form.appendChild(input);
      });
    });
  </script>
