%>
<% if (safeHeatMap) { %>
<section class="dashboard-section">
  <div class="section-header">
    <h2>Team Performance Heat Map <span class="muted small">— <%= month %>/<%= year %></span></h2>
  </div>
  <div class="card" style="overflow-x:auto; padding:0.75rem;">
    <script id="heatMapData" type="application/json">
      <%- JSON.stringify({ fields: safeHeatMap.labels, staff: safeHeatMap.staff }) %>
    </script>
    <canvas id="teamHeatMapCanvas"></canvas>
    <script>
    (function() {
      const data = JSON.parse(document.getElementById('heatMapData').textContent || '{}');
      const staff = data.staff || [];
      const fields = data.fields || [];
      if (!staff.length || !fields.length) return;

      const CELL_W = 36, CELL_H = 28;
      const LABEL_W = 80, HEADER_H = 64;
      const canvas = document.getElementById('teamHeatMapCanvas');
      canvas.width = LABEL_W + fields.length * CELL_W;
      canvas.height = HEADER_H + staff.length * CELL_H;
      canvas.style.display = 'block';

      const ctx = canvas.getContext('2d');

      function scoreColor(s) {
        if (s == null) return '#1f2937';
        if (s >= 5) return '#059669';
        if (s >= 4) return '#34d399';
        if (s >= 3) return '#fbbf24';
        if (s >= 2) return '#f97316';
        return '#ef4444';
      }

      function textColor(s) {
        return (s == null || s < 2 || s >= 3) ? '#f9fafb' : '#111827';
      }

      ctx.fillStyle = '#0d1117';
      ctx.fillRect(0, 0, canvas.width, canvas.height);

      ctx.font = '10px system-ui, sans-serif';
      ctx.textAlign = 'center';
      ctx.textBaseline = 'middle';

      // Field headers (rotated)
      fields.forEach(function(label, fi) {
        const x = LABEL_W + fi * CELL_W + CELL_W / 2;
        ctx.save();
        ctx.translate(x, HEADER_H - 4);
        ctx.rotate(-Math.PI / 2.5);
        ctx.fillStyle = '#9ca3af';
        ctx.textAlign = 'left';
        ctx.fillText(label, 0, 0);
        ctx.restore();
      });

      // Rows
      staff.forEach(function(s, si) {
        const y = HEADER_H + si * CELL_H;

        // Staff name label
        ctx.fillStyle = '#d1d5db';
        ctx.textAlign = 'right';
        ctx.fillText(s.staffName.slice(0, 10), LABEL_W - 4, y + CELL_H / 2);

        // Score cells
        s.scores.forEach(function(score, fi) {
          const x = LABEL_W + fi * CELL_W;
          ctx.fillStyle = scoreColor(score);
          ctx.fillRect(x + 1, y + 1, CELL_W - 2, CELL_H - 2);
          if (score != null) {
            ctx.fillStyle = textColor(score);
            ctx.textAlign = 'center';
            ctx.fillText(score, x + CELL_W / 2, y + CELL_H / 2);
          }
        });
      });
    })();
    </script>
  </div>
</section>
<% } %>

<% const safeActivityFeed = (typeof activityFeed !== 'undefined' && Array.isArray(activityFeed)) ? activityFeed : []; %>
<% if (safeActivityFeed.length > 0) { %>
<section class="dashboard-section">
  <div class="section-header">
    <h2>Recent Activity</h2>
  </div>
  <div class="card" style="padding:0;">
    <ul class="activity-feed-list">
      <% safeActivityFeed.forEach(function(entry) { %>
        <li class="activity-feed-item">
          <span class="activity-feed-actor"><%= entry.actorName %></span>
          <% if (entry.actionType) { %><span class="activity-feed-action"><%= entry.actionType.replace(/_/g, ' ').toLowerCase() %></span><% } %>
          <% if (entry.targetName) { %><span class="activity-feed-target"><%= entry.targetName %></span><% } %>
          <% if (entry.summary) { %><span class="activity-feed-summary muted small"><%= entry.summary %></span><% } %>
          <span class="activity-feed-time muted small">
            <%= entry.createdAt ? new Date(entry.createdAt).toLocaleString('en-US', { month: 'short', day: 'numeric', hour: 'numeric', minute: '2-digit' }) : '' %>
          </span>
        </li>
      <% }); %>
    </ul>
  </div>
</section>
<% } %>

</main>
</body>
</html>