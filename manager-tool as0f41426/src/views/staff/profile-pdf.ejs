<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Staff Profile — <%= staff.name %></title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'Segoe UI', system-ui, sans-serif;
      font-size: 11pt;
      color: #111;
      background: #fff;
      padding: 1.5cm;
    }

    h1 { font-size: 18pt; margin-bottom: 0.2rem; }
    h2 { font-size: 13pt; margin: 1.2rem 0 0.4rem; border-bottom: 1px solid #e5e7eb; padding-bottom: 0.2rem; }
    h3 { font-size: 11pt; margin: 0.8rem 0 0.3rem; color: #374151; }

    .muted { color: #6b7280; font-size: 0.9em; }
    .header-meta { color: #4b5563; font-size: 10pt; margin-bottom: 1rem; }

    .grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-top: 0.5rem; }
    .grid-3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.75rem; margin-top: 0.5rem; }

    .stat-card {
      border: 1px solid #e5e7eb;
      border-radius: 4px;
      padding: 0.5rem 0.75rem;
    }

    .stat-label { font-size: 9pt; color: #6b7280; text-transform: uppercase; letter-spacing: 0.03em; }
    .stat-value { font-size: 15pt; font-weight: 700; color: #111; }
    .stat-note { font-size: 9pt; color: #6b7280; margin-top: 0.1rem; }

    table { width: 100%; border-collapse: collapse; font-size: 9.5pt; margin-top: 0.5rem; }
    th { background: #f3f4f6; text-align: left; padding: 0.3rem 0.5rem; font-weight: 600; border: 1px solid #e5e7eb; }
    td { padding: 0.3rem 0.5rem; border: 1px solid #e5e7eb; }
    tr:nth-child(even) td { background: #f9fafb; }

    .chip { display: inline-block; padding: 0.15rem 0.5rem; border-radius: 999px; font-size: 8.5pt; border: 1px solid #d1d5db; }
    .chip-ok   { background: #d1fae5; border-color: #6ee7b7; color: #065f46; }
    .chip-warn { background: #fef3c7; border-color: #fcd34d; color: #92400e; }

    .section { margin-top: 1.2rem; page-break-inside: avoid; }

    .print-actions {
      position: fixed;
      top: 10px; right: 10px;
      display: flex;
      gap: 0.5rem;
    }

    .print-actions button {
      padding: 0.4rem 0.9rem;
      border: 1px solid #d1d5db;
      border-radius: 4px;
      cursor: pointer;
      font-size: 10pt;
      background: #fff;
    }

    .print-actions button.primary {
      background: #4f46e5;
      color: #fff;
      border-color: #4f46e5;
    }

    @media print {
      .print-actions { display: none; }
      body { padding: 0; }
    }
  </style>
</head>
<body>

<div class="print-actions">
  <button onclick="window.print()" class="primary">Print / Save PDF</button>
  <button onclick="window.close()">Close</button>
</div>

<%
  const p = staff.StaffProfile || {};
  const monthNames = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];

  const safeAttSt = (typeof attendanceStats !== 'undefined' && attendanceStats) ? attendanceStats
    : { totalDays:0, presentDays:0, absentDays:0, lateDays:0, avgMinutesLateOnLateDays:null };
  const safeEsdSt = (typeof esdStats !== 'undefined' && esdStats) ? esdStats
    : { totalDays:0, daysWithPassBeforeShift:0, daysWithPassAfterShift:0, daysWithoutPass:0 };
  const safeGoalSt = (typeof goalStats !== 'undefined' && goalStats) ? goalStats
    : { total:0, open:0, inProgress:0, done:0 };
  const safeTrainSt = (typeof trainingStats !== 'undefined' && trainingStats) ? trainingStats
    : { total:0, current:0, expiring:0, expired:0 };
  const safeRating = (typeof overallAverage !== 'undefined' && overallAverage != null) ? overallAverage.toFixed(2) : '—';
  const safeIncidents = (typeof incidents !== 'undefined' && Array.isArray(incidents)) ? incidents : [];
  const safeReviews = (typeof ratingHistory !== 'undefined' && Array.isArray(ratingHistory)) ? ratingHistory : [];
  const safeGoals = (typeof staffGoals !== 'undefined' && Array.isArray(staffGoals)) ? staffGoals : [];
  const safeEsdStreak = (typeof esdStreak !== 'undefined' && esdStreak != null) ? esdStreak : null;
  const safeAbsPattern = (typeof absencePattern !== 'undefined' && absencePattern) ? absencePattern : null;
%>

<h1><%= staff.name %></h1>
<div class="header-meta">
  <%= staff.role %><% if (p.positionType) { %> · <%= p.positionType %><% } %>
  <% if (p.employeeId) { %> · #<%= p.employeeId %><% } %>
  <% if (p.building) { %> · <%= p.building %><% } %>
  <% if (p.shift) { %> / <%= p.shift %><% } %>
  <% if (p.startDate) { %> · Started <%= p.startDate %><% } %>
</div>
<div class="muted">Exported <%= new Date().toLocaleDateString('en-US', { year:'numeric', month:'long', day:'numeric' }) %></div>

<!-- Key Metrics -->
<h2>Key Metrics</h2>
<div class="grid-3">
  <div class="stat-card">
    <div class="stat-label">Review Score</div>
    <div class="stat-value"><%= safeRating %></div>
    <div class="stat-note">Overall average</div>
  </div>
  <div class="stat-card">
    <div class="stat-label">Attendance</div>
    <div class="stat-value"><%= safeAttSt.totalDays > 0 ? Math.round(safeAttSt.presentDays / safeAttSt.totalDays * 100) + '%' : '—' %></div>
    <div class="stat-note"><%= safeAttSt.absentDays %> absent, <%= safeAttSt.lateDays %> late</div>
  </div>
  <div class="stat-card">
    <div class="stat-label">ESD Compliance</div>
    <div class="stat-value"><%= safeEsdSt.totalDays > 0 ? Math.round((safeEsdSt.daysWithPassBeforeShift + safeEsdSt.daysWithPassAfterShift) / safeEsdSt.totalDays * 100) + '%' : '—' %></div>
    <div class="stat-note">
      <% if (safeEsdStreak) { %><span class="chip chip-ok"><%= safeEsdStreak %>d streak</span><% } %>
      <% if (safeAbsPattern && safeAbsPattern.flagged) { %><span class="chip chip-warn">Mon/Fri pattern</span><% } %>
    </div>
  </div>
  <div class="stat-card">
    <div class="stat-label">Goals</div>
    <div class="stat-value"><%= safeGoalSt.total %></div>
    <div class="stat-note"><%= safeGoalSt.inProgress %> in progress · <%= safeGoalSt.done %> done</div>
  </div>
  <div class="stat-card">
    <div class="stat-label">Training</div>
    <div class="stat-value"><%= safeTrainSt.current %> / <%= safeTrainSt.total %></div>
    <div class="stat-note">current · <%= safeTrainSt.expiring %> expiring · <%= safeTrainSt.expired %> expired</div>
  </div>
  <div class="stat-card">
    <div class="stat-label">Open Incidents</div>
    <div class="stat-value"><%= safeIncidents.filter(function(i){return i.status !== 'RESOLVED' && i.status !== 'CLOSED';}).length %></div>
    <div class="stat-note"><%= safeIncidents.length %> total</div>
  </div>
</div>

<!-- Review History -->
<% if (safeReviews.length > 0) { %>
<div class="section">
  <h2>Review History (last <%= Math.min(safeReviews.length, 12) %>)</h2>
  <table>
    <thead>
      <tr>
        <th>Period</th>
        <th>Reviewer</th>
        <th>Score</th>
        <th>Comment</th>
      </tr>
    </thead>
    <tbody>
      <% safeReviews.slice(-12).reverse().forEach(function(r) { %>
        <tr>
          <td><%= r.periodLabel %></td>
          <td><%= r.submitterName %></td>
          <td><%= r.overallScore != null ? r.overallScore.toFixed(2) : '—' %></td>
          <td class="muted"><%= (r.comment || '').slice(0, 120) %><%= (r.comment || '').length > 120 ? '…' : '' %></td>
        </tr>
      <% }); %>
    </tbody>
  </table>
</div>
<% } %>

<!-- Goals -->
<% if (safeGoals.length > 0) { %>
<div class="section">
  <h2>Goals</h2>
  <table>
    <thead>
      <tr><th>Title</th><th>Type</th><th>Status</th><th>Progress</th><th>Due</th></tr>
    </thead>
    <tbody>
      <% safeGoals.forEach(function(g) { %>
        <tr>
          <td><%= g.title %></td>
          <td class="muted"><%= g.type || '—' %></td>
          <td><%= g.status %></td>
          <td><%= g.progress %>%</td>
          <td><%= g.dueDate || '—' %></td>
        </tr>
      <% }); %>
    </tbody>
  </table>
</div>
<% } %>

<!-- Incidents -->
<% if (safeIncidents.length > 0) { %>
<div class="section">
  <h2>Incidents</h2>
  <table>
    <thead>
      <tr><th>Date</th><th>Title</th><th>Severity</th><th>Status</th></tr>
    </thead>
    <tbody>
      <% safeIncidents.forEach(function(inc) { %>
        <tr>
          <td><%= inc.incidentDate ? String(inc.incidentDate).slice(0,10) : '—' %></td>
          <td><%= inc.title || '(no title)' %></td>
          <td><%= inc.severity || '—' %></td>
          <td><%= inc.status || '—' %></td>
        </tr>
      <% }); %>
    </tbody>
  </table>
</div>
<% } %>

</body>
</html>
