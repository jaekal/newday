      <div class="bucket-summary-card">
        <h3>Training Detail</h3>
        <p class="bucket-summary-note">
          Use the side pane to review course history, current status, due dates, and certification frequency without expanding this page.
        </p>

        <div class="summary-action-row">
          <button
            type="button"
            class="btn ghost btn-sm js-open-profile-drawer"
            data-drawer-title="Training & Certifications"
            data-drawer-subtitle="Course history, status, due dates, and certification health."
            data-drawer-source="drawer-training-content"
          >
            View Courses
          </button>
        </div>
      </div>

      <div id="drawer-training-content" class="profile-section-hidden-source">
        <% if (!safeTrainingGrouped || safeTrainingGrouped.length === 0) { %>
          <div class="drawer-empty">No training records found for this employee ID.</div>
        <% } else { %>
          <div class="drawer-stack">
            <div class="filter-strip">
              <span class="mini-chip">All: <strong><%= safeTrainingGrouped.length %></strong></span>
              <span class="mini-chip">Current: <strong><%= safeTrainingStats.current %></strong></span>
              <span class="mini-chip warn">Expiring: <strong><%= safeTrainingStats.expiring %></strong></span>
              <span class="mini-chip warn">Expired: <strong><%= safeTrainingStats.expired %></strong></span>
            </div>

            <% safeTrainingGrouped.forEach(function(course) { %>
              <div class="drawer-subcard">
                <div style="display:flex; justify-content:space-between; gap:0.75rem; flex-wrap:wrap; align-items:flex-start;">
                  <div>
                    <h4><%= course.courseName %></h4>
                    <div class="drawer-list-meta">
                      Last completion: <strong><%= course.lastCompleted || '—' %></strong>
                      • Next due: <strong><%= course.nextDue || '—' %></strong>
                      <% if (course.daysLeft != null) { %> • <strong><%= course.daysLeft %>d</strong><% } %>
                    </div>
                  </div>

                  <div style="display:flex; gap:0.4rem; flex-wrap:wrap;">
                    <span class="<%= course.overallBadgeClass %>"><%= course.overallLabel %></span>
                    <% if (course.courseType) { %><span class="chip small"><%= course.courseType %></span><% } %>
                    <% if (course.categoryLabel) { %><span class="<%= course.categoryChipClass %> small"><%= course.categoryLabel %></span><% } %>
                  </div>
                </div>

                <% if (course.records && course.records.length) { %>
                  <div class="table-wrap" style="margin-top:0.75rem;">
                    <table class="table">
                      <thead>
                        <tr>
                          <th>Status</th>
                          <th>Progress</th>
                          <th>Start</th>
                          <th>End</th>
                          <th>Completion</th>
                          <th>Next Due</th>
                          <th>Frequency</th>
                        </tr>
                      </thead>
                      <tbody>
                        <% course.records.forEach(function(r) { %>
                          <tr style="<% if (r.meta && r.meta.status === 'EXPIRED') { %>background: rgba(239,68,68,0.08);<% } else if (r.meta && r.meta.status === 'EXPIRING') { %>background: rgba(245,158,11,0.08);<% } %>">
                            <td><span class="<%= r.meta ? r.meta.badgeClass : 'status-badge status-open' %>"><%= r.meta ? r.meta.label : 'Unknown' %></span></td>
                            <td>
                              <% const p = r.meta ? r.meta.progressNum : null; %>
                              <% if (p != null) { %>
                                <div class="progress-cell">
                                  <div class="muted small"><%= p %>%</div>
                                  <div class="progress-bar">
                                    <div style="width:<%= Math.max(0, Math.min(100, p)) %>%;"></div>
                                  </div>
                                </div>
                              <% } else { %>
                                <span class="muted">—</span>
                              <% } %>
                            </td>
                            <td><%= r.startDateISO || '—' %></td>
                            <td><%= r.endDateISO || '—' %></td>
                            <td><%= r.completionDateISO || '—' %></td>
                            <td>
                              <%= r.dueDateISO || '—' %>
                              <% if (r.meta && r.meta.daysLeft != null) { %><div class="muted small"><%= r.meta.daysLeft %>d</div><% } %>
                            </td>
                            <td><%= (r.raw && r.raw.certificationFrequency) ? r.raw.certificationFrequency : '—' %></td>
                          </tr>
                        <% }) %>
                      </tbody>
                    </table>
                  </div>
                <% } else { %>
                  <div class="drawer-empty" style="margin-top:0.75rem;">No course history rows available.</div>
                <% } %>
              </div>
            <% }) %>
          </div>
        <% } %>
      </div>
    </section>
  </section>

