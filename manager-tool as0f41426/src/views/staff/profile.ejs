<script>
  (function () {
    const navLinks = Array.from(document.querySelectorAll('.sticky-nav a[href^="#"]'));
    if (!navLinks.length) return;

    const sectionMap = navLinks
      .map(link => {
        const id = link.getAttribute('href');
        const section = document.querySelector(id);
        return section ? { link, section, id } : null;
      })
      .filter(Boolean);

    if (!sectionMap.length) return;

    function setActive(linkToActivate) {
      navLinks.forEach(link => link.classList.remove('active'));
      if (linkToActivate) linkToActivate.classList.add('active');
    }

    const observer = new IntersectionObserver(
      (entries) => {
        const visible = entries
          .filter(entry => entry.isIntersecting)
          .sort((a, b) => b.intersectionRatio - a.intersectionRatio);

        if (!visible.length) return;

        const activeEntry = visible[0];
        const match = sectionMap.find(item => item.section === activeEntry.target);
        if (match) setActive(match.link);
      },
      {
        root: null,
        rootMargin: '-20% 0px -60% 0px',
        threshold: [0.15, 0.25, 0.4, 0.6]
      }
    );

    sectionMap.forEach(item => observer.observe(item.section));

    navLinks.forEach(link => {
      link.addEventListener('click', () => {
        setActive(link);
      });
    });

    setActive(sectionMap[0].link);
  })();
</script>

<script>
  (function () {
    (function complianceCalendar() {
      const payload = window.__PDMS_COMPLIANCE__ || { esdByDate: {}, attByDate: {}, staff: {} };
      const esdByDate = payload.esdByDate || {};
      const attByDate = payload.attByDate || {};
      const staffMeta = payload.staff || {};

      const grid = document.getElementById('complianceCalendar');
      const title = document.getElementById('calTitle');
      const btnPrev = document.getElementById('calPrevMonth');
      const btnNext = document.getElementById('calNextMonth');
      const btnToday = document.getElementById('calToday');

 const drawerSource = document.getElementById('drawer-compliance-day');
const drawerTitle = document.getElementById('drawerComplianceDayTitle');
const drawerSubtitle = document.getElementById('drawerComplianceDaySubtitle');
const drawerOpenTP = document.getElementById('drawerCalOpenTalkingPoints');
const drawerEsdBlock = document.getElementById('drawerCalEsdBlock');
const drawerAttBlock = document.getElementById('drawerCalAttBlock');

const profileDrawer = document.getElementById('profileDrawer');
const profileDrawerBackdrop = document.getElementById('profileDrawerBackdrop');
const profileDrawerTitle = document.getElementById('profileDrawerTitle');
const profileDrawerSubtitle = document.getElementById('profileDrawerSubtitle');
const profileDrawerBody = document.getElementById('profileDrawerBody');

      const riskToggle = document.getElementById('calRiskToggle');
      const clearSel = document.getElementById('calClearSelection');

      const sumEsdPass = document.getElementById('sumEsdPass');
      const sumEsdMissing = document.getElementById('sumEsdMissing');
      const sumAttPresent = document.getElementById('sumAttPresent');
      const sumAttLate = document.getElementById('sumAttLate');
      const sumAttAbsent = document.getElementById('sumAttAbsent');
      const sumLateRate = document.getElementById('sumLateRate');

      if (!grid || !title || !btnPrev || !btnNext || !btnToday) return;

      const DOW = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];
      let selectedDayISO = null;

      function pad2(n){ return String(n).padStart(2,'0'); }
      function toISODate(y,m,d){ return y + '-' + pad2(m) + '-' + pad2(d); }
      function monthLabel(date) { return date.toLocaleString(undefined, { month: 'long', year: 'numeric' }); }

      function esc(s) {
        return String(s || '').replace(/[&<>"']/g, (c) => ({
          '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'
        }[c]));
      }

      function computeEsdBadge(dayISO) {
        const e = esdByDate[dayISO];
        if (!e) return { text: 'ESD: NONE', cls: 'mini-badge mini-muted', level: 'none' };
        const r = (e.finalResult || '').toUpperCase();
        if (r === 'PASS') return { text: 'ESD: PASS', cls: 'mini-badge mini-ok', level: 'ok' };
        return { text: 'ESD: FAIL', cls: 'mini-badge mini-bad', level: 'bad' };
      }

      function computeAttBadge(dayISO) {
        const a = attByDate[dayISO];
        if (!a) return { text: 'ATT: —', cls: 'mini-badge mini-muted', level: 'none' };

        const s = (a.status || '').toUpperCase();
        const p = (a.punctualityBucket || '').toUpperCase();

        if (s === 'ABSENT') return { text: 'ATT: Absent', cls: 'mini-badge mini-bad', level: 'bad' };
        if (s === 'LATE' || p === 'LATE' || p === 'UNPUNCTUAL') return { text: 'ATT: Late', cls: 'mini-badge mini-warn', level: 'warn' };
        if (s === 'PRESENT' || p === 'ON_TIME') return { text: 'ATT: Present', cls: 'mini-badge mini-ok', level: 'ok' };
        return { text: 'ATT: ' + (a.status || '—'), cls: 'mini-badge', level: 'none' };
      }

      function overallTint(esdLevel, attLevel) {
        if (esdLevel === 'bad' || attLevel === 'bad') return 'tint-bad';
        if (esdLevel === 'none' && attLevel === 'none') return '';
        if (esdLevel === 'ok' && attLevel === 'ok') return 'tint-ok';
        if (esdLevel === 'none' && attLevel === 'ok') return 'tint-ok';
        if (esdLevel === 'ok' && attLevel === 'none') return 'tint-ok';
        return 'tint-warn';
      }

      function isIssueDay(dayISO) {
        const e = esdByDate[dayISO] || null;
        const a = attByDate[dayISO] || null;

        const esdIssue = (!e) || ((e.finalResult || '').toUpperCase() !== 'PASS');
        let attIssue = false;

        if (a) {
          const s = (a.status || '').toUpperCase();
          const p = (a.punctualityBucket || '').toUpperCase();
          attIssue = (s === 'ABSENT' || s === 'LATE' || p === 'LATE' || p === 'UNPUNCTUAL');
        }

        return esdIssue || attIssue;
      }

      function pct(n, d) {
        if (!d) return '—';
        return Math.round((n / d) * 100) + '%';
      }

      function computeMonthSummary(anchorDate) {
        const year = anchorDate.getFullYear();
        const month = anchorDate.getMonth();
        const daysInMonth = new Date(year, month + 1, 0).getDate();

        let esdTracked = 0;
        let esdPass = 0;
        let esdMissing = 0;

        let attTracked = 0;
        let attPresent = 0;
        let attLate = 0;
        let attAbsent = 0;

        for (let d = 1; d <= daysInMonth; d++) {
          const iso = toISODate(year, month + 1, d);

          const e = esdByDate[iso];
          if (!e) {
            esdMissing++;
          } else {
            esdTracked++;
            if ((e.finalResult || '').toUpperCase() === 'PASS') esdPass++;
          }

          const a = attByDate[iso];
          if (a) {
            attTracked++;
            const s = (a.status || '').toUpperCase();
            const p = (a.punctualityBucket || '').toUpperCase();

            if (s === 'ABSENT') attAbsent++;
            else if (s === 'LATE' || p === 'LATE' || p === 'UNPUNCTUAL') attLate++;
            else attPresent++;
          }
        }

        return {
          esdTracked, esdPass, esdMissing,
          attTracked, attPresent, attLate, attAbsent,
          esdPassRate: (esdTracked ? pct(esdPass, esdTracked) : '—'),
          latenessRate: (attTracked ? pct(attLate, attTracked) : '—')
        };
      }

      function renderMonthSummary(anchorDate) {
        const s = computeMonthSummary(anchorDate);
        if (sumEsdPass) sumEsdPass.textContent = 'ESD Pass rate: ' + s.esdPassRate;
        if (sumEsdMissing) sumEsdMissing.textContent = 'ESD Missing days: ' + s.esdMissing;
        if (sumAttPresent) sumAttPresent.textContent = 'Present: ' + s.attPresent;
        if (sumAttLate) sumAttLate.textContent = 'Late: ' + s.attLate;
        if (sumAttAbsent) sumAttAbsent.textContent = 'Absent: ' + s.attAbsent;
        if (sumLateRate) sumLateRate.textContent = 'Lateness rate: ' + s.latenessRate;
      }

      function applyRiskFilter(mode) {
        const cells = Array.from(grid.querySelectorAll('.cal-day'));
        const riskOn = (mode || 'all') === 'risk';

        cells.forEach(cell => {
          const iso = cell.getAttribute('data-iso');
          const out = cell.classList.contains('is-out');

          if (!riskOn) {
            cell.classList.remove('is-hidden');
            return;
          }

          if (out) {
            cell.classList.add('is-hidden');
            return;
          }

          const issue = isIssueDay(iso);
          if (!issue) cell.classList.add('is-hidden');
          else cell.classList.remove('is-hidden');
        });
      }

     function openSharedDrawer(titleText, subtitleText, html) {
  if (!profileDrawer || !profileDrawerBackdrop || !profileDrawerTitle || !profileDrawerSubtitle || !profileDrawerBody) return;

  profileDrawerTitle.textContent = titleText || 'Detail';
  profileDrawerSubtitle.textContent = subtitleText || '—';
  profileDrawerBody.innerHTML = html || '<div class="drawer-empty">No detail available.</div>';

  profileDrawer.classList.add('open');
  profileDrawerBackdrop.classList.add('open');
  profileDrawer.setAttribute('aria-hidden', 'false');
  document.body.style.overflow = 'hidden';
}

function openDetails(dayISO) {
  selectedDayISO = dayISO;

  const e = esdByDate[dayISO] || null;
  const a = attByDate[dayISO] || null;

  const subtitleParts = [];
  if (e && e.shiftLabel) subtitleParts.push('ESD shift: ' + e.shiftLabel);
  if (a && a.rawStatusSummary) subtitleParts.push('Attendance: ' + a.rawStatusSummary);

  if (drawerTitle) drawerTitle.textContent = 'Details: ' + dayISO;
  if (drawerSubtitle) drawerSubtitle.textContent = subtitleParts.length ? subtitleParts.join(' • ') : 'No records for this day.';

  if (drawerEsdBlock) {
    if (!e) {
      drawerEsdBlock.innerHTML = '<div class="muted">No ESD entries for this day.</div>';
    } else {
      drawerEsdBlock.innerHTML = `
        <div style="display:flex; flex-wrap:wrap; gap:0.5rem; margin-bottom:0.5rem;">
          <span class="chip small">Result: <strong>${esc(e.finalResult || '—')}</strong></span>
          <span class="chip small">Attempts: <strong>${esc(e.totalAttempts)}</strong></span>
          <span class="chip small">Until PASS: <strong>${esc(e.attemptsUntilPass != null ? e.attemptsUntilPass : '—')}</strong></span>
        </div>
        <div class="muted small">First attempt: <strong>${esc(e.firstAttemptTimeLabel || '—')}</strong></div>
        <div class="muted small">First PASS: <strong>${esc(e.firstPassTimeLabel || '—')}</strong></div>
        <div class="muted small">Window: <strong>${esc(e.windowLabel || '—')}</strong></div>
      `;
    }
  }

  if (drawerAttBlock) {
    if (!a) {
      drawerAttBlock.innerHTML = '<div class="muted">No attendance data for this day.</div>';
    } else {
      drawerAttBlock.innerHTML = `
        <div style="display:flex; flex-wrap:wrap; gap:0.5rem; margin-bottom:0.5rem;">
          <span class="chip small">Status: <strong>${esc(a.status || '—')}</strong></span>
          <span class="chip small">Punctuality: <strong>${esc(a.punctualityBucket || '—')}</strong></span>
          <span class="chip small">Minutes late: <strong>${esc(a.minutesLate != null ? a.minutesLate : '—')}</strong></span>
        </div>
        <div class="muted small">Raw: <strong>${esc(a.rawStatusSummary || '—')}</strong></div>
      `;
    }
  }

  const html = drawerSource ? drawerSource.innerHTML : '<div class="drawer-empty">No detail available.</div>';
  openSharedDrawer(
    'Compliance Day Detail',
    'Daily ESD and attendance detail for ' + dayISO,
    html
  );

  setTimeout(() => {
    const btn = document.getElementById('drawerCalOpenTalkingPoints');
    if (btn && !btn.dataset.boundTp) {
      btn.dataset.boundTp = '1';
      btn.addEventListener('click', openTalkingPoints);
    }
  }, 0);
}

function closeDetails() {
  selectedDayISO = null;
}

      function renderCalendar(anchorDate) {
        const year = anchorDate.getFullYear();
        const month = anchorDate.getMonth();

        title.textContent = monthLabel(anchorDate);
        renderMonthSummary(anchorDate);
        grid.innerHTML = '';

        DOW.forEach(d => {
          const h = document.createElement('div');
          h.className = 'cal-head';
          h.textContent = d;
          grid.appendChild(h);
        });

        const first = new Date(year, month, 1);
        const startDow = first.getDay();
        const startDate = new Date(year, month, 1 - startDow);

        for (let i = 0; i < 42; i++) {
          const d = new Date(startDate);
          d.setDate(startDate.getDate() + i);

          const isOut = d.getMonth() !== month;
          const dayISO = toISODate(d.getFullYear(), d.getMonth() + 1, d.getDate());

          const esd = computeEsdBadge(dayISO);
          const att = computeAttBadge(dayISO);
          const tint = overallTint(esd.level, att.level);

          const cell = document.createElement('div');
          cell.className = 'cal-day' + (isOut ? ' is-out' : '') + (tint ? ' ' + tint : '');
          cell.setAttribute('data-iso', dayISO);

          const top = document.createElement('div');
          top.style.display = 'flex';
          top.style.justifyContent = 'space-between';
          top.style.alignItems = 'baseline';
          top.style.gap = '0.35rem';

          const num = document.createElement('div');
          num.className = 'date-num';
          num.textContent = String(d.getDate());

          top.appendChild(num);

          const badges = document.createElement('div');
          badges.className = 'cal-badges';

          const b1 = document.createElement('span');
          b1.className = esd.cls;
          b1.textContent = esd.text;

          const b2 = document.createElement('span');
          b2.className = att.cls;
          b2.textContent = att.text;

          badges.appendChild(b1);
          badges.appendChild(b2);

          cell.appendChild(top);
          cell.appendChild(badges);
          cell.addEventListener('click', () => openDetails(dayISO));
          grid.appendChild(cell);
        }

        const mode = riskToggle ? (riskToggle.getAttribute('data-mode') || 'all') : 'all';
        applyRiskFilter(mode);
      }

      let anchor = new Date();
      anchor.setHours(0,0,0,0);

      btnPrev.addEventListener('click', () => {
        anchor = new Date(anchor.getFullYear(), anchor.getMonth() - 1, 1);
        renderCalendar(anchor);
      });

      btnNext.addEventListener('click', () => {
        anchor = new Date(anchor.getFullYear(), anchor.getMonth() + 1, 1);
        renderCalendar(anchor);
      });

      btnToday.addEventListener('click', () => {
        anchor = new Date();
        anchor.setHours(0,0,0,0);
        renderCalendar(anchor);
      });

      if (clearSel) {
  clearSel.addEventListener('click', () => {
    selectedDayISO = null;
    const drawer = document.getElementById('profileDrawer');
    const backdrop = document.getElementById('profileDrawerBackdrop');
    if (drawer) {
      drawer.classList.remove('open');
      drawer.setAttribute('aria-hidden', 'true');
    }
    if (backdrop) backdrop.classList.remove('open');
    document.body.style.overflow = '';
  });
}

      if (riskToggle) {
        riskToggle.addEventListener('click', () => {
          const mode = riskToggle.getAttribute('data-mode') || 'all';
          const next = (mode === 'all') ? 'risk' : 'all';
          riskToggle.setAttribute('data-mode', next);
          riskToggle.textContent = (next === 'risk') ? 'Risk filter: ON' : 'Risk filter: OFF';
          applyRiskFilter(next);
        });
      }

      const tpOverlay = document.getElementById('tpOverlay');
      const tpClose = document.getElementById('tpClose');
      const tpCopy = document.getElementById('tpCopy');
      const tpText = document.getElementById('tpText');
      const tpMeta = document.getElementById('tpMeta');

      function buildTalkingPoints(dayISO) {
        const e = esdByDate[dayISO] || null;
        const a = attByDate[dayISO] || null;

        const lines = [];
        lines.push(`1:1 Talking Points`);
        lines.push(`Staff: ${staffMeta.name || 'Staff'}${staffMeta.employeeId ? ' (Emp ' + staffMeta.employeeId + ')' : ''}`);
        if (staffMeta.position) lines.push(`Position: ${staffMeta.position}`);
        lines.push(`Date: ${dayISO}`);
        lines.push(``);
        lines.push(`What went well:`);
        lines.push(`- `);
        lines.push(``);
        lines.push(`Opportunities / follow-up:`);

        if (!e) {
          lines.push(`- ESD: No record found. Confirm process and timing, reinforce daily compliance expectations.`);
        } else if ((e.finalResult || '').toUpperCase() !== 'PASS') {
          lines.push(`- ESD: ${e.finalResult || 'FAIL'} (Attempts: ${e.totalAttempts || '—'}). Ask what caused the failure and what support is needed.`);
        } else {
          lines.push(`- ESD: PASS (First PASS: ${e.firstPassTimeLabel || '—'}).`);
        }

        if (a) {
          const s = (a.status || '').toUpperCase();
          const p = (a.punctualityBucket || '').toUpperCase();
          if (s === 'ABSENT') lines.push(`- Attendance: Absent. Confirm reason, policy alignment, and plan for prevention.`);
          else if (s === 'LATE' || p === 'LATE' || p === 'UNPUNCTUAL') lines.push(`- Attendance: Late (${a.minutesLate != null ? a.minutesLate + ' min' : '—'}). Confirm root cause and corrective habit.`);
          else lines.push(`- Attendance: Present / on time.`);
        } else {
          lines.push(`- Attendance: No record found. Verify data source or badge scan behavior.`);
        }

        lines.push(``);
        lines.push(`Action items:`);
        lines.push(`- Owner: ${staffMeta.name || 'Staff'} | Due: ____ | Action: ____`);
        lines.push(`- Owner: Lead/Supervisor | Due: ____ | Action: ____`);
        lines.push(``);
        lines.push(`Notes:`);
        lines.push(`- `);

        return lines.join('\n');
      }

      function openTalkingPoints() {
        const dayISO = selectedDayISO;
        if (!dayISO) return;

        if (tpMeta) tpMeta.textContent = `Staff: ${staffMeta.name || 'Staff'} • Date: ${dayISO}`;
        if (tpText) tpText.value = buildTalkingPoints(dayISO);

        if (tpOverlay) {
          tpOverlay.style.display = 'flex';
          tpOverlay.setAttribute('aria-hidden', 'false');
        }
      }

      function closeTalkingPoints() {
        if (tpOverlay) {
          tpOverlay.style.display = 'none';
          tpOverlay.setAttribute('aria-hidden', 'true');
        }
      }

      if (drawerOpenTP) drawerOpenTP.addEventListener('click', openTalkingPoints);
      if (tpClose) tpClose.addEventListener('click', closeTalkingPoints);
      if (tpOverlay) {
        tpOverlay.addEventListener('click', (e) => {
          if (e.target === tpOverlay) closeTalkingPoints();
        });
      }

      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') closeTalkingPoints();
      });

      if (tpCopy) {
        tpCopy.addEventListener('click', async () => {
          try {
            await navigator.clipboard.writeText(tpText.value || '');
            tpCopy.textContent = 'Copied';
            setTimeout(() => tpCopy.textContent = 'Copy', 900);
          } catch (err) {
            alert('Copy failed. You can manually copy from the text box.');
          }
        });
      }

      renderCalendar(anchor);
    })();
  })();
</script>

<script>
  (function () {
    const drawer = document.getElementById('profileDrawer');
    const backdrop = document.getElementById('profileDrawerBackdrop');
    const closeBtn = document.getElementById('profileDrawerClose');
    const titleEl = document.getElementById('profileDrawerTitle');
    const subtitleEl = document.getElementById('profileDrawerSubtitle');
    const bodyEl = document.getElementById('profileDrawerBody');

    if (!drawer || !backdrop || !closeBtn || !titleEl || !subtitleEl || !bodyEl) return;

    function openDrawer() {
      drawer.classList.add('open');
      backdrop.classList.add('open');
      drawer.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
    }

    function closeDrawer() {
      drawer.classList.remove('open');
      backdrop.classList.remove('open');
      drawer.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
    }

    function loadDrawerContent(sourceId, title, subtitle) {
      const src = document.getElementById(sourceId);

      titleEl.textContent = title || 'Detail';
      subtitleEl.textContent = subtitle || '—';

      if (!src) {
        bodyEl.innerHTML = '<div class="drawer-empty">Detail source not found.</div>';
        openDrawer();
        return;
      }

      bodyEl.innerHTML = src.innerHTML || '<div class="drawer-empty">No detail available.</div>';
      openDrawer();

      if (sourceId === 'drawer-reviews-content') {
        initReviewDrawer();
      } else if (sourceId === 'drawer-coaching-content') {
        initCoachingDrawer();
      } else if (sourceId === 'drawer-goals-content') {
        initGoalsDrawer();
      }
    }

    function bindDrawerTriggers(root) {
      (root || document).querySelectorAll('.js-open-profile-drawer').forEach((btn) => {
        if (btn.dataset.drawerBound === '1') return;
        btn.dataset.drawerBound = '1';

        btn.addEventListener('click', () => {
          loadDrawerContent(
            btn.getAttribute('data-drawer-source'),
            btn.getAttribute('data-drawer-title'),
            btn.getAttribute('data-drawer-subtitle')
          );
        });
      });
    }

    bindDrawerTriggers(document);

    // ── Metric formula tooltip + STD badge popover ──────────────────────────
    (function() {
      const tip = document.getElementById('metricFormulaTooltip');
      const stdPop = document.getElementById('metricStdPopover');
      if (!tip || !stdPop) return;

      let hideTimer = null;
      let stdVisible = false;
      let activeTipId = null;

      // ── Formula tooltip ──────────────────────────────────────────
      function buildFormulaHtml(f) {
        if (!f) return '<span style="opacity:0.5">No data</span>';
        let html = '';
        if (f.aggregate) {
          html += `<div style="margin-bottom:0.5rem;font-weight:600;color:rgba(226,232,240,0.9)">${f.aggregate}</div>`;
        }
        if (f.cols && f.rows && f.rows.length) {
          html += '<table style="width:100%;border-collapse:collapse;font-size:0.72rem">';
          html += '<thead><tr>' + f.cols.map(c =>
            `<th style="text-align:left;padding:0.2rem 0.4rem 0.2rem 0;color:rgba(226,232,240,0.4);font-weight:600;border-bottom:1px solid rgba(255,255,255,0.08)">${c}</th>`
          ).join('') + '</tr></thead><tbody>';
          f.rows.forEach(function(r) {
            html += '<tr>' + r.map((cell, i) =>
              `<td style="padding:0.22rem 0.4rem 0.22rem 0;color:rgba(226,232,240,${i === 0 ? '0.5' : '0.85'});border-bottom:1px solid rgba(255,255,255,0.04)">${cell ?? '—'}</td>`
            ).join('') + '</tr>';
          });
          html += '</tbody></table>';
        } else if (f.cols) {
          html += `<div style="opacity:0.4;font-size:0.72rem">No date-level data in window</div>`;
        }
        return html;
      }

      function positionAbovePill(anchor) {
        const el = tip;
        el.style.display = 'block';
        const rect = anchor.getBoundingClientRect();
        const tw = el.offsetWidth, th = el.offsetHeight;
        let left = rect.left + rect.width / 2 - tw / 2;
        let top = rect.top - th - 10;
        left = Math.max(8, Math.min(left, window.innerWidth - tw - 8));
        if (top < 8) top = rect.bottom + 10;
        el.style.left = left + 'px';
        el.style.top = top + 'px';
      }

      function showFormulaTip(trigger) {
        clearTimeout(hideTimer);
        const id = trigger.getAttribute('data-row-id');
        if (activeTipId === id && tip.style.display === 'block') return; // already showing
        activeTipId = id;
        const f = (window.__mf || {})[id];
        tip.innerHTML = buildFormulaHtml(f);
        const row = trigger.closest('.detail-row');
        const pill = row ? row.querySelector('.detail-row-score') : trigger;
        positionAbovePill(pill || trigger);
      }

      function hideTip() {
        hideTimer = setTimeout(() => { tip.style.display = 'none'; activeTipId = null; }, 100);
      }

      tip.addEventListener('mouseover', () => clearTimeout(hideTimer));
      tip.addEventListener('mouseout', hideTip);

      // ── STD badge popover ────────────────────────────────────────
      function buildStdHtml(s) {
        if (!s) return '';
        const dirLabel = s.direction === 'lower' ? '▼ Lower is better' : s.direction === 'higher' ? '▲ Higher is better' : 'Informational';
        const dirColor = s.direction === 'lower' ? '#86efac' : s.direction === 'higher' ? '#86efac' : '#94a3b8';
        let html = `<div style="font-weight:700;margin-bottom:0.45rem;color:#a5b4fc">Scoring Standard</div>`;
        html += `<div class="std-popover-row"><span class="std-popover-key">Direction</span><span class="std-popover-val" style="color:${dirColor}">${dirLabel}</span></div>`;
        if (s.direction !== 'none') {
          html += `<div class="std-popover-row"><span class="std-popover-key">Score 100</span><span class="std-popover-val" style="color:#86efac">${s.good}</span></div>`;
          html += `<div class="std-popover-row"><span class="std-popover-key">Score 0</span><span class="std-popover-val" style="color:#fca5a5">${s.bad}</span></div>`;
          html += `<div class="std-popover-row"><span class="std-popover-key">Scale</span><span class="std-popover-val">Linear between thresholds</span></div>`;
        }
        html += `<div class="std-popover-row"><span class="std-popover-key">Weight</span><span class="std-popover-val">${s.weight}</span></div>`;
        if (s.note) html += `<div class="std-popover-note">${s.note}</div>`;
        return html;
      }

      function positionStdAboveBadge(badge) {
        stdPop.style.display = 'block';
        stdPop.style.pointerEvents = 'auto';
        const rect = badge.getBoundingClientRect();
        const pw = stdPop.offsetWidth, ph = stdPop.offsetHeight;
        let left = rect.left + rect.width / 2 - pw / 2;
        let top = rect.top - ph - 10;
        left = Math.max(8, Math.min(left, window.innerWidth - pw - 8));
        if (top < 8) top = rect.bottom + 10;
        stdPop.style.left = left + 'px';
        stdPop.style.top = top + 'px';
      }

      function hideStdPop() {
        stdPop.style.display = 'none';
        stdPop.style.pointerEvents = 'none';
        stdVisible = false;
      }

      // Delegate events
      document.addEventListener('mouseover', function(e) {
        const trigger = e.target.closest('.metric-formula-trigger');
        if (trigger) showFormulaTip(trigger);
      });
      document.addEventListener('mouseout', function(e) {
        if (e.target.closest('.metric-formula-trigger')) hideTip();
      });

      document.addEventListener('click', function(e) {
        const badge = e.target.closest('.metric-std-trigger');
        if (badge) {
          e.stopPropagation();
          const id = badge.getAttribute('data-row-id');
          const s = (window.__ms || {})[id];
          if (stdVisible && stdPop.dataset.activeId === id) {
            hideStdPop();
          } else {
            stdPop.innerHTML = buildStdHtml(s);
            stdPop.dataset.activeId = id;
            stdVisible = true;
            positionStdAboveBadge(badge);
          }
          return;
        }
        if (!e.target.closest('#metricStdPopover')) hideStdPop();
      });
    })();

    // Review drawer — sort, filter, collapse
    let reviewSortOrder = 'period-desc';

    const MONTH_NAMES = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];

    function initReviewDrawer() {
      const stack = bodyEl.querySelector('#review-drawer-stack');
      if (!stack) return;

      const cards = Array.from(stack.querySelectorAll('.review-card'));

      // Collect unique submitters, years, months from cards
      const submitters = [...new Set(cards.map(c => c.dataset.submitterName || '').filter(Boolean))].sort();
      const years = [...new Set(cards.map(c => c.dataset.periodYear || '').filter(Boolean))].sort((a, b) => b - a);
      const months = [...new Set(cards.map(c => c.dataset.periodMonth || '').filter(Boolean))].sort((a, b) => a - b);

      const submitterSel = bodyEl.querySelector('.js-review-submitter-filter');
      const monthSel = bodyEl.querySelector('.js-review-month-filter');
      const yearSel = bodyEl.querySelector('.js-review-year-filter');

      if (submitterSel) {
        submitters.forEach(name => {
          const opt = document.createElement('option');
          opt.value = name;
          opt.textContent = name;
          submitterSel.appendChild(opt);
        });
      }
      if (yearSel) {
        years.forEach(yr => {
          const opt = document.createElement('option');
          opt.value = yr;
          opt.textContent = yr;
          yearSel.appendChild(opt);
        });
      }
      if (monthSel) {
        months.forEach(m => {
          const opt = document.createElement('option');
          opt.value = m;
          opt.textContent = MONTH_NAMES[parseInt(m, 10) - 1] || m;
          monthSel.appendChild(opt);
        });
      }

      // Set default sort active
      reviewSortOrder = 'period-desc';
      const defaultSort = bodyEl.querySelector('.js-review-sort[data-sort="period-desc"]');
      if (defaultSort) defaultSort.classList.add('active-sort');

      applyReviewSortFilter();
    }

    function applyReviewSortFilter() {
      const stack = bodyEl.querySelector('#review-drawer-stack');
      if (!stack) return;

      const submitterSel = bodyEl.querySelector('.js-review-submitter-filter');
      const monthSel = bodyEl.querySelector('.js-review-month-filter');
      const yearSel = bodyEl.querySelector('.js-review-year-filter');

      const submitterVal = submitterSel ? submitterSel.value : 'all';
      const monthVal = monthSel ? monthSel.value : 'all';
      const yearVal = yearSel ? yearSel.value : 'all';

      const cards = Array.from(stack.querySelectorAll('.review-card'));

      let visible = cards.filter(c => {
        if (submitterVal !== 'all' && (c.dataset.submitterName || '') !== submitterVal) return false;
        if (monthVal !== 'all' && String(c.dataset.periodMonth || '') !== String(monthVal)) return false;
        if (yearVal !== 'all' && String(c.dataset.periodYear || '') !== String(yearVal)) return false;
        return true;
      });

      cards.forEach(c => { c.style.display = 'none'; });
      visible.forEach(c => { c.style.display = ''; });

      visible.sort((a, b) => {
        const pa = a.dataset.period || '';
        const pb = b.dataset.period || '';
        if (reviewSortOrder === 'period-asc') return pa < pb ? -1 : pa > pb ? 1 : 0;
        return pa > pb ? -1 : pa < pb ? 1 : 0;
      });
      visible.forEach(c => stack.appendChild(c));

      const countEl = bodyEl.querySelector('.review-drawer-count');
      if (countEl) {
        countEl.textContent = `${visible.length} of ${cards.length} review${cards.length !== 1 ? 's' : ''}`;
      }
    }

    bodyEl.addEventListener('click', function(e) {
      // Sort buttons
      const sortBtn = e.target.closest('.js-review-sort');
      if (sortBtn) {
        reviewSortOrder = sortBtn.dataset.sort;
        bodyEl.querySelectorAll('.js-review-sort').forEach(b => b.classList.remove('active-sort'));
        sortBtn.classList.add('active-sort');
        applyReviewSortFilter();
        return;
      }

      // Expand/collapse all
      if (e.target.closest('.js-review-expand-all')) {
        bodyEl.querySelectorAll('.review-card').forEach(c => c.classList.add('open'));
        return;
      }
      if (e.target.closest('.js-review-collapse-all')) {
        bodyEl.querySelectorAll('.review-card').forEach(c => c.classList.remove('open'));
        return;
      }

      // Individual card toggle
      const toggle = e.target.closest('.js-review-toggle');
      if (toggle) {
        const card = toggle.closest('.review-card');
        if (card) card.classList.toggle('open');
        return;
      }
    });

    bodyEl.addEventListener('keydown', function(e) {
      if (e.key === 'Enter' || e.key === ' ') {
        const toggle = e.target.closest('.js-review-toggle');
        if (toggle) {
          e.preventDefault();
          const card = toggle.closest('.review-card');
          if (card) card.classList.toggle('open');
        }
      }
    });

    bodyEl.addEventListener('change', function(e) {
      if (e.target.matches('.js-review-submitter-filter, .js-review-month-filter, .js-review-year-filter')) {
        applyReviewSortFilter();
      }
      if (e.target.matches('.js-coaching-submitter-filter, .js-coaching-type-filter')) {
        applyCoachingSortFilter();
      }
      if (e.target.matches('.js-goals-status-filter, .js-goals-priority-filter')) {
        applyGoalsSortFilter();
      }
    });

    // ── Coaching drawer ──────────────────────────────────────────────────────
    let coachingSortOrder = 'date-desc';

    function initCoachingDrawer() {
      const stack = bodyEl.querySelector('#coaching-drawer-stack');
      if (!stack) return;

      const cards = Array.from(stack.querySelectorAll('.review-card'));
      const submitters = [...new Set(cards.map(c => c.dataset.submitterName || '').filter(Boolean))].sort();

      const submitterSel = bodyEl.querySelector('.js-coaching-submitter-filter');
      if (submitterSel) {
        submitters.forEach(name => {
          const opt = document.createElement('option');
          opt.value = name;
          opt.textContent = name;
          submitterSel.appendChild(opt);
        });
      }

      coachingSortOrder = 'date-desc';
      const defaultSort = bodyEl.querySelector('.js-coaching-sort[data-sort="date-desc"]');
      if (defaultSort) defaultSort.classList.add('active-sort');

      applyCoachingSortFilter();
    }

    function applyCoachingSortFilter() {
      const stack = bodyEl.querySelector('#coaching-drawer-stack');
      if (!stack) return;

      const submitterSel = bodyEl.querySelector('.js-coaching-submitter-filter');
      const typeSel = bodyEl.querySelector('.js-coaching-type-filter');
      const submitterVal = submitterSel ? submitterSel.value : 'all';
      const typeVal = typeSel ? typeSel.value : 'all';

      const cards = Array.from(stack.querySelectorAll('.review-card'));
      const visible = cards.filter(c => {
        if (submitterVal !== 'all' && (c.dataset.submitterName || '') !== submitterVal) return false;
        if (typeVal !== 'all' && (c.dataset.type || '') !== typeVal) return false;
        return true;
      });

      cards.forEach(c => { c.style.display = 'none'; });
      visible.forEach(c => { c.style.display = ''; });

      visible.sort((a, b) => {
        const da = a.dataset.incidentDate || '';
        const db = b.dataset.incidentDate || '';
        if (coachingSortOrder === 'date-asc') return da < db ? -1 : da > db ? 1 : 0;
        return da > db ? -1 : da < db ? 1 : 0;
      });
      visible.forEach(c => stack.appendChild(c));

      const countEl = bodyEl.querySelector('#coaching-drawer-stack ~ .review-drawer-count, .review-drawer-count');
      const toolbarCount = bodyEl.querySelector('.review-drawer-toolbar .review-drawer-count');
      if (toolbarCount) toolbarCount.textContent = `${visible.length} of ${cards.length}`;
    }

    bodyEl.addEventListener('click', function(e) {
      // Already bound — extend with coaching/goals
    });

    // Extend the existing bodyEl click handler via an additional listener
    bodyEl.addEventListener('click', function(e) {
      const coachingSort = e.target.closest('.js-coaching-sort');
      if (coachingSort) {
        coachingSortOrder = coachingSort.dataset.sort;
        bodyEl.querySelectorAll('.js-coaching-sort').forEach(b => b.classList.remove('active-sort'));
        coachingSort.classList.add('active-sort');
        applyCoachingSortFilter();
        return;
      }
      if (e.target.closest('.js-coaching-expand-all')) {
        bodyEl.querySelectorAll('#coaching-drawer-stack .review-card').forEach(c => c.classList.add('open'));
        return;
      }
      if (e.target.closest('.js-coaching-collapse-all')) {
        bodyEl.querySelectorAll('#coaching-drawer-stack .review-card').forEach(c => c.classList.remove('open'));
        return;
      }

      const goalsSort = e.target.closest('.js-goals-sort');
      if (goalsSort) {
        goalsSortOrder = goalsSort.dataset.sort;
        bodyEl.querySelectorAll('.js-goals-sort').forEach(b => b.classList.remove('active-sort'));
        goalsSort.classList.add('active-sort');
        applyGoalsSortFilter();
        return;
      }
      if (e.target.closest('.js-goals-expand-all')) {
        bodyEl.querySelectorAll('#goals-drawer-stack .review-card').forEach(c => c.classList.add('open'));
        return;
      }
      if (e.target.closest('.js-goals-collapse-all')) {
        bodyEl.querySelectorAll('#goals-drawer-stack .review-card').forEach(c => c.classList.remove('open'));
        return;
      }
    });

    // ── Goals drawer ─────────────────────────────────────────────────────────
    let goalsSortOrder = 'due-asc';

    function initGoalsDrawer() {
      goalsSortOrder = 'due-asc';
      const defaultSort = bodyEl.querySelector('.js-goals-sort[data-sort="due-asc"]');
      if (defaultSort) defaultSort.classList.add('active-sort');
      applyGoalsSortFilter();
    }

    function applyGoalsSortFilter() {
      const stack = bodyEl.querySelector('#goals-drawer-stack');
      if (!stack) return;

      const statusSel = bodyEl.querySelector('.js-goals-status-filter');
      const prioritySel = bodyEl.querySelector('.js-goals-priority-filter');
      const statusVal = statusSel ? statusSel.value : 'all';
      const priorityVal = prioritySel ? prioritySel.value : 'all';

      const cards = Array.from(stack.querySelectorAll('.review-card'));
      const visible = cards.filter(c => {
        if (statusVal !== 'all' && (c.dataset.status || '') !== statusVal) return false;
        if (priorityVal !== 'all' && (c.dataset.priority || '') !== priorityVal) return false;
        return true;
      });

      cards.forEach(c => { c.style.display = 'none'; });
      visible.forEach(c => { c.style.display = ''; });

      visible.sort((a, b) => {
        const da = a.dataset.dueDate || '9999-99-99';
        const db = b.dataset.dueDate || '9999-99-99';
        if (goalsSortOrder === 'due-asc') return da < db ? -1 : da > db ? 1 : 0;
        return da > db ? -1 : da < db ? 1 : 0;
      });
      visible.forEach(c => stack.appendChild(c));

      const toolbarCount = bodyEl.querySelector('.review-drawer-toolbar .review-drawer-count');
      if (toolbarCount) toolbarCount.textContent = `${visible.length} of ${cards.length}`;
    }

    closeBtn.addEventListener('click', closeDrawer);
    backdrop.addEventListener('click', closeDrawer);

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') closeDrawer();
    });
  })();
</script>

</main>
<script src="/js/staffProfile.js"></script>
<script>
(function () {
  const dataEl = document.getElementById('reviewSparklineData');
  const canvas = document.getElementById('reviewScoreSparkline');
  if (!dataEl || !canvas) return;

  let points;
  try { points = JSON.parse(dataEl.textContent || '[]'); } catch(e) { return; }
  if (!points.length) return;

  const scores = points.map(function(p) { return p.score; });
  const valid = scores.filter(function(s) { return s != null && !isNaN(s); });
  if (!valid.length) return;

  const minScore = Math.max(0, Math.min.apply(null, valid) - 0.5);
  const maxScore = Math.min(5, Math.max.apply(null, valid) + 0.5);
  const range = maxScore - minScore || 1;

  const ctx = canvas.getContext('2d');
  const W = canvas.width, H = canvas.height;
  const pad = { top: 8, bottom: 8, left: 4, right: 4 };
  const plotW = W - pad.left - pad.right;
  const plotH = H - pad.top - pad.bottom;
  const n = scores.length;

  ctx.clearRect(0, 0, W, H);

  // draw midline at score 3
  const midY = pad.top + plotH * (1 - (3 - minScore) / range);
  ctx.strokeStyle = 'rgba(255,255,255,0.08)';
  ctx.lineWidth = 1;
  ctx.setLineDash([3, 3]);
  ctx.beginPath();
  ctx.moveTo(pad.left, midY);
  ctx.lineTo(pad.left + plotW, midY);
  ctx.stroke();
  ctx.setLineDash([]);

  // build path
  const xs = [], ys = [];
  for (var i = 0; i < n; i++) {
    var s = scores[i];
    xs.push(pad.left + (i / (n - 1 || 1)) * plotW);
    ys.push(s != null ? pad.top + plotH * (1 - (s - minScore) / range) : null);
  }

  // fill gradient
  var grad = ctx.createLinearGradient(0, pad.top, 0, pad.top + plotH);
  grad.addColorStop(0, 'rgba(99,102,241,0.25)');
  grad.addColorStop(1, 'rgba(99,102,241,0.02)');
  ctx.fillStyle = grad;
  ctx.beginPath();
  var started = false;
  for (var i = 0; i < n; i++) {
    if (ys[i] == null) continue;
    if (!started) { ctx.moveTo(xs[i], ys[i]); started = true; }
    else ctx.lineTo(xs[i], ys[i]);
  }
  ctx.lineTo(xs[n-1], pad.top + plotH);
  ctx.lineTo(xs[0], pad.top + plotH);
  ctx.closePath();
  ctx.fill();

  // line
  ctx.strokeStyle = 'rgba(99,102,241,0.85)';
  ctx.lineWidth = 2;
  ctx.lineJoin = 'round';
  ctx.beginPath();
  started = false;
  for (var i = 0; i < n; i++) {
    if (ys[i] == null) { started = false; continue; }
    if (!started) { ctx.moveTo(xs[i], ys[i]); started = true; }
    else ctx.lineTo(xs[i], ys[i]);
  }
  ctx.stroke();

  // dots
  for (var i = 0; i < n; i++) {
    if (ys[i] == null) continue;
    ctx.beginPath();
    ctx.arc(xs[i], ys[i], 2.5, 0, Math.PI * 2);
    ctx.fillStyle = '#818cf8';
    ctx.fill();
  }
})();
</script>
