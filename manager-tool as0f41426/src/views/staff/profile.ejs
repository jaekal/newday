        data-drawer-subtitle="Department-level ranking snapshot."
        data-drawer-source="drawer-snapshot-department-rank"
      >
        <span class="label">Department Rank</span>
        <strong><%= safeDashboard.departmentRank ?? '—' %></strong>
      </button>
      <% } %>

      <% if (canSeeYearAvg) { %>
      <button
        type="button"
        class="snapshot-kpi-clickcard js-open-profile-drawer"
        data-drawer-title="Year Average"
        data-drawer-subtitle="Average across visible review history for the year view."
        data-drawer-source="drawer-snapshot-year-avg"
      >
        <span class="label">Year Avg</span>
        <strong><%= yearAvgDisplay %></strong>
      </button>
      <% } %>

      <button
        type="button"
        class="snapshot-kpi-clickcard js-open-profile-drawer"
        data-drawer-title="Current Month Average"
        data-drawer-subtitle="Current month average based on visible review records."
        data-drawer-source="drawer-snapshot-month-avg"
      >
        <span class="label">Current Month Avg</span>
        <strong><%= monthAvgDisplay %></strong>
      </button>
    </div>

    <div id="drawer-snapshot-strength" class="profile-section-hidden-source">
      <div class="drawer-subcard">
        <h4>Strength Snapshot</h4>
        <p class="bucket-summary-note"><%= summaryStrength %></p>
      </div>
    </div>

    <div id="drawer-snapshot-focus" class="profile-section-hidden-source">
      <div class="drawer-subcard">
        <h4>Area of Focus Snapshot</h4>
        <p class="bucket-summary-note"><%= summaryFocus %></p>
      </div>
    </div>

    <div id="drawer-snapshot-risk" class="profile-section-hidden-source">
      <div class="drawer-subcard">
        <h4>Risk Snapshot</h4>
        <p class="bucket-summary-note"><%= summaryRisk %></p>
      </div>
    </div>

    <div id="drawer-snapshot-latest-review" class="profile-section-hidden-source">
      <div class="drawer-subcard">
        <h4>Latest Review</h4>
        <% if (latestReview) { %>
          <p class="bucket-summary-note">
            Period: <strong><%= latestReview.periodLabel %></strong><br />
            Reviewer: <strong><%= latestReview.submitterName %></strong><br />
            Overall: <strong><%= latestReview.overallScore != null ? latestReview.overallScore.toFixed(2) : 'N/A' %></strong>
          </p>
        <% } else { %>
          <div class="drawer-empty">No review history yet.</div>
        <% } %>
      </div>
    </div>

    <div id="drawer-snapshot-shift-rank" class="profile-section-hidden-source">
      <div class="drawer-subcard">
        <h4>Shift Rank</h4>
        <p class="bucket-summary-note">
          Current shift rank: <strong><%= safeDashboard.shiftRank ?? '—' %></strong>
        </p>
      </div>
    </div>

    <div id="drawer-snapshot-department-rank" class="profile-section-hidden-source">
      <div class="drawer-subcard">
        <h4>Department Rank</h4>
        <p class="bucket-summary-note">
          Current department rank: <strong><%= safeDashboard.departmentRank ?? '—' %></strong>
        </p>
      </div>
    </div>

    <div id="drawer-snapshot-year-avg" class="profile-section-hidden-source">
      <div class="drawer-subcard">
        <h4>Year Average</h4>
        <p class="bucket-summary-note">
          Year average: <strong><%= yearAvgDisplay %></strong>
        </p>
      </div>
    </div>

    <div id="drawer-snapshot-month-avg" class="profile-section-hidden-source">
      <div class="drawer-subcard">
        <h4>Current Month Average</h4>
        <p class="bucket-summary-note">
          Current month average: <strong><%= monthAvgDisplay %></strong>
        </p>
      </div>
    </div>
  </section>

  <% if (canSeePerfDetail) { %>
  <section id="performance" class="page-band band-performance">
    <div class="band-header">
      <div>
        <div class="band-title">Performance Detail</div>
        <div class="band-subtitle">
          Click a bucket to open the side pane with metrics, interpretation, and manager action.
        </div>
      </div>
    </div>

    <div class="perf-summary-grid">
      <% perfBucketCards.forEach(function(item) { const b = item.data || {}; %>
        <button
          type="button"
          class="perf-summary-clickcard <%= b.status || '' %> js-open-profile-drawer"
          data-drawer-title="<%= item.title %>"
          data-drawer-subtitle="Detailed performance metrics, interpretation, and manager guidance."
          data-drawer-source="drawer-perf-<%= item.key %>"
        >
          <div class="perf-summary-top">
            <div class="perf-summary-title"><%= item.title %></div>
            <span class="perf-status <%= b.status || '' %>"><%= b.statusLabel || 'N/A' %></span>
          </div>

          <div class="perf-summary-score"><%= b.score != null ? b.score : '—' %></div>

          <div class="perf-summary-meta">
            <span class="chip small">
              Trend:
              <strong>
                <%= b.trend > 0 ? '▲ ' : b.trend < 0 ? '▼ ' : '• ' %><%= Math.abs(b.trend || 0) %>
              </strong>
            </span>
          </div>

          <div class="perf-summary-hint">
            <%= b.highlight || b.insight || 'Open for full detail.' %>
          </div>
        </button>
      <% }) %>
    </div>

    <% perfBucketCards.forEach(function(item) { const b = item.data || {}; const m = b.metrics || {}; %>
      <div id="drawer-perf-<%= item.key %>" class="profile-section-hidden-source">
        <div class="drawer-stack">
          <div class="drawer-subcard">
            <div style="display:flex; justify-content:space-between; gap:0.75rem; flex-wrap:wrap; align-items:flex-start;">
              <div>
                <h4><%= item.title %></h4>
                <div class="drawer-list-meta"><%= b.highlight || b.insight || '—' %></div>
              </div>
              <div style="display:flex; gap:0.4rem; flex-wrap:wrap; align-items:center;">
                <span class="perf-status <%= b.status || '' %>"><%= b.statusLabel || 'N/A' %></span>
                <span class="chip small">
                  Trend: <strong><%= b.trend > 0 ? '▲ ' : b.trend < 0 ? '▼ ' : '• ' %><%= Math.abs(b.trend || 0) %></strong>
                </span>
              </div>
            </div>
            <% if (b.score != null) { %>
              <div class="bucket-score-bar-wrap" style="margin-top:0.85rem;">
                <div style="display:flex; justify-content:space-between; margin-bottom:0.3rem;">
                  <span style="font-size:0.78rem; color:rgba(226,232,240,0.5);">Overall bucket score</span>
                  <span style="font-size:0.85rem; font-weight:700; color:rgba(226,232,240,0.9);"><%= b.score %> / 100</span>
                </div>
                <div style="height:6px; border-radius:4px; background:rgba(255,255,255,0.08); overflow:hidden;">
                  <div style="height:100%; width:<%= b.score %>%; border-radius:4px; background:<%= b.status === 'good' ? '#22c55e' : b.status === 'watch' ? '#eab308' : '#ef4444' %>;"></div>
                </div>
                <div style="display:flex; justify-content:space-between; margin-top:0.3rem; font-size:0.72rem; color:rgba(226,232,240,0.3);">
                  <span>0 — Risk</span><span>75 — Watch</span><span>90 — Strong</span>
                </div>
              </div>
            <% } %>
          </div>

          <div class="drawer-subcard">
            <h4>What this measures</h4>
            <p class="bucket-summary-note"><%= b.insight || 'No interpretation available.' %></p>
          </div>

          <div class="drawer-subcard">
            <h4>Manager action</h4>
            <p class="bucket-summary-note"><%= b.managerAction || 'Review this area with the employee using the supporting metrics below.' %></p>
          </div>

          <div class="drawer-subcard">
            <div style="display:flex; justify-content:space-between; align-items:baseline; margin-bottom:0.5rem;">
              <h4 style="margin:0;">Metric Breakdown</h4>
              <span style="font-size:0.72rem; color:rgba(226,232,240,0.35);">Value &nbsp;|&nbsp; Sub-score (0–100)</span>
            </div>
            <% const dr = b.detailRows || []; %>
            <% if (dr.length) { %>
              <div class="detail-rows-list">
                <% dr.forEach(function(row, ri) {
                  const subScore = row.score;
                  const tone = subScore == null ? 'neutral' : subScore >= 90 ? 'good' : subScore >= 75 ? 'watch' : 'risk';
                  const formulaJson = row.formula ? JSON.stringify(row.formula) : null;
                  const standardJson = row.standard ? JSON.stringify(row.standard) : null;
                  const rowId = item.key + '-' + ri;
                %>
                  <div class="detail-row">
                    <span class="detail-row-label">
                      <% if (formulaJson) { %>
                        <span class="metric-formula-trigger" data-row-id="<%= rowId %>"><%= row.label %> <span class="metric-info-icon">ⓘ</span></span>
                        <script>window.__mf = window.__mf||{}; window.__mf['<%= rowId %>'] = <%- formulaJson %>;</script>
                      <% } else { %><%= row.label %><% } %>
                    </span>
                    <span class="detail-row-value"><%= row.value != null && row.value !== '' ? row.value : '—' %></span>
                    <div class="detail-row-pills">
                      <% if (subScore != null) { %>
                        <span class="detail-row-score <%= tone %>"><%= subScore %></span>
                      <% } else { %>
                        <span class="detail-row-score neutral">—</span>
                      <% } %>
                      <% if (standardJson) { %>
                        <button type="button" class="std-badge metric-std-trigger" data-row-id="<%= rowId %>">STD</button>
                        <script>window.__ms = window.__ms||{}; window.__ms['<%= rowId %>'] = <%- standardJson %>;</script>
                      <% } %>
                    </div>
                  </div>
                <% }) %>
              </div>
            <% } else { %>
              <div class="drawer-empty">No supporting metrics available for this bucket.</div>
            <% } %>
          </div>
        </div>
      </div>
    <% }) %>
  </section>
  <% } %>

  <section id="compliance" class="page-band band-ops">
    <div class="band-header">
      <div>
        <div class="band-title">Operations / Readiness</div>
        <div class="band-subtitle">
          Daily compliance, assignment rhythm, and training readiness grouped into one operational view.
        </div>
      </div>
    </div>

    <div id="drawer-compliance-day" class="profile-section-hidden-source">
  <div class="drawer-stack">
    <div class="drawer-subcard">
      <div style="display:flex; justify-content:space-between; gap:0.75rem; flex-wrap:wrap; align-items:flex-start;">
        <div>
          <h4 id="drawerComplianceDayTitle">Day Detail</h4>
          <div class="drawer-list-meta" id="drawerComplianceDaySubtitle">—</div>
        </div>

        <div style="display:flex; gap:0.5rem; flex-wrap:wrap;">
          <button type="button" class="btn ghost btn-sm" id="drawerCalOpenTalkingPoints">Open 1:1 Talking Points</button>
        </div>
      </div>
    </div>

    <div class="calendar-details-grid">
      <div class="ops-soft-panel">
        <h4>ESD</h4>
        <div id="drawerCalEsdBlock" class="muted">—</div>
      </div>

      <div class="ops-soft-panel">
        <h4>Attendance</h4>
        <div id="drawerCalAttBlock" class="muted">—</div>
      </div>
    </div>
  </div>
</div>

    <div class="ops-summary-grid">
      <div class="ops-summary-card">
        <span class="ops-summary-label">Attendance Reliability</span>
        <strong><%= opsSummary.attendanceReliability ?? '—' %></strong>
        <p><%= opsSummary.attendanceReliabilityNote || 'Attendance consistency snapshot.' %></p>
        <% if (safeLateTrendDelta && safeLateTrendDelta.recentAvg != null) { %>
          <div style="margin-top:0.4rem; display:flex; flex-wrap:wrap; gap:0.35rem;">
            <span class="chip chip-neutral">Avg late: <%= safeLateTrendDelta.recentAvg %>min
              <% if (safeLateTrendDelta.delta != null) { %>
                (<%= safeLateTrendDelta.delta > 0 ? '↑' : '↓' %><%= Math.abs(safeLateTrendDelta.delta) %>min vs prior 30d)
              <% } %>
            </span>
          </div>
        <% } %>
        <% if (safeAbsencePattern && safeAbsencePattern.flagged) { %>
          <div style="margin-top:0.4rem;">
            <span class="chip chip-warn">⚠ Mon/Fri absence pattern detected</span>
          </div>
        <% } %>
        <a class="btn ghost btn-sm" style="margin-top:0.5rem;" href="/staff/<%= staff.id %>/attendance">Full history</a>
      </div>

      <div class="ops-summary-card">
        <span class="ops-summary-label">ESD Compliance</span>
        <strong><%= opsSummary.esdCompliance ?? '—' %></strong>
        <p><%= opsSummary.esdComplianceNote || 'Daily ESD pass readiness.' %></p>
        <% if (safeEsdStreak != null && safeEsdStreak > 0) { %>
          <div style="margin-top:0.4rem;">
            <span class="chip chip-ok"><%= safeEsdStreak %> day PASS streak</span>
          </div>
        <% } %>
        <a class="btn ghost btn-sm" style="margin-top:0.5rem;" href="/staff/<%= staff.id %>/esd">Full history</a>
      </div>

      <div class="ops-summary-card">
        <span class="ops-summary-label">Training Health</span>
        <strong><%= opsSummary.trainingHealth ?? '—' %></strong>
        <p><%= opsSummary.trainingHealthNote || 'Current vs expired / expiring training.' %></p>
        <% if (viewerRoleLocal === 'ADMIN' || viewerRoleLocal === 'SENIOR_MANAGER' || viewerRoleLocal === 'MANAGER' || viewerRoleLocal === 'SUPERVISOR' || viewerRoleLocal === 'LEAD') { %>
          <a class="btn ghost btn-sm" style="margin-top:0.5rem;" href="/staff/<%= staff.id %>/training-assignments">Manage Assignments</a>
        <% } %>
      </div>

      <div class="ops-summary-card">
        <span class="ops-summary-label">Assignment Rhythm</span>
        <strong><%= opsSummary.assignmentRhythm ?? '—' %></strong>
        <p><%= opsSummary.assignmentRhythmNote || 'Recent assignment and closure cadence.' %></p>
      </div>
    </div>

    <%
      const safeBenchmark = (typeof benchmark !== 'undefined' && benchmark) ? benchmark : null;
    %>
    <% if (safeBenchmark) { %>
      <div class="benchmark-panel" style="margin-top:1rem; margin-bottom:0.5rem;">
        <div class="benchmark-header">
          <span class="muted small">Peer comparison · <%= safeBenchmark.peerCount %> colleague<%= safeBenchmark.peerCount !== 1 ? 's' : '' %> in same <%= safeBenchmark.building %><%= safeBenchmark.shift ? ' / ' + safeBenchmark.shift : '' %> shift</span>
        </div>
        <div class="benchmark-grid">
          <% if (safeBenchmark.reviewScore.mine != null || safeBenchmark.reviewScore.peerAvg != null) { %>
            <div class="benchmark-item">
              <span class="benchmark-label">Review Score</span>
              <span class="benchmark-mine"><%= safeBenchmark.reviewScore.mine != null ? safeBenchmark.reviewScore.mine.toFixed(2) : '—' %></span>
              <span class="benchmark-vs">vs</span>
              <span class="benchmark-peer muted"><%= safeBenchmark.reviewScore.peerAvg != null ? safeBenchmark.reviewScore.peerAvg.toFixed(2) : '—' %> avg</span>
              <% if (safeBenchmark.reviewScore.delta != null) { %>
                <span class="chip <%= safeBenchmark.reviewScore.delta >= 0 ? 'chip-ok' : 'chip-warn' %>" style="font-size:0.7rem;">
                  <%= safeBenchmark.reviewScore.delta >= 0 ? '+' : '' %><%= safeBenchmark.reviewScore.delta %>
                </span>
              <% } %>
            </div>
          <% } %>
          <% if (safeBenchmark.absentRate.mine != null || safeBenchmark.absentRate.peerAvg != null) { %>
            <div class="benchmark-item">
              <span class="benchmark-label">Absent Rate</span>
              <span class="benchmark-mine"><%= safeBenchmark.absentRate.mine != null ? safeBenchmark.absentRate.mine + '%' : '—' %></span>
              <span class="benchmark-vs">vs</span>
              <span class="benchmark-peer muted"><%= safeBenchmark.absentRate.peerAvg != null ? safeBenchmark.absentRate.peerAvg + '%' : '—' %> avg</span>
              <% if (safeBenchmark.absentRate.delta != null) { %>
                <span class="chip <%= safeBenchmark.absentRate.delta <= 0 ? 'chip-ok' : 'chip-warn' %>" style="font-size:0.7rem;">
                  <%= safeBenchmark.absentRate.delta > 0 ? '+' : '' %><%= safeBenchmark.absentRate.delta %>%
                </span>
              <% } %>
            </div>
          <% } %>
        </div>
      </div>
    <% } %>

    <section class="section-shell ops-shell">
      <div class="section-shell-header">
        <div>
          <h2>Compliance Calendar</h2>
          <p>Quickly spot attendance and ESD issue days without reading every row.</p>
        </div>
      </div>

      <div class="support-strip">
        <span class="mini-chip">ESD: PASS / FAIL / NONE</span>
        <span class="mini-chip">Attendance: Present / Late / Absent</span>
        <span class="mini-chip warn">Use Risk Filter for issue-only view</span>
      </div>

      <div class="ops-panel">
        <div class="calendar-toolbar">
          <div class="calendar-actions">
            <button type="button" class="btn ghost btn-sm" id="calPrevMonth">◀ Prev</button>
            <button type="button" class="btn ghost btn-sm" id="calToday">Today</button>
            <button type="button" class="btn ghost btn-sm" id="calNextMonth">Next ▶</button>
          </div>

          <div class="calendar-tools">
            <div class="chip muted small" id="calTitle">—</div>
            <button
              type="button"
              class="btn ghost btn-sm"
              id="calRiskToggle"
              data-mode="all"
              title="Show only issue days (missing/failed ESD, late/absent attendance)"
            >
              Risk filter: OFF
            </button>
            <button type="button" class="btn ghost btn-sm" id="calClearSelection" title="Close day details panel">
              Clear selection
            </button>
          </div>
        </div>

        <div id="calSummary" class="calendar-summary">
