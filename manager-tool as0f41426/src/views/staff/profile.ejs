        <% } %>

        <div class="profile-hero-content">
          <div class="profile-hero-topline">
            <h1><%= staff.name || 'Unknown Staff' %></h1>
            <div class="trend-pill <%= trendDirection %>">
              <%= trendLabel %>
            </div>
          </div>

          <div class="profile-meta profile-meta-wide">
            <span class="badge"><%= profile.positionType || 'Position not set' %></span>
            <span class="badge"><%= staff.rosterShift || 'Shift N/A' %></span>
            <span class="badge"><%= staff.rosterBuilding || 'Bldg N/A' %></span>
            <span class="badge subtle">ID: <%= profile.employeeId || '—' %></span>
            <% if (typeof tenureLabel !== 'undefined' && tenureLabel) { %>
              <span class="badge subtle">Tenure: <%= tenureLabel %></span>
            <% } %>
          </div>

          <% if (latestReview) { %>
            <p class="muted profile-hero-note">
              Last reviewed in <strong><%= latestReview.periodLabel %></strong>
              by <strong><%= latestReview.submitterName %></strong>.
            </p>
