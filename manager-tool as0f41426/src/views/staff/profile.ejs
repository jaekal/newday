        data-drawer-source="drawer-snapshot-shift-rank"
      >
        <span class="label">Shift Rank</span>
        <strong><%= safeDashboard.shiftRank ?? '—' %></strong>
      </button>

      <button
        type="button"
        class="snapshot-kpi-clickcard js-open-profile-drawer"
