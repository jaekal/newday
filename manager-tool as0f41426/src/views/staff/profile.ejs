                <span class="review-drawer-toolbar-label">Reviewer</span>
                <select class="review-drawer-select js-review-submitter-filter">
                  <option value="all">All reviewers</option>
                </select>
              </div>
              <div class="review-drawer-toolbar-group">
                <span class="review-drawer-toolbar-label">Month</span>
                <select class="review-drawer-select js-review-month-filter">
                  <option value="all">All months</option>
                </select>
              </div>
              <div class="review-drawer-toolbar-group">
                <span class="review-drawer-toolbar-label">Year</span>
                <select class="review-drawer-select js-review-year-filter">
                  <option value="all">All years</option>
                </select>
              </div>
              <div class="review-drawer-count"></div>
            </div>
            <div class="review-drawer-toolbar-actions">
              <button type="button" class="btn ghost btn-small js-review-expand-all">Expand All</button>
              <button type="button" class="btn ghost btn-small js-review-collapse-all">Collapse All</button>
            </div>
          </div>

          <div class="drawer-stack" id="review-drawer-stack">
            <% ratingHistory.forEach(function(r) {
              const overallFull = getOverallComment(r);
              const q = r.questions || {};
              const monthNames = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
