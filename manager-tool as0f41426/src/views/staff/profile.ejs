          <div class="drawer-empty">No reviews available.</div>
        <% } else { %>
          <div class="review-drawer-toolbar">
            <div class="review-drawer-toolbar-row">
              <div class="review-drawer-toolbar-group">
                <span class="review-drawer-toolbar-label">Sort</span>
                <button type="button" class="btn ghost btn-small js-review-sort" data-sort="period-desc">Newest</button>
                <button type="button" class="btn ghost btn-small js-review-sort" data-sort="period-asc">Oldest</button>
