        <% if (canEditProfile) { %>
          <a href="/staff/<%= staff.id %>/edit" class="btn ghost">Edit Full Profile</a>
          <a href="/staff/<%= staff.id %>/export/pdf" target="_blank" class="btn ghost">Export PDF</a>
        <% } %>

        <% if (canCreateReview) { %>
          <a href="/reviews/new?staffId=<%= staff.id %>" class="btn">+ Review</a>
        <% } %>

        <% if (canCreateGoal) { %>
          <a href="/goals/new?ownerId=<%= staff.id %>" class="btn ghost">+ Goal</a>
        <% } %>

        <% if (canCreateReview) { %>
          <a href="/meetings/new?staffId=<%= staff.id %>&type=ONE_ON_ONE" class="btn ghost">Schedule 1:1</a>
