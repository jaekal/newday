<%
  const incomingProfile = (typeof locals !== 'undefined' && locals && locals.profile) ? locals.profile : null;
  const profile = incomingProfile || (staff && staff.StaffProfile ? staff.StaffProfile : {});

  const viewerRoleLocal =
    (typeof locals !== 'undefined' && locals && locals.viewerRole) ? String(locals.viewerRole).toUpperCase()
    : (typeof locals !== 'undefined' && locals && locals.currentUserRole) ? String(locals.currentUserRole).toUpperCase()
    : (typeof currentUser !== 'undefined' && currentUser && currentUser.role) ? String(currentUser.role).toUpperCase()
    : '';

  let latestReview = null;
  if (ratingHistory && ratingHistory.length) {
    latestReview = ratingHistory[ratingHistory.length - 1];
  }

  const canManageReviews = viewerRoleLocal === 'ADMIN' || viewerRoleLocal === 'SENIOR_MANAGER' || viewerRoleLocal === 'MANAGER';
  const canEditProfile = viewerRoleLocal === 'ADMIN' || viewerRoleLocal === 'SENIOR_MANAGER' || viewerRoleLocal === 'MANAGER' || viewerRoleLocal === 'SUPERVISOR';
  const canCreateReview = viewerRoleLocal === 'ADMIN' || viewerRoleLocal === 'SENIOR_MANAGER' || viewerRoleLocal === 'MANAGER' || viewerRoleLocal === 'SUPERVISOR' || viewerRoleLocal === 'LEAD';
  const canCreateGoal = viewerRoleLocal === 'ADMIN' || viewerRoleLocal === 'SENIOR_MANAGER' || viewerRoleLocal === 'MANAGER' || viewerRoleLocal === 'SUPERVISOR' || viewerRoleLocal === 'LEAD';
  const canCreateIncident = viewerRoleLocal === 'ADMIN' || viewerRoleLocal === 'SENIOR_MANAGER' || viewerRoleLocal === 'MANAGER' || viewerRoleLocal === 'SUPERVISOR' || viewerRoleLocal === 'LEAD';

  // Snapshot visibility by role
  const canSeeStrengthFocus = viewerRoleLocal === 'ADMIN' || viewerRoleLocal === 'SENIOR_MANAGER' || viewerRoleLocal === 'MANAGER';
  const canSeeRisk          = viewerRoleLocal === 'ADMIN' || viewerRoleLocal === 'SENIOR_MANAGER' || viewerRoleLocal === 'MANAGER' || viewerRoleLocal === 'SUPERVISOR';
  const canSeeRanks         = viewerRoleLocal === 'ADMIN' || viewerRoleLocal === 'SENIOR_MANAGER' || viewerRoleLocal === 'MANAGER';
  const canSeeYearAvg       = viewerRoleLocal === 'ADMIN' || viewerRoleLocal === 'SENIOR_MANAGER' || viewerRoleLocal === 'MANAGER' || viewerRoleLocal === 'SUPERVISOR';
  const canSeePerfDetail    = viewerRoleLocal === 'ADMIN' || viewerRoleLocal === 'SENIOR_MANAGER' || viewerRoleLocal === 'MANAGER' || viewerRoleLocal === 'SUPERVISOR';

  // Grid column counts for adaptive layout
  const insightStripCols = canSeeStrengthFocus ? 4 : (canSeeRisk ? 2 : 1);
  const kpiGridCols      = canSeeRanks ? 4 : (canSeeYearAvg ? 2 : 1);

  const safeAssignmentStats =
    (typeof assignmentStats !== 'undefined' && assignmentStats) ? assignmentStats : {
      totalDays: 0, totalRacks: 0, avgRacksPerDay: null, maxRacksInSingleDay: 0
    };

  const safeAttendanceStats =
    (typeof attendanceStats !== 'undefined' && attendanceStats) ? attendanceStats : {
      totalDays: 0, presentDays: 0, absentDays: 0, lateDays: 0,
      avgMinutesLateOnLateDays: null, onTimeDays: 0, unpunctualDays: 0, lateDaysByBucket: 0
    };

  const safeTrainingStats =
    (typeof trainingStats !== 'undefined' && trainingStats) ? trainingStats : {
      total: 0, completed: 0, inProgress: 0, notStarted: 0, current: 0, expiring: 0, expired: 0
    };

  const safeEsdStats =
    (typeof esdStats !== 'undefined' && esdStats) ? esdStats : {
      totalDays: 0, daysWithPassBeforeShift: 0, daysWithPassAfterShift: 0, daysWithoutPass: 0
    };

  const safeTrainingGrouped =
    (typeof trainingGrouped !== 'undefined' && Array.isArray(trainingGrouped)) ? trainingGrouped : [];

  const safeEsdDailySummary =
    (typeof esdDailySummary !== 'undefined' && Array.isArray(esdDailySummary)) ? esdDailySummary : [];

  const safeAttendanceDailySummary =
    (typeof attendanceDailySummary !== 'undefined' && Array.isArray(attendanceDailySummary)) ? attendanceDailySummary : [];

  const safeAssignmentDailySummary =
    (typeof assignmentDailySummary !== 'undefined' && Array.isArray(assignmentDailySummary)) ? assignmentDailySummary : [];

  const safeGoalStats =
    (typeof goalStats !== 'undefined' && goalStats) ? goalStats : {
      total: 0, open: 0, inProgress: 0, done: 0, onHold: 0,
      lastCheckInAt: null, daysSinceLastCheckIn: null,
    };

  const safeEsdStreak = (typeof esdStreak !== 'undefined' && esdStreak != null) ? esdStreak : null;
  const safeLateTrendDelta = (typeof lateTrendDelta !== 'undefined' && lateTrendDelta) ? lateTrendDelta : null;
  const safeAbsencePattern = (typeof absencePattern !== 'undefined' && absencePattern) ? absencePattern : null;

  const safeDashboard = (typeof dashboard !== 'undefined' && dashboard) ? dashboard : {};
  const perfBucketsArray = Array.isArray(safeDashboard.buckets) ? safeDashboard.buckets : [];
  const perfSummary = safeDashboard.summary || { strengths: [], focusAreas: [], riskFlags: [] };
  const overallPerfTrend = safeDashboard.overallTrend || { label: 'No trend data', direction: 'flat' };
  const newPerf = safeDashboard.performanceBuckets || {};

  function buildCompatBucket(label, oldBucket) {
    return {
      label,
      score: oldBucket && oldBucket.score != null ? oldBucket.score : null,
      status: oldBucket && oldBucket.status ? oldBucket.status : '',
      statusLabel:
        oldBucket && oldBucket.status === 'good' ? 'Strong'
        : oldBucket && oldBucket.status === 'watch' ? 'Watch'
        : oldBucket && oldBucket.status === 'risk' ? 'Risk'
        : 'N/A',
      trend:
        oldBucket && oldBucket.trend && oldBucket.trend.direction === 'up' ? 1
        : oldBucket && oldBucket.trend && oldBucket.trend.direction === 'down' ? -1
        : 0,
      highlight: oldBucket && oldBucket.highlight ? oldBucket.highlight : 'No detail',
      insight: oldBucket && oldBucket.summary ? oldBucket.summary : 'No interpretation available.',
      managerAction: 'Review this area using the underlying metrics and coaching notes.',
      metrics: oldBucket && oldBucket.metrics ? oldBucket.metrics : {},
      detailRows: oldBucket && Array.isArray(oldBucket.detailRows) ? oldBucket.detailRows : []
    };
  }

  const perfCompatFromOld = {
    throughput: buildCompatBucket('Throughput / Execution', perfBucketsArray[0]),
    troubleshooting: buildCompatBucket('Troubleshooting Effectiveness', perfBucketsArray[1]),
    quality: buildCompatBucket('Quality Protection', perfBucketsArray[2]),
    timeOwnership: buildCompatBucket('Time Ownership / Downtime', perfBucketsArray[3]),
    reliability: buildCompatBucket('Reliability / Readiness', perfBucketsArray[4])
  };

  const perf = Object.keys(newPerf).length ? newPerf : perfCompatFromOld;

  const summaryStrength = perfSummary && perfSummary.strengths && perfSummary.strengths.length
    ? (perfSummary.strengths[0].title || perfSummary.strengths[0].label || perfSummary.strengths[0].text || '—')
    : '—';

  const summaryFocus = perfSummary && perfSummary.focusAreas && perfSummary.focusAreas.length
    ? (perfSummary.focusAreas[0].title || perfSummary.focusAreas[0].label || perfSummary.focusAreas[0].text || '—')
    : '—';

  const summaryRisk = perfSummary && perfSummary.riskFlags && perfSummary.riskFlags.length
    ? (perfSummary.riskFlags[0].label || perfSummary.riskFlags[0].title || perfSummary.riskFlags[0].text || 'None')
    : 'None';

  const yearAvgDisplay =
    safeDashboard.yearAvg != null ? safeDashboard.yearAvg
    : overallAverage != null ? overallAverage.toFixed(2)
    : '—';

  const monthAvgDisplay =
    safeDashboard.monthAvg != null ? safeDashboard.monthAvg
    : currentMonthAverage != null ? currentMonthAverage.toFixed(2)
    : '—';

  const trendDirection = safeDashboard.trendDirection || overallPerfTrend.direction || 'flat';
  const trendLabel = safeDashboard.trendLabel || overallPerfTrend.label || 'No trend data';

  const trainingHealthScore =
    safeTrainingStats.total
      ? Math.round(((safeTrainingStats.current || 0) / safeTrainingStats.total) * 100)
      : null;

  const attendanceReliabilityApprox =
    safeAttendanceStats.totalDays
      ? Math.round((((safeAttendanceStats.totalDays || 0) - ((safeAttendanceStats.absentDays || 0) + (safeAttendanceStats.lateDays || 0))) / safeAttendanceStats.totalDays) * 100)
      : null;

  const esdReliabilityApprox =
    safeEsdStats.totalDays
      ? Math.round((((safeEsdStats.daysWithPassBeforeShift || 0) + (safeEsdStats.daysWithPassAfterShift || 0)) / safeEsdStats.totalDays) * 100)
      : null;

  const opsSummary = safeDashboard.opsSummary || {
    attendanceReliability: attendanceReliabilityApprox != null ? attendanceReliabilityApprox + '%' : '—',
    attendanceReliabilityNote: 'Attendance consistency snapshot.',
    esdCompliance: esdReliabilityApprox != null ? esdReliabilityApprox + '%' : '—',
    esdComplianceNote: 'Daily ESD pass readiness.',
    trainingHealth: trainingHealthScore != null ? trainingHealthScore + '%' : '—',
    trainingHealthNote: 'Current vs expired / expiring training.',
    assignmentRhythm: safeAssignmentStats.avgRacksPerDay != null ? safeAssignmentStats.avgRacksPerDay : '—',
    assignmentRhythmNote: 'Recent assignment and closure cadence.'
  };

  const esdByDate = {};
  (safeEsdDailySummary || []).forEach(d => { if (d && d.date) esdByDate[d.date] = d; });

  const attByDate = {};
  (safeAttendanceDailySummary || []).forEach(d => { if (d && d.date) attByDate[d.date] = d; });

  const viewerId =
    (typeof currentUser !== 'undefined' && currentUser && currentUser.id) ? String(currentUser.id) : null;

  function getSubmitterId(i) {
    if (!i) return null;
    if (i.submitterId != null) return String(i.submitterId);
    if (i.Submitter && i.Submitter.id != null) return String(i.Submitter.id);
    return null;
  }

  function getSubmitterRole(i) {
    if (!i) return '';
    if (i.Submitter && i.Submitter.role) return String(i.Submitter.role).toUpperCase();
    return '';
  }

  const incidentsAll = (typeof incidents !== 'undefined' && Array.isArray(incidents)) ? incidents : [];
  let visibleIncidents = incidentsAll;

  if (viewerRoleLocal === 'LEAD') {
    visibleIncidents = incidentsAll.filter(i => viewerId && getSubmitterId(i) === viewerId);
  } else if (viewerRoleLocal === 'SUPERVISOR') {
    visibleIncidents = incidentsAll.filter(i => {
      const sid = getSubmitterId(i);
      if (viewerId && sid === viewerId) return true;
      const sr = getSubmitterRole(i);
      return sr === 'LEAD';
    });
  }

  const incStats = { positive: 0, coaching: 0, formal: 0, openFollowUps: 0 };
  if (visibleIncidents && visibleIncidents.length) {
    visibleIncidents.forEach(function(i) {
      const t = (i.type || 'COACHING').toUpperCase();
      if (t === 'POSITIVE') incStats.positive++;
      else if (t === 'FORMAL') incStats.formal++;
      else incStats.coaching++;

      if (i.requiresFollowUp && (i.followUpStatus || '').toUpperCase() !== 'CLOSED') {
        incStats.openFollowUps++;
      }
    });
  }

  function safeText(v) {
    return (v == null) ? '' : String(v).trim();
  }

  function getOverallComment(r) {
    return safeText(r && r.comment);
  }

  function getScoreComment(r, key) {
    const field = key + 'Comment';

    const candidates = [
      r && r[field],
      r && r.questions && r.questions[field],
      r && r.questions && r.questions[key] && r.questions[key].comment,
      r && r.questionComments && (r.questionComments[field] || r.questionComments[key] || r.questionComments[key + 'Comment']),
      r && r.comments && (r.comments[field] || r.comments[key] || r.comments[key + 'Comment']),
      r && r.meta && r.meta[field]
    ];

    for (const c of candidates) {
      const t = safeText(c);
      if (t) return t;
    }
    return '';
  }

  const perfBucketCards = [
    { key: 'throughput', data: perf.throughput, title: 'Throughput / Execution' },
    { key: 'troubleshooting', data: perf.troubleshooting, title: 'Troubleshooting Effectiveness' },
    { key: 'quality', data: perf.quality, title: 'Quality Protection' },
    { key: 'timeOwnership', data: perf.timeOwnership, title: 'Time Ownership / Downtime' },
    { key: 'reliability', data: perf.reliability, title: 'Reliability / Readiness' }
  ].filter(item => item && item.data);
