      <div class="bucket-summary-card">
        <h3>Event Timeline</h3>
        <p class="bucket-summary-note">
          Open the side pane to read recognition notes, coaching details, themes, and follow-up status.
        </p>

        <div class="summary-action-row">
          <button
            type="button"
            class="btn ghost btn-sm js-open-profile-drawer"
            data-drawer-title="Coaching & Recognition"
            data-drawer-subtitle="Recognition, coaching conversations, and formal event history."
            data-drawer-source="drawer-coaching-content"
          >
            View Event Timeline
          </button>
        </div>
      </div>

      <div id="drawer-coaching-content" class="profile-section-hidden-source">
        <% if (!visibleIncidents || !visibleIncidents.length) { %>
          <div class="drawer-empty">No coaching or recognition events visible for your role.</div>
        <% } else { %>
          <div class="review-drawer-toolbar">
            <div class="review-drawer-toolbar-row">
              <div class="review-drawer-toolbar-group">
                <span class="review-drawer-toolbar-label">Sort</span>
                <button type="button" class="btn ghost btn-small js-coaching-sort" data-sort="date-desc">Newest</button>
                <button type="button" class="btn ghost btn-small js-coaching-sort" data-sort="date-asc">Oldest</button>
              </div>
              <div class="review-drawer-toolbar-group">
                <span class="review-drawer-toolbar-label">Submitted By</span>
                <select class="review-drawer-select js-coaching-submitter-filter">
                  <option value="all">All</option>
                </select>
              </div>
              <div class="review-drawer-toolbar-group">
                <span class="review-drawer-toolbar-label">Type</span>
                <select class="review-drawer-select js-coaching-type-filter">
                  <option value="all">All types</option>
                  <option value="POSITIVE">Recognition</option>
                  <option value="COACHING">Coaching</option>
                  <option value="FORMAL">Formal</option>
                </select>
              </div>
              <div class="review-drawer-count"></div>
            </div>
            <div class="review-drawer-toolbar-actions">
              <button type="button" class="btn ghost btn-small js-coaching-expand-all">Expand All</button>
              <button type="button" class="btn ghost btn-small js-coaching-collapse-all">Collapse All</button>
            </div>
          </div>

          <div class="drawer-stack" id="coaching-drawer-stack">
            <% visibleIncidents.forEach(function(i) {
              const t = (i.type || 'COACHING').toUpperCase();
              const tone = (i.tone || 'NEUTRAL').toUpperCase();
              let typeLabel = 'Coaching';
              let typeClass = 'status-badge status-open';
              if (t === 'POSITIVE') { typeLabel = 'Recognition'; typeClass = 'status-badge status-done'; }
              else if (t === 'FORMAL') { typeLabel = 'Formal'; typeClass = 'status-badge status-danger'; }
              const requiresFollowUp = !!i.requiresFollowUp;
              const followStatus = (i.followUpStatus || (requiresFollowUp ? 'OPEN' : 'NO_ACTION')).toUpperCase();
              const submitterName = (i.Submitter && i.Submitter.name) ? i.Submitter.name : '';
              const incDateStr = i.incidentDate ? String(i.incidentDate).substring(0, 10) : '';
            %>
              <div class="drawer-subcard review-card"
                data-incident-date="<%= incDateStr %>"
                data-submitter-name="<%= submitterName %>"
                data-type="<%= t %>">

                <div class="review-card-header js-review-toggle" role="button" tabindex="0">
                  <div class="review-card-header-left">
                    <span class="review-card-period"><%= incDateStr %></span>
                    <span class="review-card-submitter"><%= submitterName || 'Unknown' %></span>
                    <span class="<%= typeClass %>"><%= typeLabel %></span>
                    <% if (tone === 'RECOGNITION' && t === 'POSITIVE') { %><span class="chip small">Kudos</span><% } %>
                    <% if (tone === 'NEEDS_IMPROVEMENT' && t !== 'POSITIVE') { %><span class="chip small">Coaching Focus</span><% } %>
                  </div>
                  <div class="review-card-header-right">
                    <span class="review-card-overall" style="font-size:0.88rem; max-width:200px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;"><%= i.title %></span>
                    <span class="review-card-chevron">›</span>
                  </div>
                </div>

                <div class="review-card-body">
                  <div class="drawer-list-body" style="margin-bottom:0.65rem;">
                    <%= i.details || 'No additional detail provided.' %>
                  </div>
                  <div class="timeline-chips">
                    <% if (i.impactArea) { %><span class="chip small"><%= i.impactArea %></span><% } %>
                    <% if (i.theme) { %><span class="chip small"><%= i.theme %></span><% } %>
                    <% if (!requiresFollowUp) { %>
                      <span class="chip small">No follow-up</span>
                    <% } else { %>
                      <% if (followStatus === 'CLOSED') { %><span class="status-badge status-done">Closed</span>
                      <% } else if (followStatus === 'IN_PROGRESS') { %><span class="status-badge status-open">In Progress</span>
                      <% } else { %><span class="status-badge status-open">Follow-up Open</span><% } %>
                      <% if (i.followUpDueDate) { %><span class="chip small">Due: <%= i.followUpDueDate %></span><% } %>
                    <% } %>
                  </div>
                </div>
              </div>
            <% }) %>
          </div>
        <% } %>
      </div>
    </section>

    <section id="reviews" class="section-shell dev-shell">
      <div class="section-shell-header">
        <div>
          <h2>Review History</h2>
          <p>
            Keep the profile focused on visible scorecards. Open the side pane for full review breakdowns.
