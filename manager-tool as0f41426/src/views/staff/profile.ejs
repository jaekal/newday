          <button
            type="button"
            class="btn ghost btn-sm js-open-profile-drawer"
            data-drawer-title="Review History"
            data-drawer-subtitle="Visible reviews, bucket detail, comments, and question-level scores."
            data-drawer-source="drawer-reviews-content"
          >
            View Reviews
          </button>
        </div>
      </div>

      <div id="drawer-reviews-content" class="profile-section-hidden-source">
