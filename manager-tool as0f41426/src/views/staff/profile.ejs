        type="button"
        class="snapshot-insight-clickcard js-open-profile-drawer"
        data-drawer-title="Strength Snapshot"
        data-drawer-subtitle="Top current strength surfaced by the profile dashboard."
        data-drawer-source="drawer-snapshot-strength"
      >
        <span class="snapshot-insight-label">Strength</span>
        <strong><%= summaryStrength %></strong>
      </button>

      <button
        type="button"
        class="snapshot-insight-clickcard js-open-profile-drawer"
        data-drawer-title="Area of Focus Snapshot"
        data-drawer-subtitle="Primary area of focus currently surfaced by the dashboard."
        data-drawer-source="drawer-snapshot-focus"
      >
        <span class="snapshot-insight-label">Area of Focus</span>
        <strong><%= summaryFocus %></strong>
      </button>
