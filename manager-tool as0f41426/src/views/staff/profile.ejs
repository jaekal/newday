        <div class="dev-summary-card">
          <span class="dev-summary-label">Latest Review</span>
          <strong><%= latestReview ? latestReview.periodLabel : '—' %></strong>
          <p><%= latestReview ? ('Submitted by ' + latestReview.submitterName) : 'No review history yet' %></p>
        </div>
      </div>

      <% if (ratingHistory && ratingHistory.length >= 2) { %>
        <div class="review-sparkline-wrap">
          <div class="review-sparkline-label">Score trend (last <%= Math.min(ratingHistory.length, 12) %> reviews)</div>
          <canvas id="reviewScoreSparkline" class="review-sparkline-canvas" width="320" height="56"></canvas>
        </div>
        <script id="reviewSparklineData" type="application/json">
          <%- JSON.stringify(ratingHistory.slice(-12).map(function(r) { return { label: r.periodLabel, score: r.overallScore }; })) %>
        </script>
      <% } %>

      <% if (ratingHistory && ratingHistory.length > 0) { %>
        <div class="review-timeline-wrap">
          <div class="review-timeline-label">Review Timeline</div>
          <div class="review-timeline-track">
            <% ratingHistory.slice(-12).forEach(function(r, idx) {
              const score = r.overallScore;
              const dotClass = score == null ? 'rt-dot-neutral'
                : score >= 4 ? 'rt-dot-high'
                : score >= 3 ? 'rt-dot-mid'
                : 'rt-dot-low';
            %>
              <div class="rt-stop" title="<%= r.periodLabel %> — <%= r.submitterName %>: <%= score != null ? score.toFixed(2) : 'N/A' %>">
                <div class="rt-dot <%= dotClass %>"></div>
                <div class="rt-stop-label"><%= r.periodLabel ? r.periodLabel.slice(5) : '' %></div>
                <% if (score != null) { %><div class="rt-score"><%= score.toFixed(1) %></div><% } %>
              </div>
            <% }); %>
          </div>
        </div>
      <% } %>

