      <% if (canSeeRisk) { %>
      <button
        type="button"
        class="snapshot-insight-clickcard js-open-profile-drawer"
        data-drawer-title="Risk Snapshot"
        data-drawer-subtitle="Current flagged risk pulled from the staff dashboard."
        data-drawer-source="drawer-snapshot-risk"
      >
        <span class="snapshot-insight-label">Risk</span>
        <strong><%= summaryRisk %></strong>
