            <a href="/incidents?staffId=<%= staff.id %>" class="btn ghost btn-sm">View All Events</a>
          <% } %>

          <% if (canCreateIncident) { %>
            <a href="/incidents/new?staffId=<%= staff.id %>" class="btn ghost btn-sm">+ New Event</a>
          <% } %>
        </div>
      </div>

      <div class="dev-summary-grid">
