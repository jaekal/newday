<%- include('../layout') %>

<%
  const _filters = (typeof filters !== 'undefined' && filters) ? filters : {};
  const _staffOptions = (typeof staffOptions !== 'undefined' && staffOptions) ? staffOptions : [];
  const _viewerRole = (typeof viewerRole !== 'undefined' && viewerRole) ? viewerRole : '';
  const _filterSummary = (typeof filterSummary !== 'undefined' && filterSummary) ? filterSummary : 'All records';

  const _stats = (typeof stats !== 'undefined' && stats) ? stats : {};
  const statsSafe = {
    totalEvents:          _stats.totalEvents          ?? 0,
    positiveCount:        _stats.positiveCount        ?? 0,
    coachingCount:        _stats.coachingCount        ?? 0,
    formalCount:          _stats.formalCount          ?? 0,
    infoCount:            _stats.infoCount            ?? 0,
    recognitionCount:     _stats.recognitionCount     ?? 0,
    needsImprovementCount:_stats.needsImprovementCount?? 0,
    neutralCount:         _stats.neutralCount         ?? 0,
    openFollowUps:        _stats.openFollowUps        ?? 0,
    overdueFollowUps:     _stats.overdueFollowUps     ?? 0,
    lowSeverityCount:     _stats.lowSeverityCount     ?? 0,
    mediumSeverityCount:  _stats.mediumSeverityCount  ?? 0,
    highSeverityCount:    _stats.highSeverityCount    ?? 0,
  };

  const TYPE_OPTIONS     = ['POSITIVE','COACHING','FORMAL','INFO'];
  const TONE_OPTIONS     = ['RECOGNITION','ACHIEVEMENT','ENCOURAGEMENT','PROFESSIONAL_COMMENDATION','NEEDS_IMPROVEMENT','GUIDANCE','REDIRECTION','ACCOUNTABILITY_REMINDER','PERFORMANCE_CONCERN','POLICY_VIOLATION','CONDUCT_CONCERN','ESCALATED_DOCUMENTATION','NEUTRAL_RECORD','ATTENDANCE_NOTE','OPERATIONAL_NOTE','ADMINISTRATIVE_UPDATE'];
  const IMPACT_OPTIONS   = ['SAFETY','QUALITY','DELIVERY','PEOPLE','COST','COMPLIANCE','PROCESS','OTHER'];
  const THEME_OPTIONS    = ['OWNERSHIP','TEAMWORK','COMMUNICATION','INITIATIVE','ENGAGEMENT','ATTENDANCE','TRAINING','CONDUCT','PROCESS_IMPROVEMENT','OTHER'];
  const SEVERITY_OPTIONS = ['LOW','MEDIUM','HIGH'];

  const _rawIncidents = (typeof incidents !== 'undefined' && incidents) ? incidents : [];
  const incidentVMs = _rawIncidents.map((x) => {
    if (x && typeof x === 'object' && x.inc) return x;
    return { inc: x, followUpHealth: null };
  });

  /* ── helpers ── */
  function buildQS(obj) {
    try {
      return new URLSearchParams(Object.fromEntries(Object.entries(obj||{}).filter(([_,v])=>v!==undefined&&v!==null))).toString();
    } catch(e) {
      return Object.keys(obj||{}).filter(k=>obj[k]!==undefined&&obj[k]!==null).map(k=>encodeURIComponent(k)+'='+encodeURIComponent(String(obj[k]))).join('&');
    }
  }
  function isoToday() { try { return new Date().toISOString().slice(0,10); } catch(e) { return ''; } }
  function safeDateOnly(v) {
    if (!v) return '';
    try { return typeof v==='string'?v.slice(0,10):new Date(v).toISOString().slice(0,10); } catch(e) { return ''; }
  }
  function safeCreatedAt(v) {
    if (!v) return '';
    try { return typeof v?.toISOString==='function'?v.toISOString().slice(0,10):new Date(v).toISOString().slice(0,10); } catch(e) { return ''; }
  }
  function safeDateObj(v) {
    try { if(!v)return null; const d=new Date(v); return isNaN(d.getTime())?null:d; } catch(e){return null;}
  }
  function normalized(v) { return String(v||'').trim().toUpperCase(); }
  function humanize(v) { return String(v||'').replace(/_/g,' ').toLowerCase().replace(/^\w/,c=>c.toUpperCase()); }

  function monthKey(inc) {
    const d = safeDateObj(inc?.createdAt || inc?.incidentDate);
    if (!d) return 'unknown';
    return d.getFullYear()+'-'+String(d.getMonth()+1).padStart(2,'0');
  }
  function monthLabel(key) {
    if (!key || key==='unknown') return 'Unknown Period';
    try { const [y,m]=key.split('-').map(Number); return new Date(y,m-1,1).toLocaleString('en-US',{month:'long',year:'numeric'}); } catch(e){return key;}
  }

  function typePill(type) {
    const t = normalized(type);
    if (t==='POSITIVE') return 'ldg-type-positive';
    if (t==='COACHING') return 'ldg-type-coaching';
    if (t==='FORMAL')   return 'ldg-type-formal';
    return 'ldg-type-info';
  }
  function severityCls(sev) {
    const s = normalized(sev);
    if (s==='HIGH')   return 'ldg-sev-high';
    if (s==='MEDIUM') return 'ldg-sev-medium';
    return 'ldg-sev-low';
  }
  function healthCls(level) {
    if (level==='ok')  return 'ldg-health-ok';
    if (level==='bad') return 'ldg-health-bad';
    if (level==='warn')return 'ldg-health-warn';
    return '';
  }

  /* group by month */
  const groupMap = {};
  incidentVMs.forEach(vm => {
    const k = monthKey(vm.inc||{});
    if (!groupMap[k]) groupMap[k]=[];
    groupMap[k].push(vm);
  });
  const monthGroups = Object.keys(groupMap).sort((a,b)=>{
    if(a==='unknown')return 1; if(b==='unknown')return -1; return a<b?1:-1;
  }).map((key,i)=>({ key, label: monthLabel(key), items: groupMap[key], open: i===0 }));

  /* active filter count */
  const _activeFilterKeys = ['q','staffId','type','tone','impactArea','theme','severity','fromDate','toDate','followUp','mine'];
  const _activeCount = _activeFilterKeys.filter(k => _filters[k] && String(_filters[k]).trim()).length;

  const currentQS = buildQS(_filters);
%>

<style>
/* ═══════════════════════════════════════════════════════
   ACTIVITY LEDGER — page-scoped styles
   ═══════════════════════════════════════════════════════ */

/* ── Layout shell ───────────────────────────────────── */
.ldg-shell {
  display: flex;
  flex-direction: column;
  gap: 1.25rem;
}

/* ── Page header ────────────────────────────────────── */
.ldg-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 1rem;
  flex-wrap: wrap;
}
.ldg-header-meta h2 {
  margin: 0 0 .2rem;
  font-size: 1.35rem;
  font-weight: 700;
  color: var(--text-primary);
}
.ldg-header-meta p {
  margin: 0;
  font-size: .82rem;
  color: var(--text-muted);
}
.ldg-header-actions {
  display: flex;
  gap: .5rem;
  align-items: center;
  flex-shrink: 0;
  flex-wrap: wrap;
}

/* ── KPI strip ──────────────────────────────────────── */
.ldg-kpi-strip {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(148px, 1fr));
  gap: .7rem;
}
.ldg-kpi {
  background: var(--bg-surface);
  border: 1px solid var(--border-default);
  border-radius: var(--radius-lg);
  padding: .8rem 1rem;
  display: flex;
  flex-direction: column;
  gap: .2rem;
  position: relative;
  overflow: hidden;
}
.ldg-kpi::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 3px;
  background: var(--ldg-accent, var(--brand-primary));
}
.ldg-kpi-label {
  font-size: .7rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: .08em;
  color: var(--text-muted);
}
.ldg-kpi-value {
  font-size: 1.7rem;
  font-weight: 800;
  line-height: 1;
  color: var(--text-primary);
}
.ldg-kpi-sub {
  font-size: .72rem;
  color: var(--text-muted);
  margin-top: .15rem;
}
.ldg-kpi--positive { --ldg-accent: #22c55e; }
.ldg-kpi--coaching  { --ldg-accent: #3b82f6; }
.ldg-kpi--formal    { --ldg-accent: #ef4444; }
.ldg-kpi--followup  { --ldg-accent: #f59e0b; }
.ldg-kpi--overdue   { --ldg-accent: #ef4444; }

/* ── Toolbar / filter bar ───────────────────────────── */
.ldg-toolbar {
  background: var(--bg-surface);
  border: 1px solid var(--border-default);
  border-radius: var(--radius-lg);
  padding: .65rem .9rem;
  display: flex;
  gap: .6rem;
  align-items: center;
  flex-wrap: wrap;
  position: sticky;
  top: 0;
  z-index: 50;
  box-shadow: var(--shadow-sm);
  backdrop-filter: blur(12px);
}
.ldg-search-wrap {
  position: relative;
  flex: 1;
  min-width: 200px;
  max-width: 340px;
}
.ldg-search-wrap svg {
  position: absolute;
  left: .65rem;
  top: 50%;
  transform: translateY(-50%);
  color: var(--text-muted);
  pointer-events: none;
}
.ldg-search {
  width: 100%;
  background: var(--bg-elevated);
  border: 1px solid var(--border-default);
  border-radius: var(--radius-pill);
  padding: .38rem .75rem .38rem 2.1rem;
  font-size: .83rem;
  color: var(--text-primary);
  font-family: inherit;
}
.ldg-search:focus {
  outline: none;
  border-color: var(--brand-primary);
  box-shadow: 0 0 0 3px var(--brand-primary-muted);
}
.ldg-search::placeholder { color: var(--text-muted); }

.ldg-quick-filters {
  display: flex;
  gap: .35rem;
  flex-wrap: wrap;
  align-items: center;
}
.ldg-qf {
  display: inline-flex;
  align-items: center;
  gap: .3rem;
  padding: .3rem .65rem;
  border-radius: var(--radius-pill);
  border: 1px solid var(--border-default);
  background: var(--bg-elevated);
  color: var(--text-secondary);
  font-size: .78rem;
  font-family: inherit;
  cursor: pointer;
  text-decoration: none;
  white-space: nowrap;
  transition: background .14s, border-color .14s, color .14s;
}
.ldg-qf:hover { background: var(--state-hover); border-color: var(--border-strong); color: var(--text-primary); }
.ldg-qf.active {
  background: var(--brand-primary-muted);
  border-color: var(--brand-primary);
  color: var(--brand-primary);
  font-weight: 600;
}
.ldg-qf-dot {
  width: 6px; height: 6px;
  border-radius: 50%;
  display: inline-block;
  background: currentColor;
}

.ldg-toolbar-divider {
  width: 1px; height: 22px;
  background: var(--border-default);
  flex-shrink: 0;
}
.ldg-filter-btn {
  display: inline-flex;
  align-items: center;
  gap: .35rem;
  padding: .3rem .65rem;
  border-radius: var(--radius-pill);
  border: 1px solid var(--border-default);
  background: transparent;
  color: var(--text-secondary);
  font-size: .78rem;
  font-family: inherit;
  cursor: pointer;
  white-space: nowrap;
}
.ldg-filter-btn:hover { border-color: var(--border-strong); color: var(--text-primary); }
.ldg-filter-btn.has-filters {
  border-color: var(--brand-primary);
  color: var(--brand-primary);
  background: var(--brand-primary-muted);
}
.ldg-filter-badge {
  background: var(--brand-primary);
  color: #fff;
  font-size: .62rem;
  font-weight: 700;
  border-radius: 99px;
  padding: 0 5px;
  min-width: 16px;
  text-align: center;
}

/* ── Advanced filter drawer ─────────────────────────── */
.ldg-filter-drawer {
  display: none;
  background: var(--bg-surface);
  border: 1px solid var(--border-default);
  border-radius: var(--radius-lg);
  padding: 1rem;
  animation: slideDown .18s ease;
}
@keyframes slideDown { from { opacity:0; transform:translateY(-6px); } to { opacity:1; transform:none; } }
.ldg-filter-drawer.open { display: block; }
.ldg-filter-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
  gap: .65rem;
  margin-bottom: .75rem;
}
.ldg-filter-field label {
  display: block;
  font-size: .7rem;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: .07em;
  color: var(--text-muted);
  margin-bottom: .3rem;
}
.ldg-filter-field select,
.ldg-filter-field input {
  width: 100%;
  background: var(--bg-elevated);
  border: 1px solid var(--border-default);
  border-radius: var(--radius-md);
  padding: .38rem .6rem;
  font-size: .82rem;
  color: var(--text-primary);
  font-family: inherit;
}
.ldg-filter-field select:focus,
.ldg-filter-field input:focus {
  outline: none;
  border-color: var(--brand-primary);
  box-shadow: 0 0 0 2px var(--brand-primary-muted);
}
.ldg-filter-actions {
  display: flex;
  gap: .5rem;
  align-items: center;
  padding-top: .65rem;
  border-top: 1px solid var(--border-default);
}
.ldg-filter-summary {
  font-size: .75rem;
  color: var(--text-muted);
  flex: 1;
  font-style: italic;
}

/* ── Month group ────────────────────────────────────── */
.ldg-month-group {
  border: 1px solid var(--border-default);
  border-radius: var(--radius-lg);
  overflow: hidden;
}
.ldg-month-toggle {
  width: 100%;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: .8rem 1rem;
  background: var(--bg-elevated);
  border: none;
  color: var(--text-primary);
  font-family: inherit;
  cursor: pointer;
  gap: 1rem;
  text-align: left;
  transition: background .14s;
}
.ldg-month-toggle:hover { background: var(--bg-overlay); }
.ldg-month-toggle-left {
  display: flex;
  align-items: center;
  gap: .75rem;
}
.ldg-month-label {
  font-weight: 700;
  font-size: .95rem;
}
.ldg-month-count {
  font-size: .75rem;
  color: var(--text-muted);
  background: var(--bg-overlay);
  border: 1px solid var(--border-default);
  border-radius: var(--radius-pill);
  padding: .1rem .55rem;
}
.ldg-month-caret {
  color: var(--text-muted);
  transition: transform .2s ease;
  flex-shrink: 0;
}
.ldg-month-group.open .ldg-month-caret { transform: rotate(180deg); }
.ldg-month-body {
  display: none;
  border-top: 1px solid var(--border-default);
}
.ldg-month-group.open .ldg-month-body { display: block; }

/* ── Entry cards ────────────────────────────────────── */
.ldg-entries {
  display: flex;
  flex-direction: column;
}
.ldg-entry {
  display: grid;
  grid-template-columns: 4px 88px 1fr auto;
  gap: 0 .85rem;
  align-items: start;
  padding: .85rem 1rem;
  border-bottom: 1px solid var(--border-default);
  transition: background .12s;
  position: relative;
  cursor: pointer;
}
.ldg-entry:last-child { border-bottom: none; }
.ldg-entry:hover { background: var(--state-hover); }
.ldg-entry.expanded { background: var(--bg-elevated); }
.ldg-entry-accent {
  position: absolute;
  left: 0; top: 0; bottom: 0;
  width: 4px;
  border-radius: 0;
}
.ldg-entry-accent.positive { background: #22c55e; }
.ldg-entry-accent.coaching  { background: #3b82f6; }
.ldg-entry-accent.formal    { background: #ef4444; }
.ldg-entry-accent.info      { background: #94a3b8; }

.ldg-entry-date {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: .15rem;
  flex-shrink: 0;
}
.ldg-entry-day {
  font-size: 1.5rem;
  font-weight: 800;
  line-height: 1;
  color: var(--text-primary);
}
.ldg-entry-month {
  font-size: .68rem;
  font-weight: 600;
