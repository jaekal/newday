}
/* Type */
.ldg-type-positive { background: rgba(34,197,94,.12);  border-color: rgba(34,197,94,.28);  color: #4ade80; }
.ldg-type-coaching  { background: rgba(59,130,246,.12); border-color: rgba(59,130,246,.28); color: #60a5fa; }
.ldg-type-formal    { background: rgba(239,68,68,.12);  border-color: rgba(239,68,68,.28);  color: #f87171; }
.ldg-type-info      { background: rgba(148,163,184,.10);border-color: rgba(148,163,184,.22);color: #94a3b8; }
/* Severity */
