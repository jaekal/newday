}
.ldg-expand-meta {
  display: flex;
  flex-direction: column;
  gap: .5rem;
}
.ldg-expand-row {
  display: flex;
  justify-content: space-between;
  font-size: .8rem;
  padding: .3rem 0;
  border-bottom: 1px solid var(--border-default);
  gap: .5rem;
}
.ldg-expand-row:last-child { border-bottom: none; }
.ldg-expand-row-label { color: var(--text-muted); flex-shrink: 0; }
.ldg-expand-row-val   { color: var(--text-primary); font-weight: 500; text-align: right; }
.ldg-expand-actions {
  display: flex;
  gap: .4rem;
  flex-wrap: wrap;
  padding-top: .6rem;
  border-top: 1px solid var(--border-default);
  margin-top: .2rem;
}

/* ── Empty state ────────────────────────────────────── */
.ldg-empty {
  text-align: center;
  padding: 3.5rem 1rem;
  color: var(--text-muted);
}
.ldg-empty svg { opacity: .3; margin-bottom: .75rem; display: block; margin-inline: auto; }
.ldg-empty h3 { margin: 0 0 .4rem; font-size: 1rem; color: var(--text-secondary); }
.ldg-empty p  { margin: 0; font-size: .85rem; }

/* ── Canvas theme overrides ─────────────────────────── */
[data-theme="canvas"] .ldg-type-positive { color: #15803d; }
[data-theme="canvas"] .ldg-type-coaching  { color: #1d4ed8; }
[data-theme="canvas"] .ldg-type-formal    { color: #b91c1c; }
[data-theme="canvas"] .ldg-type-info      { color: #475569; }
[data-theme="canvas"] .ldg-sev-low    { color: #15803d; }
[data-theme="canvas"] .ldg-sev-medium { color: #92400e; }
[data-theme="canvas"] .ldg-sev-high   { color: #b91c1c; }
[data-theme="canvas"] .ldg-health-ok   { color: #15803d; }
[data-theme="canvas"] .ldg-health-warn { color: #92400e; }
[data-theme="canvas"] .ldg-health-bad  { color: #b91c1c; }

/* ── Responsive ─────────────────────────────────────── */
@media (max-width: 700px) {
  .ldg-entry { grid-template-columns: 4px 64px 1fr; }
  .ldg-entry-right { display: none; }
  .ldg-expand-inner { grid-template-columns: 1fr; padding-left: 1rem; }
  .ldg-kpi-strip { grid-template-columns: repeat(2, 1fr); }
  .ldg-filter-grid { grid-template-columns: 1fr 1fr; }
  .ldg-entry-accent { position: static; width: 100%; height: 4px; }
}
</style>

<div class="ldg-shell">

  <!-- ══════════════════════════════════════════════════
       PAGE HEADER
  ═══════════════════════════════════════════════════ -->
  <div class="ldg-header">
    <div class="ldg-header-meta">
      <h2>Activity Ledger</h2>
      <p>Recognition, coaching events, and formal incidents across your scope</p>
    </div>
    <div class="ldg-header-actions">
      <% if (['ADMIN','SENIOR_MANAGER','MANAGER','SUPERVISOR','LEAD'].includes(_viewerRole)) { %>
        <a href="/incidents/new?returnTo=/incidents" class="btn primary">
          <svg width="13" height="13" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M8 3v10M3 8h10" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
          Log Event
        </a>
      <% } %>
    </div>
  </div>

  <!-- ══════════════════════════════════════════════════
       KPI STRIP
  ═══════════════════════════════════════════════════ -->
  <div class="ldg-kpi-strip">
    <div class="ldg-kpi">
      <span class="ldg-kpi-label">Total Events</span>
      <span class="ldg-kpi-value"><%= statsSafe.totalEvents %></span>
      <span class="ldg-kpi-sub">in current view</span>
    </div>
    <div class="ldg-kpi ldg-kpi--positive">
      <span class="ldg-kpi-label">Positive</span>
      <span class="ldg-kpi-value"><%= statsSafe.positiveCount %></span>
      <span class="ldg-kpi-sub">Recognition &amp; achievement</span>
    </div>
    <div class="ldg-kpi ldg-kpi--coaching">
      <span class="ldg-kpi-label">Coaching</span>
      <span class="ldg-kpi-value"><%= statsSafe.coachingCount %></span>
      <span class="ldg-kpi-sub">Guidance &amp; development</span>
    </div>
    <div class="ldg-kpi ldg-kpi--formal">
      <span class="ldg-kpi-label">Formal</span>
      <span class="ldg-kpi-value"><%= statsSafe.formalCount %></span>
      <span class="ldg-kpi-sub">Documented incidents</span>
    </div>
    <div class="ldg-kpi ldg-kpi--followup">
      <span class="ldg-kpi-label">Open Follow-ups</span>
      <span class="ldg-kpi-value"><%= statsSafe.openFollowUps %></span>
      <span class="ldg-kpi-sub">Awaiting resolution</span>
    </div>
    <div class="ldg-kpi ldg-kpi--overdue">
      <span class="ldg-kpi-label">Overdue</span>
      <span class="ldg-kpi-value"><%= statsSafe.overdueFollowUps %></span>
      <span class="ldg-kpi-sub">Past due date</span>
    </div>
  </div>

  <!-- ══════════════════════════════════════════════════
       STICKY TOOLBAR
  ═══════════════════════════════════════════════════ -->
  <form method="GET" action="/incidents" id="ldg-filter-form">
    <div class="ldg-toolbar">

      <%/* Live search */%>
      <div class="ldg-search-wrap">
        <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <circle cx="6.5" cy="6.5" r="4.5" stroke="currentColor" stroke-width="1.5"/>
          <path d="M11 11l3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
        <input class="ldg-search" type="text" name="q" value="<%= _filters.q || '' %>"
               placeholder="Search title, details, staff…" id="ldg-search-input" autocomplete="off" />
      </div>

      <div class="ldg-toolbar-divider"></div>

      <%/* Quick-filter chips */%>
      <div class="ldg-quick-filters">
        <a class="ldg-qf <%= _filters.followUp === 'open' ? 'active' : '' %>"
           href="/incidents?<%= buildQS({..._filters, followUp: _filters.followUp==='open'?'':'open'}) %>">
          <span class="ldg-qf-dot"></span>Open Follow-ups
        </a>
        <a class="ldg-qf <%= _filters.followUp === 'overdue' ? 'active' : '' %>"
           href="/incidents?<%= buildQS({..._filters, followUp: _filters.followUp==='overdue'?'':'overdue'}) %>">
          <span class="ldg-qf-dot"></span>Overdue
        </a>
        <a class="ldg-qf <%= _filters.mine === '1' ? 'active' : '' %>"
           href="/incidents?<%= buildQS({..._filters, mine: _filters.mine==='1'?'':'1'}) %>">Mine only</a>
        <a class="ldg-qf" href="/incidents?<%= buildQS({..._filters, fromDate: isoToday(), toDate: '', followUp: ''}) %>">Today</a>
      </div>

      <div class="ldg-toolbar-divider"></div>

      <%/* Filter toggle */%>
      <button type="button" class="ldg-filter-btn <%= _activeCount > 0 ? 'has-filters' : '' %>" id="ldg-filter-toggle">
        <svg width="13" height="13" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M2 4h12M4 8h8M6 12h4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
        Filters
        <% if (_activeCount > 0) { %><span class="ldg-filter-badge"><%= _activeCount %></span><% } %>
      </button>

      <% if (_activeCount > 0) { %>
        <a href="/incidents" class="ldg-qf" style="color:var(--text-muted);">
          <svg width="11" height="11" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M4 4l8 8M12 4l-8 8" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
          Clear
        </a>
      <% } %>
    </div>

    <!-- Advanced filter drawer -->
    <div class="ldg-filter-drawer <%= _activeCount > 0 ? 'open' : '' %>" id="ldg-filter-drawer">
      <div class="ldg-filter-grid">

        <div class="ldg-filter-field">
          <label>Staff</label>
          <select name="staffId">
            <option value="">All staff</option>
            <% _staffOptions.forEach(function(s) { %>
              <option value="<%= s.id %>" <%= String(_filters.staffId||'')===String(s.id)?'selected':'' %>><%= s.name %></option>
            <% }) %>
          </select>
        </div>

        <div class="ldg-filter-field">
          <label>Type</label>
          <select name="type">
            <option value="">All types</option>
            <% TYPE_OPTIONS.forEach(function(t) { %>
              <option value="<%= t %>" <%= normalized(_filters.type)===t?'selected':'' %>><%= humanize(t) %></option>
            <% }) %>
          </select>
        </div>

        <div class="ldg-filter-field">
          <label>Tone</label>
          <select name="tone">
            <option value="">All tones</option>
            <% TONE_OPTIONS.forEach(function(t) { %>
              <option value="<%= t %>" <%= normalized(_filters.tone)===t?'selected':'' %>><%= humanize(t) %></option>
            <% }) %>
          </select>
        </div>

        <div class="ldg-filter-field">
          <label>Impact Area</label>
          <select name="impactArea">
            <option value="">All areas</option>
            <% IMPACT_OPTIONS.forEach(function(a) { %>
              <option value="<%= a %>" <%= normalized(_filters.impactArea)===a?'selected':'' %>><%= humanize(a) %></option>
            <% }) %>
          </select>
        </div>

        <div class="ldg-filter-field">
          <label>Theme</label>
          <select name="theme">
            <option value="">All themes</option>
            <% THEME_OPTIONS.forEach(function(t) { %>
              <option value="<%= t %>" <%= normalized(_filters.theme)===t?'selected':'' %>><%= humanize(t) %></option>
            <% }) %>
          </select>
        </div>

        <div class="ldg-filter-field">
          <label>Severity</label>
          <select name="severity">
            <option value="">All severity</option>
            <% SEVERITY_OPTIONS.forEach(function(s) { %>
              <option value="<%= s %>" <%= normalized(_filters.severity)===s?'selected':'' %>><%= humanize(s) %></option>
            <% }) %>
          </select>
        </div>

        <div class="ldg-filter-field">
          <label>Follow-up Status</label>
          <select name="followUp">
            <option value="">All</option>
            <option value="open"    <%= _filters.followUp==='open'?'selected':'' %>>Open</option>
            <option value="overdue" <%= _filters.followUp==='overdue'?'selected':'' %>>Overdue</option>
          </select>
        </div>

        <div class="ldg-filter-field">
          <label>From Date</label>
          <input type="date" name="fromDate" value="<%= _filters.fromDate||'' %>" />
        </div>

        <div class="ldg-filter-field">
          <label>To Date</label>
          <input type="date" name="toDate" value="<%= _filters.toDate||'' %>" />
        </div>

        <div class="ldg-filter-field">
          <label>Ownership</label>
          <select name="mine">
            <option value="">All records</option>
            <option value="1" <%= _filters.mine==='1'?'selected':'' %>>Mine only</option>
          </select>
        </div>
      </div>

      <div class="ldg-filter-actions">
        <span class="ldg-filter-summary"><%= _filterSummary %></span>
        <a href="/incidents" class="btn ghost" style="font-size:.8rem; padding:.3rem .7rem;">Reset all</a>
        <button type="submit" class="btn primary" style="font-size:.8rem; padding:.3rem .8rem;">Apply filters</button>
      </div>
    </div>
  </form>

  <!-- ══════════════════════════════════════════════════
       LEDGER — grouped by month
  ═══════════════════════════════════════════════════ -->
  <div>
    <% if (!incidentVMs.length) { %>
      <div class="ldg-empty">
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" aria-hidden="true">
          <rect x="3" y="3" width="18" height="18" rx="2"/>
          <path d="M8 12h8M8 8h8M8 16h4"/>
        </svg>
        <h3>No events found</h3>
        <p>
          <% if (_activeCount > 0) { %>
            No records match your current filters. <a href="/incidents">Clear filters</a> to see all records.
          <% } else { %>
            No activity has been logged yet. <a href="/incidents/new?returnTo=/incidents">Log the first event.</a>
          <% } %>
        </p>
      </div>

    <% } else { %>

      <% monthGroups.forEach(function(group) { %>
        <div class="ldg-month-group <%= group.open ? 'open' : '' %>" data-month-group style="margin-bottom:.75rem;">

          <button class="ldg-month-toggle" type="button" data-month-toggle
                  aria-expanded="<%= group.open ? 'true' : 'false' %>">
            <div class="ldg-month-toggle-left">
              <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <rect x="2" y="2" width="12" height="12" rx="2" stroke="currentColor" stroke-width="1.4"/>
                <path d="M5 6h6M5 9h4" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>
              </svg>
              <span class="ldg-month-label"><%= group.label %></span>
              <span class="ldg-month-count"><%= group.items.length %> event<%= group.items.length===1?'':'s' %></span>
            </div>
            <svg class="ldg-month-caret" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M4 6l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>

          <div class="ldg-month-body" data-month-body>
            <div class="ldg-entries">
              <% group.items.forEach(function(vm) {
                   const inc    = vm.inc || {};
                   const health = vm.followUpHealth || { label: '—', level: 'none' };
                   const tCls   = typePill(inc.type);
                   const sCls   = severityCls(inc.severity);
                   const hCls   = healthCls(health.level);

                   /* date parts */
                   const incDate = safeDateObj(inc.incidentDate || inc.createdAt);
                   const dayNum  = incDate ? incDate.getDate() : '—';
                   const monStr  = incDate ? incDate.toLocaleString('en-US',{month:'short'}) : '';
                   const yrStr   = incDate ? incDate.getFullYear() : '';

                   const accentCls = normalized(inc.type)==='POSITIVE' ? 'positive'
                                   : normalized(inc.type)==='COACHING'  ? 'coaching'
                                   : normalized(inc.type)==='FORMAL'    ? 'formal' : 'info';
              %>
              <%/* Entry row */%>
              <div class="ldg-entry" data-entry-id="<%= inc.id %>">
                <div class="ldg-entry-accent <%= accentCls %>"></div>

                <div class="ldg-entry-date">
                  <span class="ldg-entry-day"><%= dayNum %></span>
                  <span class="ldg-entry-month"><%= monStr %></span>
                  <span class="ldg-entry-year"><%= yrStr %></span>
                </div>

                <div class="ldg-entry-main">
                  <div class="ldg-entry-title"><%= inc.title || 'Untitled event' %></div>
                  <div class="ldg-entry-staff">
                    <% if (inc.Staff) { %>
                      <a href="/staff/<%= inc.Staff.id %>" onclick="event.stopPropagation()"><%= inc.Staff.name %></a>
                    <% } else { %>
                      <span>No staff linked</span>
                    <% } %>
                  </div>
                  <div class="ldg-entry-tags">
                    <span class="ldg-tag <%= tCls %>"><%= humanize(inc.type) %></span>
                    <% if (inc.severity && normalized(inc.severity) !== 'LOW') { %>
                      <span class="ldg-tag <%= sCls %>"><%= humanize(inc.severity) %></span>
                    <% } %>
                    <% if (inc.tone) { %><span class="ldg-tag ldg-tone"><%= humanize(inc.tone) %></span><% } %>
                    <% if (inc.impactArea) { %><span class="ldg-tag ldg-tone"><%= humanize(inc.impactArea) %></span><% } %>
                    <% if (inc.requiresFollowUp) { %>
                      <span class="ldg-tag <%= hCls %>">
                        <svg width="9" height="9" viewBox="0 0 12 12" fill="none" aria-hidden="true"><circle cx="6" cy="6" r="5" stroke="currentColor" stroke-width="1.4"/><path d="M6 4v3M6 8.5v.5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg>
                        <%= health.label %>
                      </span>
                    <% } %>
                  </div>
                </div>

                <div class="ldg-entry-right">
                  <div class="ldg-entry-submitter">
                    <% if (inc.Submitter) { %>By <%= inc.Submitter.name.split(' ')[0] %><% } %>
                    <br/><span style="font-size:.65rem;">Logged <%= safeCreatedAt(inc.createdAt) %></span>
                  </div>
                  <div style="display:flex; gap:.3rem;" onclick="event.stopPropagation()">
                    <a class="btn ghost" style="font-size:.72rem; padding:.25rem .55rem;"
                       href="/incidents/<%= inc.id %>/edit?returnTo=/incidents<%= currentQS?'?'+currentQS:'' %>">Edit</a>
                    <% if (['ADMIN','SENIOR_MANAGER','MANAGER','SUPERVISOR'].includes(_viewerRole)) { %>
                      <form method="POST" action="/incidents/<%= inc.id %>/delete" style="display:inline;"
                            onsubmit="return confirm('Permanently delete this event?');">
                        <input type="hidden" name="returnTo" value="/incidents<%= currentQS?'?'+currentQS:'' %>" />
                        <button type="submit" class="btn danger" style="font-size:.72rem; padding:.25rem .55rem;">Del</button>
                      </form>
                    <% } %>
                  </div>
                </div>
              </div>

              <%/* Expand panel */%>
              <div class="ldg-expand" id="ldg-expand-<%= inc.id %>">
                <div class="ldg-expand-inner">
                  <div>
                    <p class="ldg-expand-label">Details</p>
                    <% if (String(inc.details||'').trim()) { %>
                      <pre class="ldg-expand-pre"><%= inc.details %></pre>
                    <% } else { %>
                      <p style="font-size:.82rem; color:var(--text-muted); margin:0;">No details recorded.</p>
                    <% } %>

                    <% if (String(inc.followUpOutcome||'').trim()) { %>
                      <p class="ldg-expand-label" style="margin-top:.85rem;">Follow-up Notes</p>
                      <pre class="ldg-expand-pre"><%= inc.followUpOutcome %></pre>
                    <% } %>

                    <div class="ldg-expand-actions">
                      <a class="btn ghost" style="font-size:.8rem;"
                         href="/incidents/<%= inc.id %>/edit?returnTo=/incidents<%= currentQS?'?'+currentQS:'' %>">Open full edit</a>
                      <% if (inc.Staff && inc.Staff.id) { %>
                        <a class="btn ghost" style="font-size:.8rem;" href="/staff/<%= inc.Staff.id %>">View staff profile</a>
                      <% } %>
                    </div>
                  </div>

                  <div class="ldg-expand-meta">
                    <p class="ldg-expand-label">Record Details</p>
                    <div class="ldg-expand-row">
                      <span class="ldg-expand-row-label">Type</span>
                      <span class="ldg-expand-row-val ldg-tag <%= tCls %>"><%= humanize(inc.type) %></span>
                    </div>
                    <div class="ldg-expand-row">
                      <span class="ldg-expand-row-label">Severity</span>
                      <span class="ldg-expand-row-val ldg-tag <%= sCls %>"><%= humanize(inc.severity||'Low') %></span>
                    </div>
                    <div class="ldg-expand-row">
                      <span class="ldg-expand-row-label">Tone</span>
                      <span class="ldg-expand-row-val"><%= humanize(inc.tone||'—') %></span>
                    </div>
                    <div class="ldg-expand-row">
                      <span class="ldg-expand-row-label">Impact Area</span>
                      <span class="ldg-expand-row-val"><%= humanize(inc.impactArea||'—') %></span>
                    </div>
                    <div class="ldg-expand-row">
                      <span class="ldg-expand-row-label">Theme</span>
                      <span class="ldg-expand-row-val"><%= humanize(inc.theme||'—') %></span>
                    </div>
                    <div class="ldg-expand-row">
                      <span class="ldg-expand-row-label">Follow-up Required</span>
                      <span class="ldg-expand-row-val"><%= inc.requiresFollowUp ? 'Yes' : 'No' %></span>
                    </div>
                    <% if (inc.requiresFollowUp) { %>
                    <div class="ldg-expand-row">
                      <span class="ldg-expand-row-label">Due Date</span>
                      <span class="ldg-expand-row-val"><%= safeDateOnly(inc.followUpDueDate)||'—' %></span>
                    </div>
                    <div class="ldg-expand-row">
                      <span class="ldg-expand-row-label">Status</span>
                      <span class="ldg-expand-row-val ldg-tag <%= hCls %>"><%= health.label %></span>
                    </div>
                    <% } %>
                    <div class="ldg-expand-row">
                      <span class="ldg-expand-row-label">Event Date</span>
                      <span class="ldg-expand-row-val"><%= safeDateOnly(inc.incidentDate)||'—' %></span>
                    </div>
                    <div class="ldg-expand-row">
                      <span class="ldg-expand-row-label">Logged</span>
                      <span class="ldg-expand-row-val"><%= safeCreatedAt(inc.createdAt) %></span>
                    </div>
                  </div>
                </div>
              </div>
              <% }); %>
            </div>
          </div>
        </div>
      <% }); %>

    <% } %>
  </div>

</div>

<script>
(function() {
  /* ── Month group collapse/expand ── */
  document.querySelectorAll('[data-month-group]').forEach(function(group) {
    var btn = group.querySelector('[data-month-toggle]');
    if (!btn) return;
    btn.addEventListener('click', function() {
      var open = group.classList.toggle('open');
      btn.setAttribute('aria-expanded', open ? 'true' : 'false');
    });
  });

  /* ── Entry expand on row click ── */
  document.querySelectorAll('.ldg-entry').forEach(function(entry) {
    entry.addEventListener('click', function() {
      var id = entry.getAttribute('data-entry-id');
      var panel = document.getElementById('ldg-expand-' + id);
      if (!panel) return;

      var isOpen = panel.classList.contains('open');

      /* Close all others */
      document.querySelectorAll('.ldg-expand.open').forEach(function(p) {
        if (p !== panel) {
          p.classList.remove('open');
          var sibling = p.previousElementSibling;
          if (sibling) sibling.classList.remove('expanded');
        }
      });

      panel.classList.toggle('open', !isOpen);
      entry.classList.toggle('expanded', !isOpen);
    });
  });

  /* ── Filter drawer toggle ── */
  var filterToggle  = document.getElementById('ldg-filter-toggle');
  var filterDrawer  = document.getElementById('ldg-filter-drawer');
  if (filterToggle && filterDrawer) {
    filterToggle.addEventListener('click', function() {
      filterDrawer.classList.toggle('open');
    });
  }

  /* ── Live client-side search (immediate feedback before form submit) ── */
  var searchInput = document.getElementById('ldg-search-input');
  if (searchInput) {
    var debounce;
    searchInput.addEventListener('input', function() {
      clearTimeout(debounce);
      var q = this.value.trim().toLowerCase();

      debounce = setTimeout(function() {
        document.querySelectorAll('.ldg-entry').forEach(function(entry) {
          var text = (entry.textContent || '').toLowerCase();
          var panel = document.getElementById('ldg-expand-' + entry.getAttribute('data-entry-id'));
          var matches = !q || text.includes(q);
          entry.style.display = matches ? '' : 'none';
          if (panel) panel.style.display = matches ? '' : 'none';
        });

        /* Hide empty month groups */
        document.querySelectorAll('[data-month-group]').forEach(function(group) {
          var visible = group.querySelectorAll('.ldg-entry:not([style*="display: none"])').length;
          group.style.display = visible ? '' : 'none';
        });
      }, 200);
    });
  }
})();
</script>

</main>
</body>
</html>
