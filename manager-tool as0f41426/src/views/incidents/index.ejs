.ldg-sev-medium { background: rgba(245,158,11,.12); border-color: rgba(245,158,11,.28); color: #fbbf24; }
.ldg-sev-high   { background: rgba(239,68,68,.12);  border-color: rgba(239,68,68,.28);  color: #f87171; }
/* Follow-up health */
.ldg-health-ok   { background: rgba(34,197,94,.12);  border-color: rgba(34,197,94,.28);  color: #4ade80; }
.ldg-health-warn { background: rgba(245,158,11,.12); border-color: rgba(245,158,11,.28); color: #fbbf24; }
.ldg-health-bad  { background: rgba(239,68,68,.12);  border-color: rgba(239,68,68,.28);  color: #f87171; }
/* Tone — neutral */
