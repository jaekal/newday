<!-- src/views/rackAssignments/import.ejs -->
<%- include('../layout') %>

<%
  // ✅ Defensive locals so the page never throws ReferenceError
  const importErrorSafe =
    (typeof importError !== 'undefined' && importError)
      ? importError
      : ((typeof errorMessage !== 'undefined' && errorMessage) ? errorMessage : null);

  const importSummarySafe =
    (typeof importSummary !== 'undefined' && importSummary)
      ? importSummary
      : ((typeof summaryMessage !== 'undefined' && summaryMessage) ? summaryMessage : null);
%>

<section class="page-header">
  <div>
    <h2>Rack Assignment Import – Event Stream</h2>

    <p class="muted">
      Upload assignment exports to build exposure by <strong>Customer</strong> and <strong>Model</strong>.
      This import resolves the assignee using the <strong>Roster</strong> and ties each event back to a
      <strong>StaffProfile</strong>.
    </p>

    <div class="card" style="margin-top:0.75rem; padding:0.75rem;">
      <p class="muted" style="margin:0 0 0.5rem 0;">
        <strong>Expected columns</strong> (case-insensitive):
      </p>
      <p class="muted" style="margin:0;">
        <code>Building</code>,
        <code>Customer</code>,
        <code>assignmentTime</code>,
        <code>assigneeAtTime</code>,
        <code>model</code>,
        <code>serialNumber</code>,
        <code>type</code>
      </p>

      <p class="muted small" style="margin:0.65rem 0 0 0;">
        <strong>Staff lookup:</strong> <code>assigneeAtTime</code> is normalized into a domain username and matched to
        <code>RosterEntry.domainUsername</code>, then tied to the StaffProfile via roster <code>employeeId</code>.
      </p>
    </div>

    <div class="muted small" style="margin-top:0.75rem;">
      <strong>Rules</strong>
      <ul class="muted small" style="margin-top:0.25rem;">
        <li><strong>Required:</strong> <code>assignmentTime</code>, <code>assigneeAtTime</code>, <code>serialNumber</code>, <code>type</code></li>
        <li><strong>type</strong> must be <code>RACK</code> or <code>SERVER</code>.</li>
        <li><strong>assignmentTime format:</strong> supports <code>1/15/2026 0:20</code> and Excel date/time values.</li>
        <li>
          <strong>Dedupe:</strong> the same profile will only count a given <code>serialNumber</code> once per day per <code>type</code>,
          but multiple staff can be assigned to the same serial number on the same date.
        </li>
      </ul>
    </div>
  </div>

  <div style="display:flex; flex-direction:column; gap:0.5rem; align-items:flex-end;">
    <a href="/staff" class="btn ghost">Back to Staff Roster</a>
    <a href="/roster" class="btn ghost">View Roster</a>
    <a href="/imports/templates/rackAssignmentEvents.csv" class="btn ghost">Download Template</a>
  </div>
</section>

<div class="card">
  <% if (importErrorSafe) { %>
    <pre class="alert alert-error" style="white-space:pre-wrap;"><%= importErrorSafe %></pre>
  <% } %>

  <% if (importSummarySafe) { %>
    <pre class="alert alert-success" style="white-space:pre-wrap;"><%= importSummarySafe %></pre>
  <% } %>

  <form
    method="POST"
    action="/rack-assignments/import"
    enctype="multipart/form-data"
    style="display:flex; flex-direction:column; gap:1rem; max-width:520px;"
  >
    <label>
      <span>Assignment File (CSV or Excel)</span>
      <input type="file" name="file" accept=".csv,.xlsx,.xls" required />
    </label>

    <div class="muted small">
      Tip: import the roster first so domain usernames resolve cleanly.
    </div>

    <div style="display:flex; gap:0.5rem; justify-content:flex-end; margin-top:0.5rem;">
      <button type="submit" class="btn primary">Upload &amp; Import</button>
    </div>
  </form>
</div>

</main>
</body>
</html>
