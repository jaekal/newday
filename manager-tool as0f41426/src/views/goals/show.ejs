<!-- src/views/goals/show.ejs -->
<%- include('../layout') %>

<%
  function safeDateTime(value) {
    try {
      if (!value) return '';
      const d = new Date(value);
      if (Number.isNaN(d.getTime())) return '';
      return d.toLocaleString();
    } catch (e) {
      return '';
    }
  }

  const meta = goal.meta || {};
%>

<style>
  .goal-show-grid {
    display:grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap:1rem;
    align-items:start;
  }

  @media (max-width: 980px) {
    .goal-show-grid { grid-template-columns: 1fr; }
  }

  .timeline {
    display:flex;
    flex-direction:column;
    gap:0.85rem;
  }

  .timeline-item {
    border:1px solid rgba(255,255,255,0.08);
    background:rgba(17,24,39,0.55);
    border-radius:14px;
    padding:0.85rem;
  }

  .timeline-meta {
    display:flex;
    justify-content:space-between;
    gap:0.75rem;
    flex-wrap:wrap;
    align-items:center;
  }

  .timeline-note {
    margin-top:0.55rem;
    color:rgba(229,231,235,0.96);
    white-space:pre-wrap;
  }

  .field label {
    display:block;
    font-weight:600;
    margin-bottom:0.35rem;
  }

  .field input,
  .field textarea,
  .field select {
    width:100%;
    border:1px solid rgba(255,255,255,0.10);
    background: rgba(15,23,42,0.55);
    color: rgba(229,231,235,0.95);
    border-radius: 12px;
    padding: 0.6rem 0.75rem;
    outline:none;
  }

  .field input:focus,
  .field textarea:focus,
  .field select:focus {
    outline: 2px solid rgba(59,130,246,0.35);
  }

  .stack-list {
    display:flex;
    flex-direction:column;
    gap:0.45rem;
  }

  .goal-summary-chips {
    display:flex;
    gap:0.35rem;
    flex-wrap:wrap;
    margin-top:0.55rem;
  }

  .bar {
    height:8px;
    border-radius:999px;
    background:rgba(255,255,255,0.08);
    overflow:hidden;
    width:100%;
  }

  .bar > div {
    height:8px;
    background:rgba(59,130,246,0.85);
  }
</style>

<section class="page-header" style="display:flex; justify-content:space-between; gap:1rem; flex-wrap:wrap; align-items:flex-start;">
  <div>
    <h2 style="margin-bottom:0.25rem;"><%= goal.title %></h2>
    <p class="muted" style="max-width:880px;">
      Goal history, momentum, and check-ins all in one place.
    </p>
    <div class="goal-summary-chips">
      <span class="<%= meta.statusClass || 'status-badge status-open' %>"><%= meta.statusLabel || goal.status %></span>
      <span class="<%= meta.healthClass || 'status-badge status-done' %>"><%= meta.healthLabel || 'On Track' %></span>
      <span class="<%= meta.priorityClass || 'chip muted small' %>"><%= meta.priorityLabel || 'No Priority' %></span>
      <% if (goal.type) { %><span class="chip chip-neutral" style="font-size:0.72rem;"><%= goal.type %></span><% } %>
      <span class="chip muted small"><%= meta.categoryLabel || 'Uncategorized' %></span>
      <% if (meta.dueISO) { %>
        <span class="<%= meta.dueClass || 'chip muted small' %>">Due: <strong><%= meta.dueISO %></strong></span>
      <% } %>
    </div>
  </div>

  <div style="display:flex; gap:0.5rem; flex-wrap:wrap;">
    <a href="/goals" class="btn ghost">Back to Goals</a>
    <a href="/goals/<%= goal.id %>/edit" class="btn ghost">Edit Goal</a>
  </div>
</section>

<section class="goal-show-grid">
  <div style="display:flex; flex-direction:column; gap:1rem;">
    <section class="card" style="padding:1rem;">
      <div class="section-header">
        <div>
          <h3 style="margin-bottom:0.2rem;">Goal Summary</h3>
          <p class="muted small" style="margin:0;">
            The current snapshot of the goal.
          </p>
        </div>
      </div>

      <div class="stack-list">
        <div><strong>Owner:</strong> <%= goal.Owner ? goal.Owner.name : 'N/A' %></div>
        <div><strong>Description:</strong> <%= goal.description || '—' %></div>
        <div><strong>Success Criteria:</strong> <%= goal.successCriteria || '—' %></div>
        <div><strong>KPI / Measure:</strong> <%= goal.measure || '—' %></div>
        <div><strong>Timeline:</strong>
          <% if (meta.daysLeft == null) { %>
            —
          <% } else if (meta.daysLeft < 0) { %>
            <%= Math.abs(meta.daysLeft) %>d overdue
          <% } else { %>
            <%= meta.daysLeft %>d left
          <% } %>
        </div>
      </div>

      <div style="margin-top:0.9rem;">
        <div style="display:flex; justify-content:space-between; gap:0.5rem; margin-bottom:0.35rem;">
          <span class="muted small">Progress</span>
          <span class="muted small"><strong><%= meta.progressNum != null ? meta.progressNum : goal.progress %>%</strong></span>
        </div>
        <div class="bar">
          <div style="width:<%= Math.max(0, Math.min(100, meta.progressNum != null ? meta.progressNum : goal.progress || 0)) %>%;"></div>
        </div>
      </div>
    </section>

    <section class="card" style="padding:1rem;">
      <div class="section-header">
        <div>
          <h3 style="margin-bottom:0.2rem;">Check-In Timeline</h3>
          <p class="muted small" style="margin:0;">
            A running record of movement, updates, and coaching notes.
          </p>
        </div>
      </div>

      <% if (!checkIns || !checkIns.length) { %>
        <p class="muted">No check-ins yet.</p>
      <% } else { %>
        <div class="timeline">
          <% checkIns.forEach(function(c) { %>
            <div class="timeline-item">
              <div class="timeline-meta">
                <div>
                  <strong><%= safeDateTime(c.createdAt) %></strong>
                  <% if (c.Author && c.Author.name) { %>
                    <span class="muted small">• <%= c.Author.name %></span>
                  <% } %>
                </div>

                <div style="display:flex; gap:0.35rem; flex-wrap:wrap;">
                  <span class="chip muted small">
                    <%= String(c.statusSnapshot || '').replace(/_/g, ' ') %>
                  </span>
                  <span class="chip muted small">
                    <%= c.progressSnapshot %>%
                  </span>
                  <span class="chip muted small">
                    <%= c.entryType %>
                  </span>
                </div>
              </div>

              <% if (c.note) { %>
                <div class="timeline-note"><%= c.note %></div>
              <% } else { %>
                <div class="timeline-note muted">No note entered.</div>
              <% } %>
            </div>
          <% }) %>
        </div>
      <% } %>
    </section>
  </div>

  <div style="display:flex; flex-direction:column; gap:1rem;">
    <section class="card" style="padding:1rem;">
      <div class="section-header">
        <div>
          <h3 style="margin-bottom:0.2rem;">Add Check-In</h3>
          <p class="muted small" style="margin:0;">
            Log progress, blockers, coaching notes, or completion evidence.
          </p>
        </div>
      </div>

      <form method="POST" action="/goals/<%= goal.id %>/check-ins">
        <div class="field" style="margin-bottom:0.85rem;">
          <label for="goalCheckInNote">Check-In Note</label>
          <textarea
            id="goalCheckInNote"
            name="note"
            rows="7"
            placeholder="Example: Completed training module. Passed quiz at 94%. Needs one live observation next week before closure."
          ></textarea>
        </div>

        <div style="display:grid; grid-template-columns:1fr 1fr; gap:0.75rem; margin-bottom:0.85rem;">
          <div class="field">
            <label for="goalCheckInStatus">Status</label>
            <select id="goalCheckInStatus" name="status">
              <option value="OPEN" <%= goal.status === 'OPEN' ? 'selected' : '' %>>OPEN</option>
              <option value="IN_PROGRESS" <%= goal.status === 'IN_PROGRESS' ? 'selected' : '' %>>IN PROGRESS</option>
              <option value="DONE" <%= goal.status === 'DONE' ? 'selected' : '' %>>DONE</option>
              <option value="ON_HOLD" <%= goal.status === 'ON_HOLD' ? 'selected' : '' %>>ON HOLD</option>
            </select>
          </div>

          <div class="field">
            <label for="goalCheckInProgress">Progress</label>
            <input
              id="goalCheckInProgress"
              type="number"
              name="progress"
              min="0"
              max="100"
              value="<%= goal.progress || 0 %>"
            />
          </div>
        </div>

        <div style="display:flex; justify-content:flex-end; gap:0.5rem; flex-wrap:wrap;">
          <button type="submit" class="btn primary">Save Check-In</button>
        </div>
      </form>
    </section>
  </div>
</section>

</main>
</body>
</html>