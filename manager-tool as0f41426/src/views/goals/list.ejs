<%- include('../layout') %>

<%
  function safeDateObj(value) {
    try {
      if (!value) return null;
      const d = new Date(value);
      if (Number.isNaN(d.getTime())) return null;
      return d;
    } catch (e) {
      return null;
    }
  }

  function safeDateTime(value) {
    try {
      if (!value) return '';
      const d = new Date(value);
      if (Number.isNaN(d.getTime())) return '';
      return d.toLocaleString();
    } catch (e) {
      return '';
    }
  }

  function dueMonthKey(goal) {
    const source = goal?.dueDate || null;
    const d = safeDateObj(source);
    if (!d) return 'no-due-date';
    const y = d.getFullYear();
    const m = String(d.getMonth() + 1).padStart(2, '0');
    return `${y}-${m}`;
  }

  function dueMonthLabel(key) {
    if (key === 'no-due-date') return 'No Due Date';
    try {
      const [year, month] = String(key).split('-').map(Number);
      const d = new Date(year, (month || 1) - 1, 1);
      return d.toLocaleString('en-US', { month: 'long', year: 'numeric' });
    } catch (e) {
      return key;
    }
  }

  const _goals = Array.isArray(goals) ? goals : [];

  const groupedMap = {};
  _goals.forEach((g) => {
    const key = dueMonthKey(g);
    if (!groupedMap[key]) groupedMap[key] = [];
    groupedMap[key].push(g);
  });

  const monthGroups = Object.keys(groupedMap)
    .sort((a, b) => {
      if (a === 'no-due-date' && b === 'no-due-date') return 0;
      if (a === 'no-due-date') return 1;
      if (b === 'no-due-date') return -1;
      return a.localeCompare(b);
    })
    .map((key, idx) => ({
      key,
      label: dueMonthLabel(key),
      goals: groupedMap[key],
      openByDefault: idx === 0,
    }));
%>

<style>
  .goals-topbar {
    display:flex;
    justify-content:space-between;
    gap:1rem;
    flex-wrap:wrap;
    align-items:flex-start;
  }

  .goals-tabs {
    display:flex;
    gap:0.5rem;
    flex-wrap:wrap;
    margin-top:0.5rem;
  }

  .goals-tab {
    border:1px solid rgba(255,255,255,0.10);
    background:rgba(15,23,42,0.55);
    color:rgba(229,231,235,0.95);
    border-radius:999px;
    padding:0.35rem 0.65rem;
    cursor:pointer;
    font-size:0.85rem;
  }

  .goals-tab.active {
    outline:2px solid rgba(59,130,246,0.45);
    background:rgba(59,130,246,0.15);
  }

  /* Collapsible filters bar */
  .goals-filters-card {
    margin-bottom: 0.75rem;
  }

  .goals-filters-head {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
    align-items: flex-start;
  }

  .goals-filters-toggle {
    cursor: pointer;
    user-select: none;
    margin: 0;
  }

  .goals-filters-panel {
    display: none;
    margin-top: 0.85rem;
  }

  .goals-filters-panel.open {
    display: block;
  }

  .goals-filters-form {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    align-items: flex-end;
  }

  .goals-filter-field {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    min-width: 180px;
    flex: 1 1 190px;
  }

  .goals-filter-field.grow {
    flex: 2 1 280px;
    min-width: 260px;
  }

  .goals-filter-actions {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    align-items: center;
    margin-left: auto;
  }

  @media (max-width: 900px) {
    .goals-filter-actions {
      margin-left: 0;
      width: 100%;
      justify-content: flex-end;
    }
  }

  .goal-group {
    border:1px solid rgba(255,255,255,0.06);
    border-radius:18px;
    overflow:hidden;
    background:rgba(2,6,23,0.22);
    margin-top:1rem;
  }

  .goal-group:first-of-type {
    margin-top:0;
  }

  .goal-group-toggle {
    width:100%;
    border:0;
    background:linear-gradient(180deg, rgba(30,41,59,0.82), rgba(15,23,42,0.82));
    color:inherit;
    padding:1rem 1.1rem;
    display:flex;
    justify-content:space-between;
    align-items:center;
    gap:1rem;
    cursor:pointer;
    text-align:left;
  }

  .goal-group-toggle:hover {
    background:linear-gradient(180deg, rgba(38,52,75,0.9), rgba(15,23,42,0.88));
  }

  .goal-group-left {
    display:flex;
    flex-direction:column;
    gap:0.25rem;
  }

  .goal-group-title {
    font-weight:700;
    font-size:1rem;
  }

  .goal-group-meta {
    color:rgba(148,163,184,0.95);
    font-size:0.82rem;
  }

  .goal-group-caret {
    font-size:1rem;
    transition:transform .2s ease;
