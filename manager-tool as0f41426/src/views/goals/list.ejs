  }

  .goal-group.open .goal-group-caret {
    transform:rotate(180deg);
  }

  .goal-group-body {
    display:none;
    padding:0.9rem;
    border-top:1px solid rgba(255,255,255,0.06);
  }

  .goal-group.open .goal-group-body {
    display:block;
  }

  .goals-grid {
    display:grid;
