          name="buildTrust"
          id="buildTrust"
          min="1"
          max="5"
          step="1"
          value="<%= safeVal(review.buildTrust) %>"
          data-comment="buildTrustComment"
        />
        <textarea class="criteria-comment" name="buildTrustComment" rows="2"><%= review.buildTrustComment || '' %></textarea>
      </div>
