            type="number"
            name="enableTheTeam"
            id="enableTheTeam"
            min="1"
            max="5"
            step="1"
            value="<%= safeVal(review.enableTheTeam) %>"
            data-comment="enableTheTeamComment"
          />
          <textarea class="criteria-comment" name="enableTheTeamComment" rows="2"><%= review.enableTheTeamComment || '' %></textarea>
        </div>
      </div>

      <div class="field">
        <label for="hireDevelopManage">
