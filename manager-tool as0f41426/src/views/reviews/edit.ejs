</form>

<!-- Floating Criteria Guide button -->
<button type="button" class="criteria-fab" id="criteriaFabEdit">
  <span class="criteria-fab-icon">?</span>
  <span class="criteria-fab-text">Review Criteria</span>
</button>

<script>
  (function () {
    const editForm = document.querySelector('form[method="POST"]');

    // Bucket expand / collapse
    document.querySelectorAll('.bucket-toggle').forEach(btn => {
      btn.addEventListener('click', () => {
        const targetId = btn.getAttribute('data-target');
        const body = document.getElementById(targetId);
        if (!body) return;

        const icon = btn.querySelector('.bucket-toggle-icon');
        const isHidden = body.style.display === 'none';

        body.style.display = isHidden ? 'block' : 'none';
        if (icon) icon.textContent = isHidden ? '\u25BC' : '\u25B2';
        btn.textContent = '';
        btn.appendChild(icon);
        btn.insertAdjacentText('beforeend', isHidden ? ' Collapse' : ' Expand');
      });
    });

    // Hover help tooltips
    let tooltipEl = null;
    let hideTimer = null;

    function showTooltip(el) {
      const text = el.getAttribute('data-help');
      if (!text) return;

      if (!tooltipEl) {
        tooltipEl = document.createElement('div');
        tooltipEl.className = 'criteria-tooltip';
        document.body.appendChild(tooltipEl);
      }

      tooltipEl.textContent = text;

      const rect = el.getBoundingClientRect();
      const top = rect.bottom + 6;
      const left = rect.left;

      tooltipEl.style.top = top + 'px';
      tooltipEl.style.left = left + 'px';
      tooltipEl.style.display = 'block';
    }

    function hideTooltip() {
      if (tooltipEl) tooltipEl.style.display = 'none';
    }

    document.addEventListener('mouseover', (evt) => {
      const target = evt.target.closest('.question-help');
      if (!target) {
        if (hideTimer) clearTimeout(hideTimer);
        hideTimer = setTimeout(hideTooltip, 80);
        return;
      }
      if (hideTimer) clearTimeout(hideTimer);
      showTooltip(target);
    });

    document.addEventListener('mouseout', (evt) => {
      const target = evt.target.closest('.question-help');
      if (target && hideTimer) {
        hideTimer = setTimeout(hideTooltip, 80);
      }
    });

    // Floating criteria guide button
    const fab = document.getElementById('criteriaFabEdit');
    if (fab) {
      fab.addEventListener('click', function () {
        window.open('/reviews/criteria', '_blank');
      });
    }

    // -- Hide empty comment fields; show "Add comment" toggle --
    document.querySelectorAll('.criteria-comment').forEach(function (ta) {
      if ((ta.value || '').trim() !== '') return; // already has content - leave visible

      ta.style.display = 'none';

      const btn = document.createElement('button');
      btn.type = 'button';
      btn.textContent = '+ Add comment';
      btn.className = 'btn ghost btn-sm';
      btn.style.cssText = 'margin-top:4px;font-size:0.78rem;padding:2px 8px;';

      btn.addEventListener('click', function () {
        ta.style.display = '';
        ta.focus();
        btn.remove();
      });

      ta.parentNode.insertBefore(btn, ta.nextSibling);
    });

    // -- Hide main comment if empty; show "Add comment" button --
    (function () {
      const wrap = document.getElementById('comment-field-wrap');
      const ta = wrap && wrap.querySelector('textarea#comment');
      if (!ta || (ta.value || '').trim() !== '') return;

      ta.style.display = 'none';

      const btn = document.createElement('button');
      btn.type = 'button';
      btn.textContent = '+ Add comment';
      btn.className = 'btn ghost btn-sm';
      btn.style.cssText = 'margin-top:4px;font-size:0.78rem;';

      btn.addEventListener('click', function () {
        ta.style.display = '';
        ta.focus();
        btn.remove();
      });

      ta.parentNode.insertBefore(btn, ta.nextSibling);
    })();

    // -- Track original values + highlight changed scores --
    const originalValues = {};
    editForm && editForm.querySelectorAll('input[type="number"][name]').forEach(function (inp) {
      originalValues[inp.name] = inp.value;
      inp.addEventListener('input', function () {
        const changed = inp.value !== originalValues[inp.name];
        inp.style.outline = changed ? '2px solid rgba(251,191,36,0.6)' : '';
        inp.title = changed ? 'Changed from ' + (originalValues[inp.name] || 'blank') + ' -> ' + inp.value : '';
      });
    });

    // -- Confirm before leaving with unsaved edits --
    let editFormDirty = false;
    editForm && editForm.querySelectorAll('input, textarea').forEach(function (el) {
      el.addEventListener('input', function () { editFormDirty = true; });
    });
    editForm && editForm.addEventListener('submit', function () { editFormDirty = false; });
    window.addEventListener('beforeunload', function (e) {
      if (editFormDirty) { e.preventDefault(); e.returnValue = ''; }
    });

    // -- Comment validation on submit --
    // Comments are required for any score that is 1, 2, 4, or 5.
    const LEADING_FIELDS_EDIT = ['decisionMakingWithRisk', 'enableTheTeam', 'hireDevelopManage'];
    const COMMENT_MAP_EDIT = {
      positiveAttitude:       'positiveAttitudeComment',
      proactive:              'proactiveComment',
      integrity:              'integrityComment',
      accountability2:        'accountability2Comment',
      problemSolving:         'problemSolvingComment',
      efficiency:             'efficiencyComment',
      resultsOrientation:     'resultsOrientationComment',
      communication:          'communicationComment',
      continuousImprovement:  'continuousImprovementComment',
      teamwork2:              'teamwork2Comment',
      collaboration:          'collaborationComment',
      buildTrust:             'buildTrustComment',
      decisionMakingWithRisk: 'decisionMakingWithRiskComment',
      enableTheTeam:          'enableTheTeamComment',
      hireDevelopManage:      'hireDevelopManageComment',
    };

    if (editForm) {
      editForm.addEventListener('submit', function (evt) {
        const scoreInputs = editForm.querySelectorAll('input[type="number"][data-comment]');
        let errors = [];
        let firstErrorEl = null;

        scoreInputs.forEach(function (input) {
          const raw = (input.value || '').trim();
          if (!raw) return;
          const n = Number(raw);
          if (!Number.isFinite(n) || !Number.isInteger(n) || n === 3) return;

          const commentName = COMMENT_MAP_EDIT[input.name];
          if (!commentName) return;
          const ta = editForm.querySelector('textarea[name="' + commentName + '"]');
          if (!ta) return;

          const hasText = (ta.value || '').trim().length > 0;
          if (!hasText) {
            // Show inline error on the textarea
            let errEl = ta._editCommentErr;
            if (!errEl) {
              errEl = document.createElement('span');
              errEl.style.cssText = 'display:block;margin-top:3px;font-size:0.76rem;font-weight:500;color:var(--danger,#ef4444);';
              ta.after(errEl);
              ta._editCommentErr = errEl;
            }
            errEl.textContent = 'A comment is required for scores of 1, 2, 4, or 5.';
            ta.style.borderColor = 'var(--danger,#ef4444)';
            errors.push(input.name);
            if (!firstErrorEl) firstErrorEl = ta;
          } else {
            // Clear any existing error
            if (ta._editCommentErr) ta._editCommentErr.textContent = '';
            ta.style.borderColor = '';
          }
        });

        if (errors.length > 0) {
          evt.preventDefault();
          evt.stopPropagation();
          if (firstErrorEl) firstErrorEl.scrollIntoView({ behavior: 'smooth', block: 'center' });
          // Show summary banner if present
          let banner = document.getElementById('edit-validation-summary');
          if (!banner) {
            banner = document.createElement('div');
            banner.id = 'edit-validation-summary';
            banner.style.cssText = 'margin-top:0.75rem;padding:0.6rem 0.9rem;border-radius:0.5rem;border:1px solid rgba(239,68,68,0.5);background:rgba(127,29,29,0.35);color:#fecaca;font-size:0.85rem;';
            const saveBtn = editForm.querySelector('button[type="submit"]');
            if (saveBtn) saveBtn.parentNode.insertBefore(banner, saveBtn);
          }
          banner.textContent = errors.length + (errors.length === 1 ? ' comment is' : ' comments are') + ' required for non-average scores before you can save.';
          banner.style.display = 'block';
        } else {
          const banner = document.getElementById('edit-validation-summary');
          if (banner) banner.style.display = 'none';
        }
      });

      // Clear comment errors as the user types into a textarea
      editForm.querySelectorAll('textarea[name]').forEach(function (ta) {
        ta.addEventListener('input', function () {
          if ((ta.value || '').trim().length > 0) {
            if (ta._editCommentErr) ta._editCommentErr.textContent = '';
            ta.style.borderColor = '';
          }
        });
      });
    }
  })();
</script>

<script id="positionCriteriaData" type="application/json"><%- JSON.stringify(typeof positionCriteria !== 'undefined' ? positionCriteria : {}) %></script>
<script>
  (function () {
    let criteriaData = {};
    try {
      const el = document.getElementById('positionCriteriaData');
      if (el) criteriaData = JSON.parse(el.textContent || '{}');
    } catch (e) {}
    const positionType = '<%= review && review.positionTypeSnapshot ? String(review.positionTypeSnapshot).toUpperCase() : "" %>';
    const criteria = criteriaData[positionType] || null;
    if (!criteria) return;
    document.querySelectorAll('.criteria-comment-row').forEach(function (row) {
      const field = row.getAttribute('data-for') || '';
      const key = field.replace('Comment', '');
      const hint = criteria[key];
      if (!hint) return;
      let hintEl = row.querySelector('.criteria-position-hint');
      if (!hintEl) {
        hintEl = document.createElement('p');
        hintEl.className = 'muted small criteria-position-hint';
        hintEl.style.marginTop = '0.35rem';
        row.appendChild(hintEl);
      }
      hintEl.textContent = positionType + ': ' + hint;
    });
  })();
</script>

</main>
</body>
</html>
