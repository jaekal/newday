            data-comment="decisionMakingWithRiskComment"
          />
          <textarea class="criteria-comment" name="decisionMakingWithRiskComment" rows="2"><%= review.decisionMakingWithRiskComment || '' %></textarea>
        </div>

        <div class="field">
