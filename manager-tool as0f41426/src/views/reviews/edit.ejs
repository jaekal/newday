              <span class="question-help-icon">?</span>
            </span>
          </label>
          <input
            type="number"
            name="resultsOrientation"
            id="resultsOrientation"
            min="1"
            max="5"
            step="1"
            value="<%= safeVal(review.resultsOrientation) %>"
            data-comment="resultsOrientationComment"
          />
          <textarea class="criteria-comment" name="resultsOrientationComment" rows="2"><%= review.resultsOrientationComment || '' %></textarea>
        </div>

        <div class="field">
          <label for="communication">
            Communication
            <span class="question-help" data-help="Keeps others informed, escalates blockers, and is open to feedback from the team and management.">
              <span class="question-help-icon">?</span>
            </span>
          </label>
          <input
            type="number"
            name="communication"
            id="communication"
            min="1"
            max="5"
            step="1"
            value="<%= safeVal(review.communication) %>"
            data-comment="communicationComment"
          />
          <textarea class="criteria-comment" name="communicationComment" rows="2"><%= review.communicationComment || '' %></textarea>
        </div>
      </div>

      <div class="field">
        <label for="continuousImprovement">
          Continuous Improvement
          <span class="question-help" data-help="Grows their knowledge of tests, processes, and products, and applies learning to improve daily work.">
            <span class="question-help-icon">?</span>
          </span>
        </label>
        <input
          type="number"
          name="continuousImprovement"
          id="continuousImprovement"
          min="1"
          max="5"
          step="1"
          value="<%= safeVal(review.continuousImprovement) %>"
          data-comment="continuousImprovementComment"
        />
        <textarea class="criteria-comment" name="continuousImprovementComment" rows="2"><%= review.continuousImprovementComment || '' %></textarea>
      </div>
    </div>
  </section>

  <!-- PARTNERSHIP -->
  <section class="card bucket-card" data-bucket="partnership">
    <header class="bucket-card-header">
      <div>
        <h3>Partnership</h3>
        <p class="muted small">
          Teamwork, collaboration, and how they build trust in the team.
        </p>
      </div>
      <button type="button" class="btn ghost btn-small bucket-toggle" data-target="partnership-body">
        <span class="bucket-toggle-icon">▼</span> Collapse
      </button>
    </header>

    <div class="bucket-card-body" id="partnership-body">
      <div class="layout-two-column">
        <div class="field">
          <label for="teamwork2">
            Teamwork
            <span class="question-help" data-help="Shares knowledge, is willing to help others, and supports the overall success of the team.">
              <span class="question-help-icon">?</span>
            </span>
          </label>
          <input
            type="number"
            name="teamwork2"
            id="teamwork2"
            min="1"
            max="5"
            step="1"
            value="<%= safeVal(review.teamwork2) %>"
            data-comment="teamwork2Comment"
          />
          <textarea class="criteria-comment" name="teamwork2Comment" rows="2"><%= review.teamwork2Comment || '' %></textarea>
        </div>

        <div class="field">
          <label for="collaboration">
            Collaboration
            <span class="question-help" data-help="Respects different perspectives, works well with diverse teammates, and contributes in meetings and discussions.">
              <span class="question-help-icon">?</span>
            </span>
          </label>
          <input
            type="number"
            name="collaboration"
            id="collaboration"
            min="1"
            max="5"
            step="1"
            value="<%= safeVal(review.collaboration) %>"
            data-comment="collaborationComment"
          />
          <textarea class="criteria-comment" name="collaborationComment" rows="2"><%= review.collaborationComment || '' %></textarea>
        </div>
      </div>

      <div class="field">
        <label for="buildTrust">
          Build Trust
          <span class="question-help" data-help="Consistently reliable, respectful, and able to work independently without constant supervision.">
            <span class="question-help-icon">?</span>
          </span>
        </label>
        <input
