        <div class="field">
          <label for="accountability2">
            Accountability
            <span class="question-help" data-help="Dependable, meets expectations, owns their work, and follows through without excuses.">
              <span class="question-help-icon">?</span>
            </span>
          </label>
          <input
            type="number"
            name="accountability2"
            id="accountability2"
            min="1"
            max="5"
            step="1"
            value="<%= safeVal(review.accountability2) %>"
            data-comment="accountability2Comment"
          />
          <textarea class="criteria-comment" name="accountability2Comment" rows="2"><%= review.accountability2Comment || '' %></textarea>
        </div>

        <div class="field">
          <label for="problemSolving">
            Problem Solving
            <span class="question-help" data-help="Addresses day-to-day issues, escalates appropriately, and contributes ideas to improve work.">
              <span class="question-help-icon">?</span>
            </span>
          </label>
          <input
            type="number"
            name="problemSolving"
            id="problemSolving"
            min="1"
            max="5"
            step="1"
            value="<%= safeVal(review.problemSolving) %>"
            data-comment="problemSolvingComment"
          />
          <textarea class="criteria-comment" name="problemSolvingComment" rows="2"><%= review.problemSolvingComment || '' %></textarea>
        </div>
      </div>

      <div class="field">
        <label for="efficiency">
          Efficiency
          <span class="question-help" data-help="Organizes their work, uses time well (including downtime), and makes effective day-to-day decisions.">
            <span class="question-help-icon">?</span>
          </span>
        </label>
        <input
          type="number"
          name="efficiency"
