<%- include('../layout') %>

<%
  // review is passed as plain object with Staff + StaffProfile included
  const staff = review.Staff || null;
  const profile = staff && staff.StaffProfile ? staff.StaffProfile : null;

  function safeVal(v) {
    return typeof v === 'number' ? v : '';
  }
%>

<section class="page-header">
  <div>
    <h2>Edit Monthly Review</h2>
    <p class="muted">
      Update scores and comments for this review. Bucket averages will be recalculated
      automatically based on your changes.
    </p>
    <p class="muted" style="margin-top:0.25rem;">
      Need calibration? Use the
      <a href="/reviews/criteria" target="_blank">Review Criteria Guide</a>
      or hover the “?” bubbles beside each question.
    </p>
  </div>

  <div>
    <p class="muted small" style="text-align:right;">
      Period: <strong><%= review.periodMonth %>/<%= review.periodYear %></strong><br />
      Staff: <strong><%= staff ? staff.name : 'N/A' %></strong>
    </p>
  </div>
</section>

<% if (duplicateWarning) { %>
  <section class="card" style="border-left:4px solid #f97316;">
    <h3>Duplicate Review Detected</h3>
    <p class="muted">
      A review for <strong><%= staff ? staff.name : 'this staff member' %></strong> in
      <strong><%= review.periodMonth %>/<%= review.periodYear %></strong> already exists.
      You are now editing that review instead of creating a new one.
    </p>
  </section>
<% } %>

<section class="card" style="margin-bottom:1rem;">
  <div class="section-header">
    <h3>Staff Snapshot</h3>
  </div>

  <div class="layout-two-column">
    <div>
      <p class="muted small">
        <strong>Name:</strong> <%= staff ? staff.name : 'N/A' %><br />
        <strong>Role:</strong> <%= staff && staff.role ? staff.role : 'N/A' %>
        <% if (profile && profile.positionType) { %>
          • <strong>Position:</strong> <%= profile.positionType %>
        <% } %>
      </p>
    </div>
    <div>
      <p class="muted small">
        <% if (profile && profile.building) { %>
          <strong>Building:</strong> <%= profile.building %><br />
        <% } %>
        <% if (profile && profile.shift) { %>
          <strong>Shift:</strong> <%= profile.shift %><br />
        <% } %>
      </p>
    </div>
  </div>
</section>

<% const safeOpenIncidents = (typeof openIncidents !== 'undefined' && Array.isArray(openIncidents)) ? openIncidents : []; %>
<% if (safeOpenIncidents.length > 0) { %>
  <div class="review-incidents-panel">
    <div class="review-incidents-header">
      <span class="chip chip-warn" style="font-size:0.75rem;">⚠ <%= safeOpenIncidents.length %> open incident<%= safeOpenIncidents.length > 1 ? 's' : '' %></span>
      <span style="font-size:0.8rem; color:var(--text-muted); margin-left:0.5rem;">Consider these when rating accountability and behavior.</span>
    </div>
    <ul class="review-incidents-list">
      <% safeOpenIncidents.forEach(function(inc) { %>
        <li>
          <span class="review-incident-date"><%= inc.incidentDate ? String(inc.incidentDate).slice(0,10) : '—' %></span>
          <span class="review-incident-title"><%= inc.title || '(no title)' %></span>
          <% if (inc.severity) { %><span class="review-incident-severity chip chip-<%= inc.severity === 'HIGH' || inc.severity === 'CRITICAL' ? 'warn' : 'neutral' %>" style="font-size:0.7rem;"><%= inc.severity %></span><% } %>
        </li>
      <% }); %>
    </ul>
  </div>
<% } %>

<form method="POST" action="/reviews/<%= review.id %>/update">
  <!-- PEOPLE FIRST -->
  <section class="card bucket-card" data-bucket="people">
    <header class="bucket-card-header">
      <div>
        <h3>People First</h3>
        <p class="muted small">
          Attitude, engagement, integrity, and how they show up for the team.
        </p>
      </div>
      <button type="button" class="btn ghost btn-small bucket-toggle" data-target="people-body">
        <span class="bucket-toggle-icon">▼</span> Collapse
      </button>
    </header>

    <div class="bucket-card-body" id="people-body">
      <div class="layout-two-column">
        <div class="field">
          <label for="positiveAttitude">
            Positive Attitude
            <span class="question-help" data-help="Shows a 'can do' attitude, participates in meetings, and communicates disagreements professionally.">
              <span class="question-help-icon">?</span>
            </span>
          </label>
          <input
            type="number"
            name="positiveAttitude"
            id="positiveAttitude"
            min="1"
            max="5"
            step="1"
            value="<%= safeVal(review.positiveAttitude) %>"
            data-comment="positiveAttitudeComment"
          />
          <textarea
            class="criteria-comment"
            name="positiveAttitudeComment"
            rows="2"
          ><%= review.positiveAttitudeComment || '' %></textarea>
        </div>

        <div class="field">
          <label for="proactive">
            Proactive
            <span class="question-help" data-help="Anticipates needs, helps the team hit goals, and offers ideas or solutions instead of waiting.">
              <span class="question-help-icon">?</span>
            </span>
          </label>
          <input
            type="number"
            name="proactive"
            id="proactive"
            min="1"
            max="5"
            step="1"
            value="<%= safeVal(review.proactive) %>"
            data-comment="proactiveComment"
          />
          <textarea
            class="criteria-comment"
            name="proactiveComment"
            rows="2"
          ><%= review.proactiveComment || '' %></textarea>
        </div>
      </div>

      <div class="field">
        <label for="integrity">
          Integrity
          <span class="question-help" data-help="Follows policies, acts consistently with company values, and gives constructive feedback professionally.">
            <span class="question-help-icon">?</span>
          </span>
        </label>
        <input
          type="number"
          name="integrity"
          id="integrity"
          min="1"
          max="5"
          step="1"
          value="<%= safeVal(review.integrity) %>"
          data-comment="integrityComment"
        />
        <textarea
          class="criteria-comment"
          name="integrityComment"
          rows="2"
        ><%= review.integrityComment || '' %></textarea>
      </div>
    </div>
  </section>

  <!-- OWNERSHIP MENTALITY -->
  <section class="card bucket-card" data-bucket="ownership">
    <header class="bucket-card-header">
