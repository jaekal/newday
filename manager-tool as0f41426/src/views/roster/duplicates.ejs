<!-- src/views/roster/duplicates.ejs -->
<%- include('../layout') %>

<style>
  .dup-page { display:flex; flex-direction:column; gap:1rem; }
  .dup-group { padding:1rem; }
  .dup-group-header { display:flex; justify-content:space-between; gap:1rem; flex-wrap:wrap; margin-bottom:0.85rem; }
  .dup-meta { display:flex; gap:0.45rem; flex-wrap:wrap; align-items:center; }

  .dup-badge {
    display:inline-flex; align-items:center; gap:0.3rem; padding:0.2rem 0.55rem;
    font-size:0.78rem; line-height:1.1; white-space:nowrap; border:1px solid rgba(255,255,255,0.08);
  }

  .dup-badge.keep { border-radius:999px; background:rgba(34,197,94,0.14); color:#dcfce7; }
  .dup-badge.remove { border-radius:999px; background:rgba(239,68,68,0.16); color:#fecaca; }

  .dup-table { width:100%; border-collapse:collapse; }
  .dup-table th, .dup-table td {
    padding:0.6rem 0.65rem; text-align:left; border-top:1px solid rgba(75,85,99,0.32); vertical-align:middle; font-size:0.9rem;
  }
  .dup-table thead { background:rgba(31,41,55,0.96); color:#e5e7eb; }
</style>

<section class="dup-page">
  <section class="page-header" style="display:flex; justify-content:space-between; gap:1rem; flex-wrap:wrap; align-items:flex-end;">
    <div>
      <h2>Roster Duplicate Preview</h2>
      <p class="muted">Preview duplicate roster entries by employee ID before running dedupe.</p>
    </div>

    <div style="display:flex; gap:0.5rem; flex-wrap:wrap;">
      <a href="/roster" class="btn ghost">Back to Roster</a>
      <form method="POST" action="/roster/dedupe" style="display:inline;">
        <button type="submit" class="btn danger" onclick="return confirm('Run dedupe now? This will remove duplicate rows.');">
          Run Dedupe
        </button>
      </form>
    </div>
  </section>

  <% if (!groups || groups.length === 0) { %>
    <div class="card" style="padding:1rem;">
      <p class="muted" style="margin:0;">No duplicate employee IDs were found.</p>
    </div>
  <% } else { %>
    <% groups.forEach(function (g) { %>
      <div class="card dup-group">
        <div class="dup-group-header">
          <div>
            <strong>Employee ID:</strong> <%= g.employeeId %>
          </div>
          <div class="dup-meta">
            <span class="dup-badge keep">Keep ID #<%= g.keepId %></span>
            <span class="dup-badge remove"><%= g.duplicateRows.length %> duplicate(s) removed</span>
          </div>
        </div>

        <table class="dup-table" cellpadding="0" cellspacing="0">
          <thead>
            <tr>
              <th>Action</th>
              <th>ID</th>
              <th>Domain Username</th>
              <th>Roster Name</th>
              <th>Email</th>
              <th>Building</th>
              <th>Shift</th>
            </tr>
          </thead>
          <tbody>
            <% g.allRows.forEach(function (r, idx) { %>
              <tr>
                <td>
                  <% if (idx === 0) { %>
                    <span class="dup-badge.keep dup-badge keep">Keep</span>
                  <% } else { %>
                    <span class="dup-badge remove">Remove</span>
                  <% } %>
                </td>
                <td><%= r.id %></td>
                <td><%= r.domainUsername || '—' %></td>
                <td><%= r.fullName || '—' %></td>
                <td><%= r.email || '—' %></td>
                <td><%= r.building || '—' %></td>
                <td><%= r.shift || '—' %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% }) %>
  <% } %>
</section>