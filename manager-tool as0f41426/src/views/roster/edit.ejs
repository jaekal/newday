<!-- src/views/roster/edit.ejs -->
<%- include('../layout') %>

<style>
  .roster-edit-page {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .roster-edit-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .roster-edit-header h2 {
    margin-bottom: 0.2rem;
  }

  .roster-edit-header p {
    margin: 0;
    max-width: 820px;
  }

  .roster-edit-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(240px, 1fr));
    gap: 0.9rem 1rem;
  }

  .roster-edit-field {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .roster-edit-field.full {
    grid-column: 1 / -1;
  }

  .roster-edit-field label {
    font-size: 0.82rem;
    color: rgba(156,163,175,0.96);
  }

  .roster-edit-field input,
  .roster-edit-field textarea {
    width: 100%;
  }

  .roster-edit-status {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    align-items: center;
  }

  .status-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.2rem 0.55rem;
    font-size: 0.78rem;
    line-height: 1.1;
    white-space: nowrap;
    border: 1px solid rgba(255,255,255,0.08);
  }

  .status-badge.linked {
    border-radius: 999px;
    border: 1px dashed rgba(34, 197, 94, 0.55);
    color: #dcfce7;
  }

  .status-badge.unlinked {
    border-radius: 999px;
    border: 1px dashed rgba(156, 163, 175, 0.55);
    color: #d1d5db;
  }

  .roster-edit-actions {
    display: flex;
    justify-content: flex-end;
    gap: 0.6rem;
    flex-wrap: wrap;
  }

  @media (max-width: 780px) {
    .roster-edit-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<section class="roster-edit-page">
  <section class="page-header roster-edit-header">
    <div>
      <h2>Edit Roster Entry</h2>
      <p class="muted">
        Update a single roster mapping without reimporting the full file.
      </p>
    </div>

    <div class="roster-edit-status">
      <% if (row && row.isLinkedToUser) { %>
        <span class="status-badge linked">
          Linked to <%= row.linkedUserName || 'User' %>
          <% if (row.linkedUsername) { %> • <%= row.linkedUsername %><% } %>
        </span>
      <% } else { %>
        <span class="status-badge unlinked">Not linked to a user</span>
      <% } %>
    </div>
  </section>

  <% if (error) { %>
    <div class="card" style="padding:0.85rem 1rem; color:#fecaca; border-color:rgba(239,68,68,0.35);">
      <%= error %>
    </div>
  <% } %>

  <form method="POST" action="/roster/<%= row.id %>/update" class="card" style="padding:1rem;">
    <div class="roster-edit-grid">
      <div class="roster-edit-field">
        <label for="domainUsername">Domain Username</label>
        <input id="domainUsername" name="domainUsername" type="text" value="<%= row.domainUsername || '' %>" required />
      </div>

      <div class="roster-edit-field">
        <label for="employeeId">Employee ID</label>
        <input id="employeeId" name="employeeId" type="text" value="<%= row.employeeId || '' %>" required />
      </div>

      <div class="roster-edit-field">
        <label for="fullName">Roster Name</label>
        <input id="fullName" name="fullName" type="text" value="<%= row.fullName || '' %>" />
      </div>

      <div class="roster-edit-field">
        <label for="email">Email</label>
        <input id="email" name="email" type="email" value="<%= row.email || '' %>" />
      </div>

      <div class="roster-edit-field">
        <label for="building">Building</label>
        <input id="building" name="building" type="text" value="<%= row.building || '' %>" />
      </div>

      <div class="roster-edit-field">
        <label for="shift">Shift</label>
        <input id="shift" name="shift" type="text" value="<%= row.shift || '' %>" />
      </div>

      <div class="roster-edit-field full">
        <label for="notes">Notes</label>
        <textarea id="notes" name="notes" rows="5"><%= row.notes || '' %></textarea>
      </div>
    </div>

    <div class="roster-edit-actions" style="margin-top:1rem;">
      <a href="/roster" class="btn ghost">Cancel</a>
      <button type="submit" class="btn primary">Save Changes</button>
    </div>
  </form>
</section>