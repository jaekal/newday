<!-- src/views/roster/importPreview.ejs -->
<%- include('../layout') %>

<style>
  .preview-page { display:flex; flex-direction:column; gap:1rem; }
  .preview-table-wrap { overflow-x:auto; }
  .preview-table { width:100%; border-collapse:collapse; min-width:1100px; }
  .preview-table th, .preview-table td {
    padding:0.6rem 0.65rem; text-align:left; border-top:1px solid rgba(75,85,99,0.32); vertical-align:top;
  }
  .preview-table thead { background:rgba(31,41,55,0.96); color:#e5e7eb; }
  .preview-badge {
    display:inline-flex; align-items:center; gap:0.3rem; padding:0.18rem 0.48rem;
    font-size:0.74rem; line-height:1.1; white-space:nowrap; border:1px solid rgba(255,255,255,0.08);
    margin-right:0.3rem; margin-bottom:0.25rem;
  }
  .preview-badge.valid { border-radius:999px; background:rgba(34,197,94,0.14); color:#dcfce7; }
  .preview-badge.invalid { border-radius:999px; background:rgba(239,68,68,0.16); color:#fecaca; }
  .preview-badge.warn { border-radius:999px; background:rgba(245,158,11,0.16); color:#fde68a; }
</style>

<section class="preview-page">
  <section class="page-header" style="display:flex; justify-content:space-between; gap:1rem; flex-wrap:wrap; align-items:flex-end;">
    <div>
      <h2>Roster Import Preview</h2>
      <p class="muted">Review the parsed file before applying the import.</p>
    </div>

    <div style="display:flex; gap:0.5rem; flex-wrap:wrap;">
      <a href="/roster/import" class="btn ghost">Back</a>
    </div>
  </section>

  <div class="card" style="padding:1rem;">
    <div style="display:flex; gap:0.75rem; flex-wrap:wrap; align-items:center;">
      <span class="preview-badge valid">Valid rows: <%= (previewRows || []).filter(r => r.isValid).length %></span>
      <span class="preview-badge invalid">Invalid rows: <%= (previewRows || []).filter(r => !r.isValid).length %></span>
      <span class="preview-badge warn">Warnings: <%= (previewRows || []).filter(r => r.warnings && r.warnings.length).length %></span>
    </div>
  </div>

  <div class="card preview-table-wrap">
    <table class="preview-table" cellpadding="0" cellspacing="0">
      <thead>
        <tr>
          <th>Row</th>
          <th>Status</th>
          <th>Domain Username</th>
          <th>Employee ID</th>
          <th>Roster Name</th>
          <th>Email</th>
          <th>Building</th>
          <th>Shift</th>
          <th>Issues / Warnings</th>
        </tr>
      </thead>
      <tbody>
        <% if (!previewRows || previewRows.length === 0) { %>
          <tr>
            <td colspan="9" class="muted" style="padding:1rem; text-align:center;">No preview rows found.</td>
          </tr>
        <% } else { %>
          <% previewRows.forEach(function (r) { %>
            <tr>
              <td><%= r.rowNumber %></td>
              <td>
                <% if (r.isValid) { %>
                  <span class="preview-badge valid">Ready</span>
                <% } else { %>
                  <span class="preview-badge invalid">Invalid</span>
                <% } %>
              </td>
              <td><%= r.domainUsername || '—' %></td>
              <td><%= r.employeeId || '—' %></td>
              <td><%= r.fullName || '—' %></td>
              <td><%= r.email || '—' %></td>
              <td><%= r.building || '—' %></td>
              <td><%= r.shift || '—' %></td>
              <td>
                <% if (r.issues && r.issues.length) { %>
                  <% r.issues.forEach(function (issue) { %>
                    <div class="preview-badge invalid"><%= issue %></div>
                  <% }) %>
                <% } %>
                <% if (r.warnings && r.warnings.length) { %>
                  <% r.warnings.forEach(function (warning) { %>
                    <div class="preview-badge warn"><%= warning %></div>
                  <% }) %>
                <% }) %>
                <% if ((!r.issues || !r.issues.length) && (!r.warnings || !r.warnings.length)) { %>
                  <span class="muted">No issues</span>
                <% } %>
              </td>
            </tr>
          <% }) %>
        <% } %>
      </tbody>
    </table>
  </div>

  <form method="POST" action="/roster/import">
    <input type="hidden" name="importPayload" value="<%= importPayload %>" />
    <div style="display:flex; justify-content:flex-end; gap:0.6rem; flex-wrap:wrap;">
      <a href="/roster/import" class="btn ghost">Cancel</a>
      <button type="submit" class="btn primary" onclick="return confirm('Apply this import?');">
        Confirm Import
      </button>
    </div>
  </form>
</section>